{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/dist/cli.js hook --agent codex"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/dist/cli.js hook --agent codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node packages/cli/dist/cli.js hook --agent codex"
          }
        ]
      }
    ]
  }
}
