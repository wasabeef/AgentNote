{
  "name": "agent-note",
  "version": "1.0.4",
  "description": "Remember why your code changed. Link AI agent sessions to git commits.",
  "author": "Daichi Furiya (wasabeef)",
  "type": "module",
  "bin": {
    "agent-note": "./dist/cli.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx src/cli.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' | xargs node --import tsx/esm --test",
    "test:coverage": "find src -name '*.test.ts' | xargs node --import tsx/esm --test --experimental-test-coverage",
    "prepack": "node scripts/prepare-package-files.mjs",
    "postpack": "node scripts/clean-package-files.mjs",
    "prepublishOnly": "npm run build && npx publint"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "git",
    "session",
    "agent-note",
    "ai",
    "traceability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wasabeef/AgentNote.git",
    "directory": "packages/cli"
  },
  "homepage": "https://wasabeef.github.io/AgentNote/",
  "bugs": {
    "url": "https://github.com/wasabeef/AgentNote/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^20.19.41",
    "esbuild": "^0.28.0",
    "publint": "^0.3.20",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
