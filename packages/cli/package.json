{
  "name": "agent-note",
  "version": "0.2.2",
  "description": "Remember why your code changed. Link AI agent sessions to git commits.",
  "type": "module",
  "bin": {
    "agent-note": "./dist/cli.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx src/cli.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' | xargs node --import tsx/esm --test",
    "test:coverage": "find src -name '*.test.ts' | xargs node --import tsx/esm --test --experimental-test-coverage",
    "prepublishOnly": "npm run build && npx publint"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "cursor",
    "gemini",
    "git",
    "session",
    "agent-note",
    "ai",
    "traceability"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wasabeef/AgentNote.git",
    "directory": "packages/cli"
  },
  "homepage": "https://wasabeef.github.io/AgentNote/",
  "bugs": {
    "url": "https://github.com/wasabeef/AgentNote/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "agent-note-pr-report": "file:../pr-report"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "publint": "^0.3.18",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
