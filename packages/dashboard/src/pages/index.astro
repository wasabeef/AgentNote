---
import { existsSync, readdirSync, readFileSync } from "node:fs";
import { resolve } from "node:path";
import { fileURLToPath } from "node:url";

interface DashboardCommitSummary {
  sha: string;
  short_sha: string;
  message: string;
  date: string;
  author: string;
  agent: string | null;
  model: string | null;
  session_id: string | null;
  ai_ratio: number;
  lines_ai: number;
  lines_total: number;
  turns: number;
  note_url: string;
}

interface DashboardPrSummary {
  number: number;
  title: string;
  commits: string[];
}

interface DashboardIndexData {
  version: number;
  generated_at: string;
  repo: string;
  prs: DashboardPrSummary[];
  commits: DashboardCommitSummary[];
}

const baseUrl = import.meta.env.BASE_URL;
const homePath = `${baseUrl}`;
const repoUrl = "https://github.com/wasabeef/AgentNote";
const notesDir = resolve(fileURLToPath(new URL("../../public/view-demo/notes", import.meta.url)));

function stringValue(value: unknown): string {
  return typeof value === "string" ? value : "";
}

function numberValue(value: unknown): number {
  return typeof value === "number" ? value : 0;
}

function buildDashboardIndex(): DashboardIndexData {
  const noteFiles = existsSync(notesDir)
    ? readdirSync(notesDir).filter((file) => file.endsWith(".json")).sort()
    : [];

  const noteRecords = noteFiles
    .map((file) => {
      try {
        const raw = readFileSync(resolve(notesDir, file), "utf-8");
        return {
          file,
          note: JSON.parse(raw) as Record<string, unknown>,
        };
      } catch {
        return null;
      }
    })
    .filter(Boolean) as Array<{ file: string; note: Record<string, unknown> }>;

  const commits = noteRecords
    .map(({ file, note }) => {
      const commit = (note.commit ?? {}) as Record<string, unknown>;
      const attribution = (note.attribution ?? {}) as Record<string, unknown>;
      const lines = (attribution.lines ?? {}) as Record<string, unknown>;
      const interactions = Array.isArray(note.interactions) ? note.interactions : [];
      const shortSha = stringValue(commit.short_sha) || file.replace(/\.json$/, "");

      return {
        sha: stringValue(commit.sha) || shortSha,
        short_sha: shortSha,
        message: stringValue(commit.message) || shortSha,
        date: stringValue(commit.date),
        author: stringValue(commit.author),
        agent: stringValue(note.agent) || null,
        model: stringValue(note.model) || null,
        session_id: stringValue(note.session_id) || null,
        ai_ratio: numberValue(attribution.ai_ratio),
        lines_ai: numberValue(lines.ai_added),
        lines_total: numberValue(lines.total_added),
        turns: interactions.length,
        note_url: `${baseUrl}/view-demo/notes/${file}`.replace(/\/+/g, "/"),
      } satisfies DashboardCommitSummary;
    })
    .sort((a, b) => {
      const dateCompare = b.date.localeCompare(a.date);
      if (dateCompare !== 0) return dateCompare;
      return b.short_sha.localeCompare(a.short_sha);
    });

  const prs = new Map<number, { number: number; title: string; commits: Array<{ short_sha: string; date: string }> }>();

  for (const { note } of noteRecords) {
    const pullRequest = (note.pull_request ?? {}) as Record<string, unknown>;
    const commit = (note.commit ?? {}) as Record<string, unknown>;
    const number = typeof pullRequest.number === "number" ? pullRequest.number : null;
    if (number == null) continue;

    const title = stringValue(pullRequest.title) || `PR #${number}`;
    const shortSha = stringValue(commit.short_sha);
    if (!shortSha) continue;

    if (!prs.has(number)) {
      prs.set(number, { number, title, commits: [] });
    }
    prs.get(number)?.commits.push({
      short_sha: shortSha,
      date: stringValue(commit.date),
    });
  }

  return {
    version: 1,
    generated_at: new Date().toISOString(),
    repo: "wasabeef/AgentNote",
    prs: [...prs.values()]
      .map((pr) => ({
        number: pr.number,
        title: pr.title,
        commits: pr.commits
          .sort((a, b) => {
            const dateCompare = b.date.localeCompare(a.date);
            if (dateCompare !== 0) return dateCompare;
            return b.short_sha.localeCompare(a.short_sha);
          })
          .map((commit) => commit.short_sha),
      }))
      .sort((a, b) => b.number - a.number),
    commits,
  };
}

const dashboardIndex = buildDashboardIndex();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Note — Chat Viewer</title>
    <link rel="icon" href={`${baseUrl}/favicon.svg`.replace(/\/+/g, "/")} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0b1220;
        --panel-2: #111c2e;
        --panel-3: #18253b;
        --border: #1e2a44;
        --border-strong: #334155;
        --text: #f1f5f9;
        --text-soft: #cbd5e1;
        --muted: #94a3b8;
        --muted-2: #64748b;
        --accent: #22c55e;
        --accent-2: #86efac;
        --accent-dim: rgba(34, 197, 94, 0.14);
        --user-bubble: linear-gradient(180deg, #166534, #14532d);
        --user-bubble-text: #ecfccb;
        --ai-bubble: #111c2e;
        --code-bg: #030712;
        --code-border: #1e293b;
        --chip-bg: #0f172a;
        --diff-add: rgba(34, 197, 94, 0.13);
        --diff-add-text: #86efac;
        --diff-del: rgba(239, 68, 68, 0.13);
        --diff-del-text: #fca5a5;
        --diff-hunk: rgba(59, 130, 246, 0.1);
        --diff-hunk-text: #93c5fd;
        --shadow: 0 6px 24px rgba(2, 6, 23, 0.6);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          'IBM Plex Sans', -apple-system, BlinkMacSystemFont,
          'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      code, pre, kbd {
        font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
      }
      button {
        font-family: inherit;
      }

      /* ─── App skeleton ─── */
      .app {
        display: grid;
        grid-template-columns: 292px minmax(0, 1fr);
        min-height: 100vh;
      }
      @media (max-width: 1180px) {
        .app {
          grid-template-columns: 268px minmax(0, 1fr);
        }
      }
      @media (max-width: 960px) {
        .app, .app.wide { grid-template-columns: 1fr; }
        .sidebar {
          position: fixed; inset: 0 auto 0 0; z-index: 40;
          width: min(86vw, 320px);
          transform: translateX(-100%);
          transition: transform 200ms ease;
        }
        .sidebar.open { transform: translateX(0); box-shadow: 4px 0 40px rgba(0,0,0,0.5); }
        .overlay {
          position: fixed; inset: 0; z-index: 35;
          background: rgba(0,0,0,0.5);
          display: none;
        }
        .overlay.show { display: block; }
      }

      /* ─── Sidebar ─── */
      .sidebar {
        background: var(--panel);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        max-height: 100vh;
        position: sticky;
        top: 0;
      }
      .sidebar-header {
        padding: 0.9rem 1rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .sidebar-header .logo {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.01em;
      }
      .sidebar-header .logo::before {
        content: "";
        width: 22px; height: 22px;
        background: var(--accent);
        mask-image: radial-gradient(circle, black 25%, transparent 26%);
        border-radius: 6px;
      }
      .badge {
        padding: 0.15rem 0.55rem;
        font-size: 0.62rem;
        border-radius: 999px;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .badge.accent { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }

      .tab-row {
        display: flex;
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid var(--border);
        gap: 0.25rem;
        background: var(--panel);
      }
      .tab-row button {
        flex: 1;
        padding: 0.45rem;
        background: transparent;
        border: 1px solid transparent;
        color: var(--muted);
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.78rem;
      }
      .tab-row button:hover { color: var(--text-soft); background: var(--panel-2); }
      .tab-row button.active { color: var(--accent); background: var(--accent-dim); border-color: var(--accent); }

      .search {
        padding: 0.55rem 0.8rem 0.8rem;
        position: relative;
      }
      .search input {
        width: 100%;
        padding: 0.55rem 0.8rem 0.55rem 2rem;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        color: var(--text);
        font-family: inherit;
        font-size: 0.85rem;
        outline: none;
      }
      .search input:focus { border-color: var(--accent); }
      .search::before {
        content: "🔍";
        position: absolute;
        left: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        opacity: 0.5;
      }
      .search kbd {
        position: absolute;
        right: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        padding: 0.1rem 0.4rem;
        font-size: 0.65rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        border-radius: 4px;
        color: var(--muted);
      }

      .sidebar-list {
        overflow-y: auto;
        flex: 1;
        padding: 0.25rem 0 2rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border-strong) transparent;
      }
      .sidebar-list::-webkit-scrollbar { width: 6px; }
      .sidebar-list::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

      .group-label {
        padding: 0.75rem 1rem 0.3rem;
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }

      .pr-card, .commit-card, .session-card {
        margin: 0.15rem 0.55rem;
        padding: 0.65rem 0.85rem;
        border-radius: 10px;
        cursor: pointer;
        transition: background 120ms, border-color 120ms, transform 120ms;
        border: 1px solid transparent;
        position: relative;
        overflow: hidden;
      }
      .pr-card::before,
      .commit-card::before,
      .session-card::before,
      .tree-commit::before,
      .turn-node::before {
        content: "";
        position: absolute;
        left: 0;
        top: 10px;
        bottom: 10px;
        width: 3px;
        border-radius: 0 999px 999px 0;
        opacity: 0;
        transform: scaleY(0.72);
        transition: opacity 120ms, transform 120ms;
      }
      .pr-card::before,
      .commit-card::before,
      .session-card::before,
      .tree-commit::before {
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
      }
      .turn-node::before {
        background: linear-gradient(180deg, #60a5fa, #bfdbfe);
      }
      .pr-card:hover, .commit-card:hover, .session-card:hover {
        background: var(--panel-2);
      }
      .pr-card.active, .commit-card.active, .session-card.active {
        background: var(--accent-dim);
        border-color: rgba(34, 197, 94, 0.55);
        box-shadow: inset 0 0 0 1px rgba(134, 239, 172, 0.08);
        transform: translateY(1px);
      }
      .pr-card.active::before,
      .commit-card.active::before,
      .session-card.active::before,
      .tree-commit.active::before,
      .turn-node.active::before {
        opacity: 1;
        transform: scaleY(1);
      }
      .card-title {
        font-size: 0.83rem;
        color: var(--text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-meta {
        margin-top: 0.3rem;
        font-size: 0.68rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .card-meta .sha { color: var(--accent); }
      .card-meta .ratio { color: var(--accent-2); }
      .ratio-bar {
        margin-top: 0.4rem;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .ratio-bar span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .pr-card .pr-commits {
        margin-top: 0.4rem;
        font-size: 0.68rem;
        color: var(--muted);
        display: flex;
        gap: 0.4rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .sidebar-tree {
        margin: 0.12rem 0.55rem 0.55rem 1.1rem;
        padding-left: 0.75rem;
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.22rem;
      }
      .tree-section-label {
        margin: 0.28rem 0 0.24rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.54rem;
        letter-spacing: 0.14em;
        line-height: 1.35;
        text-transform: uppercase;
      }
      .tree-commit,
      .turn-node {
        width: 100%;
        border: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        text-align: left;
        border-radius: 9px;
        cursor: pointer;
        transition: background 120ms, border-color 120ms, color 120ms, transform 120ms;
        position: relative;
        overflow: hidden;
      }
      .tree-commit {
        padding: 0.5rem 0.65rem;
      }
      .tree-commit:hover,
      .turn-node:hover {
        background: var(--panel-2);
        color: var(--text);
      }
      .tree-commit.active {
        background: rgba(34, 197, 94, 0.1);
        border-color: rgba(34, 197, 94, 0.4);
        color: var(--text);
        box-shadow: inset 0 0 0 1px rgba(134, 239, 172, 0.08);
        transform: translateY(1px);
      }
      .tree-commit.scroll-target {
        border-style: dashed;
      }
      .tree-commit-title {
        font-size: 0.78rem;
        line-height: 1.35;
        color: inherit;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .tree-commit-meta {
        margin-top: 0.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0.55rem;
        font-size: 0.66rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .tree-commit-meta .sha {
        color: var(--accent);
      }
      .turn-tree {
        margin: 0.18rem 0 0.35rem 0.7rem;
        padding-left: 0.75rem;
        border-left: 1px dashed rgba(100, 116, 139, 0.5);
        display: flex;
        flex-direction: column;
        gap: 0.18rem;
      }
      .turn-node {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: start;
        gap: 0.4rem;
        padding: 0.38rem 0.55rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .turn-node.active {
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(96, 165, 250, 0.45);
        color: var(--text);
        box-shadow: inset 0 0 0 1px rgba(147, 197, 253, 0.08);
        transform: translateY(1px);
      }
      .turn-node-id {
        color: var(--accent);
      }
      .turn-node-text {
        min-width: 0;
        line-height: 1.35;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        word-break: break-word;
      }
      .turn-node-pill {
        padding: 0.08rem 0.38rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-soft);
        font-size: 0.64rem;
      }

      /* ─── Main area ─── */
      .main {
        overflow-y: auto;
        max-height: 100vh;
      }
      .main-inner {
        max-width: 860px;
        margin: 0 auto;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 1.25rem clamp(1rem, 2.2vw, 1.5rem) 5rem;
      }
      .main-footer {
        margin-top: auto;
        padding-top: 1.25rem;
      }

      .topbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        position: sticky;
        top: 0;
        z-index: 24;
        padding: 0.15rem 0 0.9rem;
        background: linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(2, 6, 23, 0.84) 72%, transparent);
        backdrop-filter: blur(14px);
      }
      .icon-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.45rem 0.75rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--muted);
        cursor: pointer;
        font-size: 0.78rem;
        transition: color 120ms, border-color 120ms, background 120ms;
      }
      .icon-btn:hover {
        color: var(--text);
        border-color: var(--border-strong);
        background: var(--panel-2);
      }
      .icon-btn.primary {
        background: var(--accent-dim);
        border-color: var(--accent);
        color: var(--accent);
      }
      .hamburger { display: none; }
      @media (max-width: 960px) { .hamburger { display: inline-flex; } }
      .spacer { flex: 1; }

      .commit-head {
        padding: 1.25rem 1.5rem;
        background:
          radial-gradient(circle at top right, rgba(34, 197, 94, 0.12), transparent 34%),
          linear-gradient(180deg, rgba(11, 18, 32, 0.96), rgba(11, 18, 32, 0.92));
        border: 1px solid rgba(51, 65, 85, 0.88);
        border-radius: 16px;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
      }
      .commit-title {
        margin: 0 0 0.5rem;
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.35;
      }
      .commit-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.9rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .commit-meta-row .sha {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent);
        cursor: pointer;
        position: relative;
      }
      .commit-meta-row .sha:hover { color: var(--accent-2); }
      .commit-meta-row .sha.copied::after {
        content: "copied!";
        position: absolute;
        left: 100%;
        margin-left: 0.5rem;
        font-size: 0.7rem;
        color: var(--accent-2);
        font-family: inherit;
      }
      .stats-row {
        margin-top: 0.9rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .stat {
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .stat.primary { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }
      .stat.outline { background: transparent; border: 1px solid var(--border-strong); color: var(--muted); }
      .stat.bar {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .stat.bar .track {
        width: 60px;
        height: 5px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
      }
      .stat.bar .track span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .stat.warm {
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(96, 165, 250, 0.5);
        color: #bfdbfe;
      }
      .commit-context-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(220px, 0.95fr);
        gap: 0.8rem;
      }
      .commit-context-card {
        padding: 0.9rem 1rem;
        background: rgba(2, 6, 23, 0.42);
        border: 1px solid rgba(51, 65, 85, 0.7);
        border-radius: 12px;
      }
      .commit-context-title {
        margin: 0 0 0.6rem;
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .meta-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.28rem 0.55rem;
        border-radius: 999px;
        background: var(--chip-bg);
        border: 1px solid var(--border-strong);
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.71rem;
        min-width: 0;
      }
      .meta-pill-label {
        color: var(--muted-2);
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .meta-pill-value {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .meta-pill.agent-pill {
        padding-left: 0.34rem;
      }
      .commit-file-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .commit-file-row {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.36rem 0.68rem;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(51, 65, 85, 0.82);
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        min-width: 0;
        max-width: 100%;
      }
      .commit-file-row .by_ai { color: var(--accent); }
      .commit-file-row .by_human { color: var(--muted-2); }
      .commit-file-name {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .commit-head,
      .collection-commit,
      .turn {
        scroll-margin-top: 5rem;
      }
      .commit-file-empty {
        color: var(--muted);
        font-size: 0.74rem;
        font-family: 'JetBrains Mono', monospace;
      }

      /* ─── Tabs / split ─── */
      .view-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
      }
      .view-tabs button {
        padding: 0.6rem 1.1rem;
        background: transparent;
        color: var(--muted);
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        font-size: 0.85rem;
        transition: color 120ms;
      }
      .view-tabs button:hover { color: var(--text); }
      .view-tabs button.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }

      /* Chat */
      .chat-pane {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .turn-divider {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.65rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        margin: 0.5rem 0;
      }
      .turn-divider::before, .turn-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .bubble-row {
        display: flex;
        gap: 0.6rem;
      }
      .bubble-row.from-user {
        justify-content: flex-end;
      }
      .bubble-row.from-ai {
        justify-content: flex-start;
      }
      .avatar {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        background: var(--panel-2);
        border: 1px solid var(--border);
      }
      .avatar.ai {
        background: linear-gradient(135deg, #14532d 0%, #166534 100%);
        border-color: var(--accent);
        color: var(--accent-2);
      }
      .avatar.ai-icon {
        width: 30px;
        height: 30px;
        padding: 0;
        border-radius: 10px;
        overflow: hidden;
        background: transparent;
        border-color: rgba(148, 163, 184, 0.35);
        box-shadow: 0 8px 20px rgba(2, 6, 23, 0.35);
      }
      .avatar.ai-icon svg {
        display: block;
        width: 100%;
        height: 100%;
      }
      .avatar-inline {
        width: 18px;
        height: 18px;
        border-radius: 6px;
        font-size: 0.72rem;
        box-shadow: none;
      }
      .bubble {
        max-width: min(82%, 540px);
        padding: 0.75rem 1rem;
        border-radius: 14px;
        line-height: 1.6;
        font-size: 0.92rem;
        word-wrap: break-word;
        position: relative;
      }
      .bubble .md { white-space: normal; }
      .bubble.user {
        background: var(--user-bubble);
        color: var(--user-bubble-text);
        border-bottom-right-radius: 4px;
      }
      .bubble.ai {
        background: var(--ai-bubble);
        color: var(--text-soft);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border);
      }
      .bubble.ai.empty {
        color: var(--muted-2);
        font-style: italic;
        display: inline-flex;
        align-items: center;
        min-height: 0;
        padding-top: 0.9rem;
        padding-bottom: 0.9rem;
      }
      /* ─── Markdown content inside bubbles ─── */
      .md {
        white-space: normal;
      }
      .md > *:first-child { margin-top: 0; }
      .md > *:last-child { margin-bottom: 0; }
      .md p { margin: 0.5rem 0; line-height: 1.65; }
      .md h1, .md h2, .md h3, .md h4 {
        margin: 1rem 0 0.45rem;
        line-height: 1.3;
        font-weight: 600;
        color: var(--text);
      }
      .md h1 { font-size: 1.15rem; }
      .md h2 { font-size: 1.05rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      .md h3 { font-size: 0.95rem; }
      .md h4 { font-size: 0.88rem; color: var(--text-soft); }
      .md ul, .md ol { margin: 0.5rem 0; padding-left: 1.4rem; }
      .md li { margin: 0.15rem 0; }
      .md li > p { margin: 0.2rem 0; }
      .md blockquote {
        margin: 0.6rem 0;
        padding: 0.25rem 0.8rem;
        border-left: 3px solid var(--accent);
        background: rgba(34, 197, 94, 0.05);
        color: var(--muted);
      }
      .md a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dashed var(--accent);
      }
      .md a:hover { color: var(--accent-2); border-bottom-style: solid; }
      .md strong { color: var(--text); font-weight: 600; }
      .md em { font-style: italic; color: var(--text-soft); }
      .md hr { border: 0; border-top: 1px solid var(--border); margin: 1rem 0; }
      .md table {
        border-collapse: collapse;
        margin: 0.75rem 0;
        font-size: 0.85rem;
        width: 100%;
      }
      .md th, .md td {
        border: 1px solid var(--border);
        padding: 0.35rem 0.7rem;
        text-align: left;
      }
      .md th {
        background: var(--panel-2);
        color: var(--text);
        font-weight: 600;
        font-size: 0.8rem;
      }
      .md pre {
        margin: 0.65rem 0;
        padding: 0.75rem 1rem;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 8px;
        font-size: 0.82rem;
        line-height: 1.55;
        overflow-x: auto;
        white-space: pre;
      }
      .md pre code {
        color: var(--text-soft);
        background: transparent;
        padding: 0;
        font-size: inherit;
      }
      .md code:not(pre code) {
        padding: 0.1em 0.35em;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 4px;
        font-size: 0.86em;
        color: var(--accent-2);
      }
      .md img {
        max-width: 100%;
        border-radius: 8px;
        margin: 0.5rem 0;
      }
      .md input[type="checkbox"] { margin-right: 0.4rem; }

      .bubble-footer {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.55rem;
        background: var(--chip-bg);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .chip.tool { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
      .chip.file::before {
        content: "📄";
        font-size: 0.7rem;
        opacity: 0.6;
      }
      .turn-label {
        color: var(--muted-2);
        font-size: 0.65rem;
        font-family: 'JetBrains Mono', monospace;
        margin: 0 0.5rem;
        align-self: flex-end;
      }

      .bubble-actions {
        position: absolute;
        top: -0.5rem;
        right: 0.5rem;
        display: none;
        gap: 0.2rem;
      }
      .bubble:hover .bubble-actions { display: flex; }
      .bubble-actions button {
        padding: 0.15rem 0.45rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        color: var(--muted);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.65rem;
      }
      .bubble-actions button:hover { color: var(--text); border-color: var(--accent); }

      .collapsed-hint {
        color: var(--muted-2);
        font-size: 0.75rem;
        cursor: pointer;
        margin-top: 0.3rem;
        font-style: italic;
      }
      .collapsed-hint:hover { color: var(--accent); }

      /* Diff */
      .diff-pane {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .diff-file {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: var(--panel);
      }
      .diff-file-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: var(--panel-2);
        border-bottom: 1px solid var(--border);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: var(--text);
        cursor: pointer;
      }
      .diff-file-header:hover { background: var(--panel-3); }
      .diff-file-header .caret {
        color: var(--muted);
        transition: transform 150ms;
        display: inline-block;
      }
      .diff-file.collapsed .caret { transform: rotate(-90deg); }
      .diff-file.collapsed .diff-body, .diff-file.collapsed .diff-truncated { display: none; }
      .diff-file-header .stats {
        margin-left: auto;
        font-size: 0.7rem;
        color: var(--muted);
        display: flex;
        gap: 0.5rem;
      }
      .diff-file-header .stats .added { color: var(--diff-add-text); }
      .diff-file-header .stats .removed { color: var(--diff-del-text); }
      .diff-body {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.76rem;
        line-height: 1.55;
        overflow-x: auto;
      }
      .diff-line {
        display: grid;
        grid-template-columns: 48px 1fr;
        white-space: pre;
      }
      .diff-line .lineno {
        background: var(--panel);
        color: var(--muted-2);
        padding: 0 0.5rem;
        text-align: right;
        font-size: 0.7rem;
        border-right: 1px solid var(--border);
        user-select: none;
      }
      .diff-line .content { padding: 0 1rem; }
      .diff-line.add .content { background: var(--diff-add); color: var(--diff-add-text); }
      .diff-line.del .content { background: var(--diff-del); color: var(--diff-del-text); }
      .diff-line.hunk .content { background: var(--diff-hunk); color: var(--diff-hunk-text); font-weight: 600; }
      .diff-line.meta { display: none; } /* suppress diff/index/+++/--- headers for cleanliness */
      .diff-truncated {
        padding: 0.5rem 1rem;
        color: var(--muted);
        font-style: italic;
        background: var(--panel-2);
        border-top: 1px solid var(--border);
        font-size: 0.74rem;
      }

      /* Aggregate views */
      .collection-head {
        padding: 1.35rem 1.5rem;
        background:
          radial-gradient(circle at top right, rgba(34, 197, 94, 0.14), transparent 32%),
          linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(11, 18, 32, 0.96));
        border: 1px solid var(--border);
        border-radius: 18px;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
      }
      .collection-kicker {
        margin-bottom: 0.45rem;
        color: var(--accent-2);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-family: 'JetBrains Mono', monospace;
      }
      .collection-title {
        margin: 0;
        font-size: 1.3rem;
        line-height: 1.25;
        letter-spacing: -0.02em;
      }
      .collection-subtitle {
        margin: 0.55rem 0 0;
        color: var(--text-soft);
        font-size: 0.95rem;
        line-height: 1.7;
      }
      .collection-jump-list {
        margin-top: 1rem;
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .jump-chip {
        padding: 0.35rem 0.7rem;
        background: rgba(15, 23, 42, 0.9);
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        cursor: pointer;
      }
      .jump-chip:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      .collection-pane {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .collection-commit {
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(11, 18, 32, 0.95), rgba(15, 23, 42, 0.98));
        box-shadow: var(--shadow);
      }
      .collection-commit-head {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        justify-content: space-between;
        padding: 1rem 1.15rem;
        border-bottom: 1px solid var(--border);
        background: rgba(17, 28, 46, 0.7);
      }
      .collection-commit-head-main {
        min-width: 0;
      }
      .collection-commit-kicker {
        margin-bottom: 0.35rem;
        color: var(--muted-2);
        font-size: 0.7rem;
        font-family: 'JetBrains Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .collection-commit-title {
        margin: 0;
        font-size: 1rem;
        line-height: 1.4;
      }
      .collection-commit-meta {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.8rem;
        color: var(--muted);
        font-size: 0.74rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .collection-commit-actions {
        display: flex;
        gap: 0.45rem;
        flex-shrink: 0;
      }
      .collection-commit-body {
        padding: 1rem 1.15rem 1.15rem;
      }
      .collection-commit .chat-pane {
        gap: 1rem;
      }
      .collection-commit .bubble {
        max-width: min(88%, 640px);
      }
      .collection-commit details {
        margin-top: 1rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: rgba(2, 6, 23, 0.45);
      }
      .collection-commit summary {
        list-style: none;
        cursor: pointer;
        padding: 0.8rem 1rem;
        color: var(--text-soft);
        font-size: 0.82rem;
        font-family: 'JetBrains Mono', monospace;
        background: rgba(15, 23, 42, 0.95);
        border-bottom: 1px solid transparent;
      }
      .collection-commit details[open] summary {
        border-bottom-color: var(--border);
      }
      .collection-commit summary::-webkit-details-marker {
        display: none;
      }

      .right-rail {
        padding: 1.5rem 1.25rem;
        background: var(--panel);
        border-left: 1px solid var(--border);
        overflow-y: auto;
        max-height: 100vh;
      }
      .right-rail h3 {
        margin: 0 0 0.5rem;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .right-rail .section { margin-bottom: 1.5rem; }
      .right-rail .file-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 0.83rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        cursor: default;
      }
      .right-rail .file-row:hover { background: var(--panel-2); color: var(--text); }
      .right-rail button.file-row {
        width: 100%;
        border: none;
        background: transparent;
        text-align: left;
        font: inherit;
      }
      .right-rail .file-row .by_ai { color: var(--accent); }
      .right-rail .file-row .by_human { color: var(--muted-2); }
      .right-rail .kv {
        font-size: 0.78rem;
        color: var(--muted);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.3rem 0.8rem;
      }
      .right-rail .kv dt { color: var(--muted-2); font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
      .right-rail .kv dd { margin: 0; color: var(--text-soft); font-family: 'JetBrains Mono', monospace; font-size: 0.76rem; }
      .right-rail .file-row.active {
        background: var(--accent-dim);
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .right-rail .pill {
        margin-left: auto;
        padding: 0.08rem 0.4rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-soft);
        font-size: 0.66rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .right-rail .nav-row {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: start;
      }
      .right-rail .row-id {
        flex-shrink: 0;
        font-size: 0.68rem;
      }
      .right-rail .row-main {
        min-width: 0;
        line-height: 1.35;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        word-break: break-word;
      }
      .right-rail .nav-row .pill {
        margin-left: 0;
        align-self: start;
        font-size: 0.68rem;
      }

      /* Empty state */
      .empty {
        padding: 4rem 1rem;
        text-align: center;
        color: var(--muted);
      }
      .empty .big { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        padding: 0.6rem 1rem;
        background: var(--panel-3);
        border: 1px solid var(--accent);
        border-radius: 10px;
        color: var(--accent-2);
        font-size: 0.85rem;
        transition: transform 200ms ease;
        z-index: 60;
        font-family: 'JetBrains Mono', monospace;
      }
      .toast.show { transform: translateX(-50%) translateY(0); }

      /* Keyboard hints */
      .hints {
        margin-top: 2rem;
        padding: 1rem 1.25rem;
        background: var(--panel);
        border-radius: 10px;
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.8;
      }
      .hints kbd {
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        padding: 0.1rem 0.45rem;
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--text-soft);
      }
      @media (max-width: 960px) {
        .main {
          max-height: none;
        }
        .main-inner {
          padding: 1rem 0.9rem 4rem;
        }
        .topbar {
          padding-bottom: 0.7rem;
        }
        .commit-head,
        .collection-commit,
        .turn {
          scroll-margin-top: 5rem;
        }
      }
      @media (max-width: 720px) {
        .topbar {
          gap: 0.4rem;
        }
        .spacer {
          display: none;
        }
        .icon-btn {
          padding: 0.4rem 0.65rem;
          font-size: 0.74rem;
        }
        .commit-head,
        .collection-head {
          padding: 1rem;
        }
        .collection-commit-head,
        .collection-commit-body {
          padding: 0.9rem 1rem;
        }
        .commit-context-grid {
          grid-template-columns: 1fr;
        }
        .view-tabs {
          gap: 0;
        }
        .view-tabs button {
          flex: 1;
          padding: 0.6rem 0.75rem;
          text-align: center;
        }
        .bubble {
          max-width: calc(100vw - 5rem);
        }
        .turn-label {
          display: none;
        }
        .turn .bubble-footer {
          margin-left: 0 !important;
        }
      }
      @media (max-width: 560px) {
        .commit-meta-row {
          gap: 0.25rem 0.6rem;
          font-size: 0.74rem;
        }
        .stats-row {
          gap: 0.35rem;
        }
        .stat {
          padding: 0.28rem 0.6rem;
          font-size: 0.7rem;
        }
        .collection-jump-list {
          flex-wrap: nowrap;
          overflow-x: auto;
          padding-bottom: 0.25rem;
          scrollbar-width: thin;
        }
        .jump-chip {
          white-space: nowrap;
        }
      }
    </style>
  </head>
  <body>
    <div class="overlay" id="overlay"></div>
    <div class="app" id="app">
      <!-- ─── Sidebar ─── -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <a href={homePath} class="logo">Agent Note</a>
          <span class="badge accent">Preview</span>
        </div>
        <div class="tab-row" id="tab-row">
          <button data-tab="prs" class="active">PRs</button>
          <button data-tab="commits">Commits</button>
        </div>
        <div class="search">
          <input id="search-box" type="search" placeholder="Search…" autocomplete="off" />
          <kbd>/</kbd>
        </div>
        <div class="sidebar-list" id="sidebar-list">
          <div class="empty"><div class="big">⏳</div>Loading…</div>
        </div>
      </aside>

      <!-- ─── Main ─── -->
      <main class="main" id="main">
        <div class="main-inner" id="main-inner">
          <div class="topbar">
            <button class="icon-btn hamburger" id="btn-menu" aria-label="Menu">☰</button>
            <button class="icon-btn" id="btn-prev" aria-label="Previous commit">← prev</button>
            <button class="icon-btn" id="btn-next" aria-label="Next commit">next →</button>
            <div class="spacer"></div>
            <a class="icon-btn" id="btn-github" href={repoUrl} target="_blank" rel="noopener">GitHub ↗</a>
          </div>

          <div id="root">
            <div class="empty">
              <div class="big">💬</div>
              Pick a commit from the sidebar.
            </div>
          </div>
          <div class="main-footer" id="main-footer"></div>
        </div>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline define:vars={{ baseUrl, repoUrl, dashboardIndex }}>
      const state = {
        index: dashboardIndex,
        current: null,
        currentNote: null,
        currentGroupNotes: [],
        loading: false,
        loadToken: 0,
        noteCache: new Map(),
        tab: "chat",            // main tabs: chat | diff
        sideTab: "prs",         // sidebar tabs: prs | commits
        search: "",
        flatCommits: [],
        wide: false,
