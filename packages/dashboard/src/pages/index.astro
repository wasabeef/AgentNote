        const sortedByDate = [...notes].sort((a, b) => (a.commit?.date || "").localeCompare(b.commit?.date || ""));
        return {
          commits: notes.length,
          turns,
          aiAdded,
          totalAdded,
          deleted,
          uniqueFiles: fileCounts.size,
          avgRatio: notes.length ? Math.round(ratioTotal / notes.length) : 0,
          firstDate: sortedByDate[0]?.commit?.date ?? null,
          lastDate: sortedByDate[sortedByDate.length - 1]?.commit?.date ?? null,
          agents: [...agents],
          authors: [...authors],
          prNumbers: [...prNumbers],
          fileCounts: [...fileCounts.values()].sort((a, b) => b.count - a.count || a.path.localeCompare(b.path)),
        };
      }
      function commitSectionId(note) {
        return commitSectionIdFromSummary(note.commit || {});
      }
      function scrollToId(id) {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
      }
      function updateGitHubLink() {
        const link = document.getElementById("btn-github");
        if (!link) return;
        let href = repoUrl;
        let label = "GitHub ↗";
        if (state.current?.mode === "commit" && state.currentNote?.commit?.sha) {
          href = `${repoUrl}/commit/${state.currentNote.commit.sha}`;
          label = `Commit ${state.currentNote.commit.short_sha || state.currentNote.commit.sha.slice(0, 7)} ↗`;
        } else if (state.current?.mode === "pr" && state.current?.prNumber != null) {
          href = `${repoUrl}/pull/${state.current.prNumber}`;
          label = `PR #${state.current.prNumber} ↗`;
        }
        link.href = href;
        link.textContent = label;
      }

      // ─── Main ───
      function renderCommitHeader(note) {
        const c = note.commit || {};
        const attr = note.attribution || {};
        const files = note.files || [];
        const ratio = attr.ai_ratio ?? 0;
        const lines = attr.lines || {};
        const sessionShort = note.session_id ? `${note.session_id.slice(0, 8)}…` : null;

        const shaSpan = h("span", {
          className: "sha",
          title: "Click to copy full SHA",
          onClick: () => {
            copyToClipboard(c.sha || c.short_sha || "");
            shaSpan.classList.add("copied");
            setTimeout(() => shaSpan.classList.remove("copied"), 1200);
          },
        }, c.short_sha || (c.sha || "").slice(0, 7));

        return h("div", { className: "commit-head" }, [
          h("h1", { className: "commit-title" }, c.message || "(no message)"),
          h("div", { className: "commit-meta-row" }, [
            shaSpan,
            c.author && h("span", {}, c.author),
            c.date && h("span", {}, formatDateTime(c.date)),
          ].filter(Boolean)),
          h("div", { className: "stats-row" }, [
            h("span", { className: "stat primary bar" }, [
              h("span", {}, "🤖 " + ratio + "%"),
              h("span", { className: "track" }, h("span", { style: "width:" + ratio + "%;" })),
            ]),
            note.interactions && h("span", { className: "stat outline" }, note.interactions.length + " turns"),
          ].filter(Boolean)),
          h("div", { className: "commit-context-grid" }, [
            h("section", { className: "commit-context-card" }, [
              h("h2", { className: "commit-context-title" }, "Meta"),
              h("div", { className: "meta-pill-row" }, [
                renderAgentPill(note.agent, note.model),
                renderMetaPill("model", note.model),
                renderMetaPill("session", sessionShort, []),
                renderMetaPill("method", attr.method),
                renderMetaPill("added", `${lines.ai_added ?? 0} / ${lines.total_added ?? 0}`),
                renderMetaPill("deleted", String(lines.deleted ?? 0)),
              ].filter(Boolean)),
            ]),
            h("section", { className: "commit-context-card" }, [
              h("h2", { className: "commit-context-title" }, "Files in Commit"),
              renderCommitFiles(files),
            ]),
          ]),
        ]);
      }

      function renderTurn(interaction, idx, total, agent, model, anchorPrefix = "") {
        const tools = interaction.tools || [];
        const files = interaction.files_touched || [];
        const turnId = anchorPrefix + "t-" + (idx + 1);

        // User bubble — prompts are usually plain text (user input), render as markdown too for inline code support
        const userBody = h("div", {});
        renderMarkdownInto(userBody, interaction.prompt || "");
        const userRow = h("div", { className: "bubble-row from-user" }, [
          h("span", { className: "turn-label" }, "#" + (idx + 1)),
          h("div", {
            className: "bubble user",
            dataset: { turn: String(idx + 1) },
          }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy prompt",
                onClick: () => copyToClipboard(interaction.prompt || ""),
              }, "📋"),
              h("button", {
                title: "Permalink",
                onClick: () => {
                  const url = new URL(window.location.href);
                  url.hash = turnId;
                  copyToClipboard(url.toString());
                },
              }, "🔗"),
            ]),
            userBody,
          ]),
          h("div", { className: "avatar" }, "🧑"),
        ]);

        // AI bubble — markdown-rendered
        const hasResp = !!interaction.response;
        const aiBody = h("div", {});
        if (hasResp) renderMarkdownInto(aiBody, interaction.response);
        else aiBody.textContent = "(no response captured)";
        const aiRow = h("div", { className: "bubble-row from-ai" }, [
          renderAgentAvatar(agent, model),
          h("div", { className: "bubble ai" + (hasResp ? "" : " empty") }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy response",
                onClick: () => copyToClipboard(interaction.response || ""),
              }, "📋"),
            ]),
            aiBody,
          ]),
        ]);

        const footer = [];
        for (const t of tools) footer.push(h("span", { className: "chip tool" }, t));
        for (const f of files) footer.push(h("span", { className: "chip file" }, f.split("/").pop()));

        return h("div", { className: "turn", id: turnId }, [
          h("div", { className: "turn-divider" }, "turn " + (idx + 1) + " / " + total),
          userRow,
          aiRow,
          footer.length > 0 && h("div", { className: "bubble-footer", style: "margin-left: 2.3rem;" }, footer),
        ].filter(Boolean));
      }

      function renderChat(note, anchorPrefix = "") {
        const thread = h("div", { className: "chat-pane" });
        const interactions = note.interactions || [];
        interactions.forEach((i, idx) => {
          thread.appendChild(renderTurn(i, idx, interactions.length, note.agent, note.model, anchorPrefix));
        });
        return thread;
      }

      function diffStats(file) {
        let added = 0, removed = 0;
        for (const line of file.lines || []) {
          if (line.startsWith("+") && !line.startsWith("+++")) added++;
          else if (line.startsWith("-") && !line.startsWith("---")) removed++;
        }
        return { added, removed };
      }

      function renderDiff(note) {
        const wrap = h("div", { className: "diff-pane" });
        const diff = note.diff;
        if (!diff?.files?.length) {
          wrap.appendChild(h("div", { className: "empty" }, [h("div", { className: "big" }, "📄"), "No diff captured"]));
          return wrap;
        }
        for (const file of diff.files) {
          const { added, removed } = diffStats(file);
          const header = h("div", {
            className: "diff-file-header",
            onClick: (e) => {
              const parent = e.currentTarget.parentElement;
              parent.classList.toggle("collapsed");
            },
          }, [
            h("span", { className: "caret" }, "▾"),
            h("span", {}, file.path),
            h("span", { className: "stats" }, [
              h("span", { className: "added" }, "+" + added),
              h("span", { className: "removed" }, "−" + removed),
            ]),
          ]);

          const body = h("div", { className: "diff-body" });
          let oldNo = 0, newNo = 0;
          for (const line of file.lines || []) {
            let cls = "diff-line";
            let num = "";
            if (line.startsWith("@@")) {
              cls += " hunk";
              const m = line.match(/\+(\d+)/);
              if (m) newNo = parseInt(m[1], 10) - 1;
              const m2 = line.match(/-(\d+)/);
              if (m2) oldNo = parseInt(m2[1], 10) - 1;
              num = "";
            } else if (line.startsWith("+") && !line.startsWith("+++")) {
              cls += " add"; newNo++; num = String(newNo);
            } else if (line.startsWith("-") && !line.startsWith("---")) {
              cls += " del"; oldNo++; num = String(oldNo);
            } else if (line.startsWith("diff ") || line.startsWith("index ") || line.startsWith("---") || line.startsWith("+++") || line.startsWith("new file") || line.startsWith("deleted file") || line.startsWith("rename") || line.startsWith("similarity")) {
              cls += " meta";
              num = "";
            } else {
              oldNo++; newNo++; num = String(newNo);
            }
            body.appendChild(h("div", { className: cls }, [
              h("span", { className: "lineno" }, num),
              h("span", { className: "content" }, line || " "),
            ]));
          }

          const fileEl = h("div", { className: "diff-file" }, [
            header,
            body,
            file.truncated && h("div", { className: "diff-truncated" }, "(diff truncated at 400 lines)"),
          ].filter(Boolean));
          wrap.appendChild(fileEl);
        }
        return wrap;
      }
      function renderCollectionHeader(notes) {
        const summary = summarizeNotes(notes);
        const pr = (state.index?.prs || []).find((item) => item.number === state.current?.prNumber);
        const title = `PR #${pr?.number ?? state.current?.prNumber} · ${pr?.title || "Merged conversation"}`;
        const subtitle = "Read the whole conversation arc across commits before drilling into a single diff.";

        return h("div", { className: "collection-head" }, [
          h("div", { className: "collection-kicker" }, "Pull Request Story"),
          h("h1", { className: "collection-title" }, title),
          h("p", { className: "collection-subtitle" }, subtitle),
          h("div", { className: "stats-row" }, [
            h("span", { className: "stat primary bar" }, [
              h("span", {}, "🤖 " + summary.avgRatio + "%"),
              h("span", { className: "track" }, h("span", { style: "width:" + summary.avgRatio + "%;" })),
            ]),
            h("span", { className: "stat outline" }, summary.commits + " commits"),
            h("span", { className: "stat outline" }, summary.turns + " turns"),
            h("span", { className: "stat outline" }, summary.uniqueFiles + " files"),
            h("span", { className: "stat warm" }, `${summary.aiAdded}/${summary.totalAdded} AI-added lines`),
          ]),
          h("div", { className: "collection-subtitle", style: "margin-top:0.85rem;" }, [
            summary.firstDate && h("span", {}, `${formatDate(summary.firstDate)} → ${formatDate(summary.lastDate)}`),
            summary.authors.length > 0 && h("span", {}, ` · ${summary.authors.join(", ")}`),
            summary.agents.length > 0 && h("span", {}, ` · ${summary.agents.join(", ")}`),
          ].filter(Boolean)),
          h("div", { className: "collection-jump-list" },
            notes.map((note) => h("button", {
              className: "jump-chip",
              onClick: () => jumpToAnchor(commitSectionId(note)),
            }, `${note.commit?.short_sha} · ${compactText(note.commit?.message, 28)}`))
          ),
        ]);
      }
      function renderCollectionCommit(note, idx, total) {
        const commit = note.commit || {};
        const ratio = note.attribution?.ai_ratio ?? 0;
        return h("section", { className: "collection-commit", id: commitSectionId(note) }, [
          h("div", { className: "collection-commit-head" }, [
            h("div", { className: "collection-commit-head-main" }, [
              h("div", { className: "collection-commit-kicker" }, `Commit ${idx + 1} of ${total}`),
              h("h2", { className: "collection-commit-title" }, commit.message || "(no message)"),
              h("div", { className: "collection-commit-meta" }, [
                h("span", { className: "sha" }, commit.short_sha || (commit.sha || "").slice(0, 7)),
                commit.author && h("span", {}, commit.author),
                commit.date && h("span", {}, formatDateTime(commit.date)),
                h("span", { className: "ratio" }, `🤖 ${ratio}%`),
                h("span", {}, `${note.interactions?.length || 0} turns`),
              ].filter(Boolean)),
            ]),
            h("div", { className: "collection-commit-actions" }, [
              h("button", {
                className: "icon-btn primary",
                onClick: () => selectCommit(commit.short_sha || (commit.sha || "").slice(0, 7)),
              }, "Open commit"),
            ]),
          ]),
          h("div", { className: "collection-commit-body" }, [
            renderChat(note, `${commit.short_sha || (commit.sha || "").slice(0, 7)}-`),
            h("details", {}, [
              h("summary", {}, `Show diff (${note.diff?.files?.length || 0} files)`),
              renderDiff(note),
            ]),
          ]),
        ]);
      }
      function renderCollection(notes) {
        return h("div", { className: "collection-pane" }, notes.map((note, idx) => renderCollectionCommit(note, idx, notes.length)));
      }

      function renderViewTabs() {
        const tabs = [
          { id: "chat", label: "💬 Chat" },
          { id: "diff", label: "📝 Diff" },
        ];
        return h("div", { className: "view-tabs" },
          tabs.map((t) => h("button", {
            className: state.tab === t.id ? "active" : "",
            onClick: () => {
              state.tab = t.id;
              setUrlParam("tab", t.id === "chat" ? null : t.id);
              renderMain();
            },
          }, t.label))
        );
      }

      function renderKeyboardHints() {
        return h("div", { className: "hints" }, [
          h("span", {}, "Tip: "),
          h("kbd", {}, "/"), " to focus search · use the sidebar tree or jump chips to move through the story.",
        ]);
      }

      function renderMain() {
        const root = document.getElementById("root");
        const footer = document.getElementById("main-footer");
        root.innerHTML = "";
        footer.innerHTML = "";
        footer.appendChild(renderKeyboardHints());
        updateGitHubLink();
        if (state.loading) {
          root.appendChild(h("div", { className: "empty" }, [
            h("div", { className: "big" }, "⏳"),
            "Loading captured notes…",
          ]));
          return;
        }
        if (!state.current) {
          root.appendChild(h("div", { className: "empty" }, [
            h("div", { className: "big" }, "💬"),
            "Pick a commit from the sidebar.",
          ]));
          return;
        }
        if (state.current.mode === "commit") {
          if (!state.currentNote) {
            root.appendChild(h("div", { className: "empty" }, [
              h("div", { className: "big" }, "📭"),
              "No note data found for this commit.",
            ]));
            return;
          }
          const note = state.currentNote;
          root.appendChild(renderCommitHeader(note));
          root.appendChild(renderViewTabs());
          root.appendChild(state.tab === "diff" ? renderDiff(note) : renderChat(note));
        } else {
          const notes = state.currentGroupNotes;
          if (notes.length === 0) {
            root.appendChild(h("div", { className: "empty" }, [
              h("div", { className: "big" }, "📭"),
              "No note data found for this selection.",
            ]));
            return;
          }
          root.appendChild(renderCollectionHeader(notes));
          root.appendChild(renderCollection(notes));
        }

        // Scroll to anchor if any
        if (window.location.hash) {
          const el = document.querySelector(window.location.hash);
          if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      function renderRail() {
        return;
      }

      // ─── Mobile sidebar drawer ───
      function openMobileSidebar() {
        document.getElementById("sidebar").classList.add("open");
        document.getElementById("overlay").classList.add("show");
      }
      function closeMobileSidebar() {
        document.getElementById("sidebar").classList.remove("open");
        document.getElementById("overlay").classList.remove("show");
      }

      // ─── Wide mode detect ───
      function detectLayout() {
        state.wide = false;
        document.getElementById("app").classList.remove("wide");
      }

      // ─── Init ───
      function bindTopbar() {
        document.getElementById("btn-menu").addEventListener("click", openMobileSidebar);
        document.getElementById("overlay").addEventListener("click", closeMobileSidebar);
        document.getElementById("btn-prev").addEventListener("click", () => {
          const s = neighborCommit(-1);
          if (s) selectCommit(s);
        });
        document.getElementById("btn-next").addEventListener("click", () => {
          const s = neighborCommit(1);
          if (s) selectCommit(s);
        });
      }

      function bindSidebarTabs() {
        for (const btn of document.querySelectorAll("#tab-row button")) {
          btn.addEventListener("click", () => {
            document.querySelectorAll("#tab-row button").forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            state.sideTab = btn.dataset.tab;
            renderSidebar();
          });
        }
      }

      function bindKeyboard() {
        window.addEventListener("keydown", (e) => {
          if (e.target.tagName === "INPUT") {
            if (e.key === "Escape") e.target.blur();
            return;
          }
          if (e.key === "/") {
            e.preventDefault();
            document.getElementById("search-box").focus();
          }
        });
      }

      function bindSearch() {
        const input = document.getElementById("search-box");
        input.addEventListener("input", (e) => {
          state.search = e.target.value || "";
          renderSidebar();
        });
      }

      function restoreFromUrl() {
        const p = new URLSearchParams(window.location.search);
        const tab = p.get("tab");
        if (tab === "diff") state.tab = "diff";
        const commit = p.get("commit");
        if (commit) return selectCommit(commit);
        const pr = p.get("pr");
        if (pr && state.index?.prs) {
          const match = state.index.prs.find((x) => String(x.number) === pr);
          if (match?.commits?.length) return selectPR(match.number);
        }
        if (state.index?.prs?.length) return selectPR(state.index.prs[0].number);
        if (state.index?.commits?.length) return selectCommit(state.index.commits[0].short_sha);
      }

      async function init() {
        detectLayout();
        window.addEventListener("resize", () => {
          detectLayout();
        });

        // Build flat-sorted commit list for keyboard/prev/next (newest first)
        state.flatCommits = [...(state.index.commits || [])].sort((a, b) => (b.date || "").localeCompare(a.date || ""));

        bindTopbar();
        bindSidebarTabs();
        bindKeyboard();
        bindSearch();
        renderSidebar();
        await restoreFromUrl();
      }

      init();
    </script>
  </body>
</html>
