---
import { execFileSync } from "node:child_process";
import { existsSync, readdirSync, readFileSync } from "node:fs";
import { resolve } from "node:path";

interface DashboardCommitSummary {
  sha: string;
  short_sha: string;
  message: string;
  date: string;
  author: string;
  agent: string | null;
  model: string | null;
  session_id: string | null;
  ai_ratio: number;
  lines_ai: number | null;
  lines_total: number | null;
  line_data_available: boolean;
  turns: number;
  note_url: string;
}

interface DashboardPrSummary {
  number: number;
  title: string;
  commits: string[];
}

interface DashboardIndexData {
  version: number;
  generated_at: string;
  repo: string | null;
  prs: DashboardPrSummary[];
  commits: DashboardCommitSummary[];
}

const baseUrl = import.meta.env.BASE_URL;
const JSON_EXTENSION = ".json";
const NOTES_PUBLIC_DIR = "public/notes";
const TEXT_ENCODING = "utf-8";
const homePath = `${baseUrl}`;
const configuredRepo =
  typeof import.meta.env.PUBLIC_REPO === "string" ? import.meta.env.PUBLIC_REPO.trim() : "";
const configuredRepoUrl =
  typeof import.meta.env.PUBLIC_REPO_URL === "string"
    ? import.meta.env.PUBLIC_REPO_URL.trim()
    : "";
const repoUrl = configuredRepoUrl || (configuredRepo ? `https://github.com/${configuredRepo}` : "");
// Resolve from the package root because Astro/Vite rewrites import.meta.url to
// the compiled module location during build, which can make source-relative
// traversal miss public/notes even when the files are present.
const notesDir = resolve(process.cwd(), NOTES_PUBLIC_DIR);
const commitMetadataCache = new Map<string, {
  sha: string;
  short_sha: string;
  message: string;
  date: string;
  author: string;
} | null>();

function stringValue(value: unknown): string {
  return typeof value === "string" ? value : "";
}

function numberValue(value: unknown): number {
  return typeof value === "number" ? value : 0;
}

function hasLineData(lines: Record<string, unknown>): boolean {
  return typeof lines.total_added === "number" && lines.total_added > 0;
}

function readCommitMetadata(sha: string) {
  if (!sha) return null;
  if (commitMetadataCache.has(sha)) {
    return commitMetadataCache.get(sha) ?? null;
  }

  try {
    const raw = execFileSync(
      "git",
      ["show", "-s", "--format=%H%x00%h%x00%s%x00%aI%x00%an", sha],
      {
        encoding: TEXT_ENCODING,
        stdio: ["pipe", "pipe", "pipe"],
        env: process.env,
      },
    ).trim();
    const [fullSha = "", shortSha = "", message = "", date = "", author = ""] = raw.split("\u0000");
    const metadata = {
      sha: fullSha || sha,
      short_sha: shortSha || sha.slice(0, 7),
      message,
      date,
      author,
    };
    commitMetadataCache.set(sha, metadata);
    return metadata;
  } catch {
    commitMetadataCache.set(sha, null);
    return null;
  }
}

function buildDashboardIndex(): DashboardIndexData {
  const noteFiles = existsSync(notesDir)
    ? readdirSync(notesDir).filter((file) => file.endsWith(JSON_EXTENSION)).sort()
    : [];

  const noteRecords = noteFiles
    .map((file) => {
      try {
        const raw = readFileSync(resolve(notesDir, file), TEXT_ENCODING);
        return {
          file,
          note: JSON.parse(raw) as Record<string, unknown>,
        };
      } catch {
        return null;
      }
    })
    .filter(Boolean) as Array<{ file: string; note: Record<string, unknown> }>;

  const commits = noteRecords
    .map(({ file, note }) => {
      const commit = (note.commit ?? {}) as Record<string, unknown>;
      const attribution = (note.attribution ?? {}) as Record<string, unknown>;
      const lines = (attribution.lines ?? {}) as Record<string, unknown>;
      const lineDataAvailable = hasLineData(lines);
      const interactions = Array.isArray(note.interactions) ? note.interactions : [];
      const commitSha = stringValue(commit.sha);
      const fallbackRef =
        commitSha || stringValue(commit.short_sha) || file.replace(/\.json$/, "");
      const fallback = readCommitMetadata(fallbackRef);
      const shortSha =
        stringValue(commit.short_sha) || fallback?.short_sha || file.replace(/\.json$/, "");

      return {
        sha: commitSha || fallback?.sha || shortSha,
        short_sha: shortSha,
        message: stringValue(commit.message) || fallback?.message || shortSha,
        date: stringValue(commit.date) || fallback?.date || "",
        author: stringValue(commit.author) || fallback?.author || "",
        agent: stringValue(note.agent) || null,
        model: stringValue(note.model) || null,
        session_id: stringValue(note.session_id) || null,
        ai_ratio: numberValue(attribution.ai_ratio),
        lines_ai: lineDataAvailable ? numberValue(lines.ai_added) : null,
        lines_total: lineDataAvailable ? numberValue(lines.total_added) : null,
        line_data_available: lineDataAvailable,
        turns: interactions.length,
        note_url: `${baseUrl}/notes/${file}`.replace(/\/+/g, "/"),
      } satisfies DashboardCommitSummary;
    })
    .sort((a, b) => {
      const dateCompare = b.date.localeCompare(a.date);
      if (dateCompare !== 0) return dateCompare;
      return b.short_sha.localeCompare(a.short_sha);
    });

  const prs = new Map<number, { number: number; title: string; commits: Array<{ short_sha: string; date: string }> }>();

  for (const { note } of noteRecords) {
    const pullRequest = (note.pull_request ?? {}) as Record<string, unknown>;
    const commit = (note.commit ?? {}) as Record<string, unknown>;
    const number = typeof pullRequest.number === "number" ? pullRequest.number : null;
    if (number == null) continue;

    const title = stringValue(pullRequest.title) || `PR #${number}`;
    const shortSha = stringValue(commit.short_sha);
    if (!shortSha) continue;

    if (!prs.has(number)) {
      prs.set(number, { number, title, commits: [] });
    }
    prs.get(number)?.commits.push({
      short_sha: shortSha,
      date: stringValue(commit.date),
    });
  }

  return {
    version: 1,
    generated_at: new Date().toISOString(),
    repo: configuredRepo || null,
    prs: [...prs.values()]
      .map((pr) => ({
        number: pr.number,
        title: pr.title,
        commits: pr.commits
          .sort((a, b) => {
            const dateCompare = b.date.localeCompare(a.date);
            if (dateCompare !== 0) return dateCompare;
            return b.short_sha.localeCompare(a.short_sha);
          })
          .map((commit) => commit.short_sha),
      }))
      .sort((a, b) => b.number - a.number),
    commits,
  };
}

const dashboardIndex = buildDashboardIndex();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Note — Chat Viewer</title>
    <link rel="icon" href={`${baseUrl}/favicon.svg`.replace(/\/+/g, "/")} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0b1220;
        --panel-2: #111c2e;
        --panel-3: #18253b;
        --border: #1e2a44;
        --border-strong: #334155;
        --text: #f1f5f9;
        --text-soft: #cbd5e1;
        --muted: #94a3b8;
        --muted-2: #64748b;
        --accent: #22c55e;
        --accent-2: #86efac;
        --accent-dim: rgba(34, 197, 94, 0.14);
        --user-bubble: linear-gradient(180deg, #166534, #14532d);
        --user-bubble-text: #ecfccb;
        --ai-bubble: #111c2e;
        --code-bg: #030712;
        --code-border: #1e293b;
        --chip-bg: #0f172a;
        --diff-add: rgba(34, 197, 94, 0.13);
        --diff-add-text: #86efac;
        --diff-del: rgba(239, 68, 68, 0.13);
        --diff-del-text: #fca5a5;
        --diff-hunk: rgba(59, 130, 246, 0.1);
        --diff-hunk-text: #93c5fd;
        --shadow: 0 6px 24px rgba(2, 6, 23, 0.6);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          'IBM Plex Sans', -apple-system, BlinkMacSystemFont,
          'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      code, pre, kbd {
        font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
      }
      button {
        font-family: inherit;
      }

      /* ─── App skeleton ─── */
      .app {
        display: grid;
        grid-template-columns: 292px minmax(0, 1fr);
        min-height: 100vh;
      }
      @media (max-width: 1180px) {
        .app {
          grid-template-columns: 268px minmax(0, 1fr);
        }
      }
      @media (max-width: 960px) {
        .app, .app.wide { grid-template-columns: 1fr; }
        .sidebar {
          position: fixed; inset: 0 auto 0 0; z-index: 40;
          width: min(86vw, 320px);
          transform: translateX(-100%);
          transition: transform 200ms ease;
        }
        .sidebar.open { transform: translateX(0); box-shadow: 4px 0 40px rgba(0,0,0,0.5); }
        .overlay {
          position: fixed; inset: 0; z-index: 35;
          background: rgba(0,0,0,0.5);
          display: none;
        }
        .overlay.show { display: block; }
      }

      /* ─── Sidebar ─── */
      .sidebar {
        background: var(--panel);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        max-height: 100vh;
        position: sticky;
        top: 0;
      }
      .sidebar-header {
        padding: 0.9rem 1rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .sidebar-header .logo {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.01em;
      }
      .sidebar-header .logo::before {
        content: "";
        width: 22px; height: 22px;
        background: var(--accent);
        mask-image: radial-gradient(circle, black 25%, transparent 26%);
        border-radius: 6px;
      }
      .badge {
        padding: 0.15rem 0.55rem;
        font-size: 0.62rem;
        border-radius: 999px;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .badge.accent { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }

      .tab-row {
        display: flex;
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid var(--border);
        gap: 0.25rem;
        background: var(--panel);
      }
      .tab-row button {
        flex: 1;
        padding: 0.45rem;
        background: transparent;
        border: 1px solid transparent;
        color: var(--muted);
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.78rem;
      }
      .tab-row button:hover { color: var(--text-soft); background: var(--panel-2); }
      .tab-row button.active { color: var(--accent); background: var(--accent-dim); border-color: var(--accent); }

      .search {
        padding: 0.55rem 0.8rem 0.8rem;
        position: relative;
      }
      .search input {
        width: 100%;
        padding: 0.55rem 0.8rem 0.55rem 2rem;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        color: var(--text);
        font-family: inherit;
        font-size: 0.85rem;
        outline: none;
      }
      .search input:focus { border-color: var(--accent); }
      .search::before {
        content: "🔍";
        position: absolute;
        left: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        opacity: 0.5;
      }
      .search kbd {
        position: absolute;
        right: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        padding: 0.1rem 0.4rem;
        font-size: 0.65rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        border-radius: 4px;
        color: var(--muted);
      }

      .sidebar-list {
        overflow-y: auto;
        flex: 1;
        padding: 0.25rem 0 2rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border-strong) transparent;
      }
      .sidebar-list::-webkit-scrollbar { width: 6px; }
      .sidebar-list::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

      .group-label {
        padding: 0.75rem 1rem 0.3rem;
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }

      .pr-card, .commit-card, .session-card {
        margin: 0.15rem 0.55rem;
        padding: 0.65rem 0.85rem;
        border-radius: 10px;
        cursor: pointer;
        transition: background 120ms, border-color 120ms, transform 120ms;
        border: 1px solid transparent;
        position: relative;
        overflow: hidden;
      }
      .pr-card::before,
      .commit-card::before,
      .session-card::before,
      .tree-commit::before,
      .turn-node::before {
        content: "";
        position: absolute;
        left: 0;
        top: 10px;
        bottom: 10px;
        width: 3px;
        border-radius: 0 999px 999px 0;
        opacity: 0;
        transform: scaleY(0.72);
        transition: opacity 120ms, transform 120ms;
      }
      .pr-card::before,
      .commit-card::before,
      .session-card::before,
      .tree-commit::before {
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
      }
      .turn-node::before {
        background: linear-gradient(180deg, #60a5fa, #bfdbfe);
      }
      .pr-card:hover, .commit-card:hover, .session-card:hover {
        background: var(--panel-2);
      }
      .pr-card.active, .commit-card.active, .session-card.active {
        background: var(--accent-dim);
        border-color: rgba(34, 197, 94, 0.55);
        box-shadow: inset 0 0 0 1px rgba(134, 239, 172, 0.08);
        transform: translateY(1px);
      }
      .pr-card.active::before,
      .commit-card.active::before,
      .session-card.active::before,
      .tree-commit.active::before,
      .turn-node.active::before {
        opacity: 1;
        transform: scaleY(1);
      }
      .card-title {
        font-size: 0.83rem;
        color: var(--text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-meta {
        margin-top: 0.3rem;
        font-size: 0.68rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .card-meta .sha { color: var(--accent); }
      .card-meta .ratio { color: var(--accent-2); }
      .ratio-bar {
        margin-top: 0.4rem;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .ratio-bar span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .pr-card .pr-commits {
        margin-top: 0.4rem;
        font-size: 0.68rem;
        color: var(--muted);
        display: flex;
        gap: 0.4rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .sidebar-tree {
        margin: 0.12rem 0.55rem 0.55rem 1.1rem;
        padding-left: 0.75rem;
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.22rem;
      }
      .tree-section-label {
        margin: 0.28rem 0 0.24rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.54rem;
        letter-spacing: 0.14em;
        line-height: 1.35;
        text-transform: uppercase;
      }
      .tree-commit,
      .turn-node {
        width: 100%;
        border: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        text-align: left;
        border-radius: 9px;
        cursor: pointer;
        transition: background 120ms, border-color 120ms, color 120ms, transform 120ms;
        position: relative;
        overflow: hidden;
      }
      .tree-commit {
        padding: 0.5rem 0.65rem;
      }
      .tree-commit:hover,
      .turn-node:hover {
        background: var(--panel-2);
        color: var(--text);
      }
      .tree-commit.active {
        background: rgba(34, 197, 94, 0.1);
        border-color: rgba(34, 197, 94, 0.4);
        color: var(--text);
        box-shadow: inset 0 0 0 1px rgba(134, 239, 172, 0.08);
        transform: translateY(1px);
      }
      .tree-commit.scroll-target {
        border-style: dashed;
      }
      .tree-commit-title {
        font-size: 0.78rem;
        line-height: 1.35;
        color: inherit;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .tree-commit-meta {
        margin-top: 0.25rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0.55rem;
        font-size: 0.66rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .tree-commit-meta .sha {
        color: var(--accent);
      }
      .turn-tree {
        margin: 0.18rem 0 0.35rem 0.7rem;
        padding-left: 0.75rem;
        border-left: 1px dashed rgba(100, 116, 139, 0.5);
        display: flex;
        flex-direction: column;
        gap: 0.18rem;
      }
      .turn-node {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: start;
        gap: 0.4rem;
        padding: 0.38rem 0.55rem;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .turn-node.active {
        background: rgba(59, 130, 246, 0.12);
        border-color: rgba(96, 165, 250, 0.45);
        color: var(--text);
        box-shadow: inset 0 0 0 1px rgba(147, 197, 253, 0.08);
        transform: translateY(1px);
      }
      .turn-node-id {
        color: var(--accent);
      }
      .turn-node-text {
        min-width: 0;
        line-height: 1.35;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        word-break: break-word;
      }
      .turn-node-pill {
        padding: 0.08rem 0.38rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-soft);
        font-size: 0.64rem;
      }

      /* ─── Main area ─── */
      .main {
        overflow-y: auto;
        max-height: 100vh;
      }
      .main-inner {
        max-width: 860px;
        margin: 0 auto;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        padding: 1.25rem clamp(1rem, 2.2vw, 1.5rem) 5rem;
      }
      .main-footer {
        margin-top: auto;
        padding-top: 1.25rem;
      }

      .topbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        position: sticky;
        top: 0;
        z-index: 24;
        padding: 0.15rem 0 0.9rem;
        background: linear-gradient(180deg, rgba(2, 6, 23, 0.98), rgba(2, 6, 23, 0.84) 72%, transparent);
        backdrop-filter: blur(14px);
      }
      .icon-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.45rem 0.75rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--muted);
        cursor: pointer;
        font-size: 0.78rem;
        transition: color 120ms, border-color 120ms, background 120ms;
      }
      .icon-btn:hover {
        color: var(--text);
        border-color: var(--border-strong);
        background: var(--panel-2);
      }
      .icon-btn.primary {
        background: var(--accent-dim);
        border-color: var(--accent);
        color: var(--accent);
      }
      .hamburger { display: none; }
      @media (max-width: 960px) { .hamburger { display: inline-flex; } }
      .spacer { flex: 1; }

      .commit-head {
        padding: 1.25rem 1.5rem;
        background:
          radial-gradient(circle at top right, rgba(34, 197, 94, 0.12), transparent 34%),
          linear-gradient(180deg, rgba(11, 18, 32, 0.96), rgba(11, 18, 32, 0.92));
        border: 1px solid rgba(51, 65, 85, 0.88);
        border-radius: 16px;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
      }
      .commit-title {
        margin: 0 0 0.5rem;
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.35;
      }
      .commit-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.9rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .commit-meta-row .sha {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent);
        cursor: pointer;
        position: relative;
      }
      .commit-meta-row .sha:hover { color: var(--accent-2); }
      .commit-meta-row .sha.copied::after {
        content: "copied!";
        position: absolute;
        left: 100%;
        margin-left: 0.5rem;
        font-size: 0.7rem;
        color: var(--accent-2);
        font-family: inherit;
      }
      .stats-row {
        margin-top: 0.9rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .stat {
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .stat.primary { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }
      .stat.outline { background: transparent; border: 1px solid var(--border-strong); color: var(--muted); }
      .stat.bar {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .stat.bar .track {
        width: 60px;
        height: 5px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
      }
      .stat.bar .track span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .stat.warm {
        background: rgba(59, 130, 246, 0.12);
        border: 1px solid rgba(96, 165, 250, 0.5);
        color: #bfdbfe;
      }
      .commit-context-grid {
        margin-top: 1rem;
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(220px, 0.95fr);
        gap: 0.8rem;
      }
      .commit-context-card {
        padding: 0.9rem 1rem;
        background: rgba(2, 6, 23, 0.42);
        border: 1px solid rgba(51, 65, 85, 0.7);
        border-radius: 12px;
      }
      .commit-context-title {
        margin: 0 0 0.6rem;
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .meta-pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .meta-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.28rem 0.55rem;
        border-radius: 999px;
        background: var(--chip-bg);
        border: 1px solid var(--border-strong);
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.71rem;
        min-width: 0;
      }
      .meta-pill-label {
        color: var(--muted-2);
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .meta-pill-value {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .meta-pill.agent-pill {
        padding-left: 0.34rem;
      }
      .commit-file-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .commit-file-row {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.36rem 0.68rem;
        border-radius: 999px;
        background: rgba(15, 23, 42, 0.82);
        border: 1px solid rgba(51, 65, 85, 0.82);
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        min-width: 0;
        max-width: 100%;
      }
      .commit-file-row .by_ai { color: var(--accent); }
      .commit-file-row .by_human { color: var(--muted-2); }
      .commit-file-name {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .commit-head,
      .collection-commit,
      .turn {
        scroll-margin-top: 5rem;
      }
      .commit-file-empty {
        color: var(--muted);
        font-size: 0.74rem;
        font-family: 'JetBrains Mono', monospace;
      }

      /* ─── Tabs / split ─── */
      .view-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
      }
      .view-tabs button {
        padding: 0.6rem 1.1rem;
        background: transparent;
        color: var(--muted);
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        font-size: 0.85rem;
        transition: color 120ms;
      }
      .view-tabs button:hover { color: var(--text); }
      .view-tabs button.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }

      /* Chat */
      .chat-pane {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .turn-divider {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.65rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        margin: 0.5rem 0;
      }
      .turn-divider::before, .turn-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .bubble-row {
        display: flex;
        gap: 0.6rem;
      }
      .bubble-row.from-user {
        justify-content: flex-end;
      }
      .bubble-row.from-ai {
        justify-content: flex-start;
      }
      .avatar {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        background: var(--panel-2);
        border: 1px solid var(--border);
      }
      .avatar.ai {
        background: linear-gradient(135deg, #14532d 0%, #166534 100%);
        border-color: var(--accent);
        color: var(--accent-2);
      }
      .avatar.ai-icon {
        width: 30px;
        height: 30px;
        padding: 0;
        border-radius: 10px;
        overflow: hidden;
        background: transparent;
        border-color: rgba(148, 163, 184, 0.35);
        box-shadow: 0 8px 20px rgba(2, 6, 23, 0.35);
      }
      .avatar.ai-icon img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .avatar-inline {
        width: 18px;
        height: 18px;
        border-radius: 6px;
        font-size: 0.72rem;
        box-shadow: none;
      }
      .bubble {
        max-width: min(82%, 540px);
        padding: 0.75rem 1rem;
        border-radius: 14px;
        line-height: 1.6;
        font-size: 0.92rem;
        word-wrap: break-word;
        position: relative;
      }
      .bubble .md { white-space: normal; }
      .bubble.user {
        background: var(--user-bubble);
        color: var(--user-bubble-text);
        border-bottom-right-radius: 4px;
      }
      .bubble.ai {
        background: var(--ai-bubble);
        color: var(--text-soft);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border);
      }
      .bubble.ai.empty {
        color: var(--muted-2);
        font-style: italic;
        display: inline-flex;
        align-items: center;
        min-height: 0;
        padding-top: 0.9rem;
        padding-bottom: 0.9rem;
      }
      .context-row {
        display: flex;
        justify-content: center;
      }
      .context-card {
        width: min(78%, 620px);
        padding: 0.7rem 0.95rem;
        border: 1px solid rgba(148, 163, 184, 0.25);
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.82), rgba(21, 128, 61, 0.08));
        color: var(--muted);
      }
      .context-label {
        margin-bottom: 0.35rem;
        color: var(--accent-2);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .context-card .md {
        color: var(--muted);
        font-size: 0.82rem;
        line-height: 1.6;
      }
      /* ─── Markdown content inside bubbles ─── */
      .md {
        white-space: normal;
      }
      .md > *:first-child { margin-top: 0; }
      .md > *:last-child { margin-bottom: 0; }
      .md p { margin: 0.5rem 0; line-height: 1.65; }
      .md h1, .md h2, .md h3, .md h4 {
        margin: 1rem 0 0.45rem;
        line-height: 1.3;
        font-weight: 600;
        color: var(--text);
      }
      .md h1 { font-size: 1.15rem; }
      .md h2 { font-size: 1.05rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      .md h3 { font-size: 0.95rem; }
      .md h4 { font-size: 0.88rem; color: var(--text-soft); }
      .md ul, .md ol { margin: 0.5rem 0; padding-left: 1.4rem; }
      .md li { margin: 0.15rem 0; }
      .md li > p { margin: 0.2rem 0; }
      .md blockquote {
        margin: 0.6rem 0;
        padding: 0.25rem 0.8rem;
        border-left: 3px solid var(--accent);
        background: rgba(34, 197, 94, 0.05);
        color: var(--muted);
      }
      .md a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dashed var(--accent);
      }
      .md a:hover { color: var(--accent-2); border-bottom-style: solid; }
      .md strong { color: var(--text); font-weight: 600; }
      .md em { font-style: italic; color: var(--text-soft); }
      .md hr { border: 0; border-top: 1px solid var(--border); margin: 1rem 0; }
      .md table {
        border-collapse: collapse;
        margin: 0.75rem 0;
        font-size: 0.85rem;
        width: 100%;
      }
      .md th, .md td {
        border: 1px solid var(--border);
        padding: 0.35rem 0.7rem;
        text-align: left;
      }
      .md th {
        background: var(--panel-2);
        color: var(--text);
        font-weight: 600;
        font-size: 0.8rem;
      }
      .md pre {
        margin: 0.65rem 0;
        padding: 0.75rem 1rem;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 8px;
        font-size: 0.82rem;
        line-height: 1.55;
        overflow-x: auto;
        white-space: pre;
      }
      .md pre code {
        color: var(--text-soft);
        background: transparent;
        padding: 0;
        font-size: inherit;
      }
      .md code:not(pre code) {
        padding: 0.1em 0.35em;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 4px;
        font-size: 0.86em;
        color: var(--accent-2);
      }
      .md img {
        max-width: 100%;
        border-radius: 8px;
        margin: 0.5rem 0;
      }
      .md input[type="checkbox"] { margin-right: 0.4rem; }

      .bubble-footer {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.55rem;
        background: var(--chip-bg);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .chip.tool { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
      .chip.file::before {
        content: "📄";
        font-size: 0.7rem;
        opacity: 0.6;
      }
      .turn-label {
        color: var(--muted-2);
        font-size: 0.65rem;
        font-family: 'JetBrains Mono', monospace;
        margin: 0 0.5rem;
        align-self: flex-end;
      }

      .bubble-actions {
        position: absolute;
        top: -0.5rem;
        right: 0.5rem;
        display: none;
        gap: 0.2rem;
      }
      .bubble:hover .bubble-actions { display: flex; }
      .bubble-actions button {
        padding: 0.15rem 0.45rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        color: var(--muted);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.65rem;
      }
      .bubble-actions button:hover { color: var(--text); border-color: var(--accent); }

      .collapsed-hint {
        color: var(--muted-2);
        font-size: 0.75rem;
        cursor: pointer;
        margin-top: 0.3rem;
        font-style: italic;
      }
      .collapsed-hint:hover { color: var(--accent); }

      /* Diff */
      .diff-pane {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .diff-file {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: var(--panel);
      }
      .diff-file-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: var(--panel-2);
        border-bottom: 1px solid var(--border);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: var(--text);
        cursor: pointer;
      }
      .diff-file-header:hover { background: var(--panel-3); }
      .diff-file-header .caret {
        color: var(--muted);
        transition: transform 150ms;
        display: inline-block;
      }
      .diff-file.collapsed .caret { transform: rotate(-90deg); }
      .diff-file.collapsed .diff-body, .diff-file.collapsed .diff-truncated { display: none; }
      .diff-file-header .stats {
        margin-left: auto;
        font-size: 0.7rem;
        color: var(--muted);
        display: flex;
        gap: 0.5rem;
      }
      .diff-file-header .stats .added { color: var(--diff-add-text); }
      .diff-file-header .stats .removed { color: var(--diff-del-text); }
      .diff-body {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.76rem;
        line-height: 1.55;
        overflow-x: auto;
      }
      .diff-line {
        display: grid;
        grid-template-columns: 48px 1fr;
        white-space: pre;
      }
      .diff-line .lineno {
        background: var(--panel);
        color: var(--muted-2);
        padding: 0 0.5rem;
        text-align: right;
        font-size: 0.7rem;
        border-right: 1px solid var(--border);
        user-select: none;
      }
      .diff-line .content { padding: 0 1rem; }
      .diff-line.add .content { background: var(--diff-add); color: var(--diff-add-text); }
      .diff-line.del .content { background: var(--diff-del); color: var(--diff-del-text); }
      .diff-line.hunk .content { background: var(--diff-hunk); color: var(--diff-hunk-text); font-weight: 600; }
      .diff-line.meta { display: none; } /* suppress diff/index/+++/--- headers for cleanliness */
      .diff-truncated {
        padding: 0.5rem 1rem;
        color: var(--muted);
        font-style: italic;
        background: var(--panel-2);
        border-top: 1px solid var(--border);
        font-size: 0.74rem;
      }

      /* Aggregate views */
      .collection-head {
        padding: 1.35rem 1.5rem;
        background:
          radial-gradient(circle at top right, rgba(34, 197, 94, 0.14), transparent 32%),
          linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(11, 18, 32, 0.96));
        border: 1px solid var(--border);
        border-radius: 18px;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
      }
      .collection-kicker {
        margin-bottom: 0.45rem;
        color: var(--accent-2);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        font-family: 'JetBrains Mono', monospace;
      }
      .collection-title {
        margin: 0;
        font-size: 1.3rem;
        line-height: 1.25;
        letter-spacing: -0.02em;
      }
      .collection-subtitle {
        margin: 0.55rem 0 0;
        color: var(--text-soft);
        font-size: 0.95rem;
        line-height: 1.7;
      }
      .collection-jump-list {
        margin-top: 1rem;
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
      }
      .jump-chip {
        padding: 0.35rem 0.7rem;
        background: rgba(15, 23, 42, 0.9);
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        color: var(--text-soft);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.72rem;
        cursor: pointer;
      }
      .jump-chip:hover {
        border-color: var(--accent);
        color: var(--accent);
      }
      .collection-pane {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .collection-commit {
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(11, 18, 32, 0.95), rgba(15, 23, 42, 0.98));
        box-shadow: var(--shadow);
      }
      .collection-commit-head {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        justify-content: space-between;
        padding: 1rem 1.15rem;
        border-bottom: 1px solid var(--border);
        background: rgba(17, 28, 46, 0.7);
      }
      .collection-commit-head-main {
        min-width: 0;
      }
      .collection-commit-kicker {
        margin-bottom: 0.35rem;
        color: var(--muted-2);
        font-size: 0.7rem;
        font-family: 'JetBrains Mono', monospace;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .collection-commit-title {
        margin: 0;
        font-size: 1rem;
        line-height: 1.4;
      }
      .collection-commit-meta {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.8rem;
        color: var(--muted);
        font-size: 0.74rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .collection-commit-actions {
        display: flex;
        gap: 0.45rem;
        flex-shrink: 0;
      }
      .collection-commit-body {
        padding: 1rem 1.15rem 1.15rem;
      }
      .collection-commit .chat-pane {
        gap: 1rem;
      }
      .collection-commit .bubble {
        max-width: min(88%, 640px);
      }
      .collection-commit details {
        margin-top: 1rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: rgba(2, 6, 23, 0.45);
      }
      .collection-commit summary {
        list-style: none;
        cursor: pointer;
        padding: 0.8rem 1rem;
        color: var(--text-soft);
        font-size: 0.82rem;
        font-family: 'JetBrains Mono', monospace;
        background: rgba(15, 23, 42, 0.95);
        border-bottom: 1px solid transparent;
      }
      .collection-commit details[open] summary {
        border-bottom-color: var(--border);
      }
      .collection-commit summary::-webkit-details-marker {
        display: none;
      }

      .right-rail {
        padding: 1.5rem 1.25rem;
        background: var(--panel);
        border-left: 1px solid var(--border);
        overflow-y: auto;
        max-height: 100vh;
      }
      .right-rail h3 {
        margin: 0 0 0.5rem;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .right-rail .section { margin-bottom: 1.5rem; }
      .right-rail .file-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 0.83rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        cursor: default;
      }
      .right-rail .file-row:hover { background: var(--panel-2); color: var(--text); }
      .right-rail button.file-row {
        width: 100%;
        border: none;
        background: transparent;
        text-align: left;
        font: inherit;
      }
      .right-rail .file-row .by_ai { color: var(--accent); }
      .right-rail .file-row .by_human { color: var(--muted-2); }
      .right-rail .kv {
        font-size: 0.78rem;
        color: var(--muted);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.3rem 0.8rem;
      }
      .right-rail .kv dt { color: var(--muted-2); font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
      .right-rail .kv dd { margin: 0; color: var(--text-soft); font-family: 'JetBrains Mono', monospace; font-size: 0.76rem; }
      .right-rail .file-row.active {
        background: var(--accent-dim);
        color: var(--accent);
        border: 1px solid var(--accent);
      }
      .right-rail .pill {
        margin-left: auto;
        padding: 0.08rem 0.4rem;
        border-radius: 999px;
        background: rgba(148, 163, 184, 0.14);
        color: var(--text-soft);
        font-size: 0.66rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .right-rail .nav-row {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        align-items: start;
      }
      .right-rail .row-id {
        flex-shrink: 0;
        font-size: 0.68rem;
      }
      .right-rail .row-main {
        min-width: 0;
        line-height: 1.35;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        word-break: break-word;
      }
      .right-rail .nav-row .pill {
        margin-left: 0;
        align-self: start;
        font-size: 0.68rem;
      }

      /* Empty state */
      .empty {
        padding: 4rem 1rem;
        text-align: center;
        color: var(--muted);
      }
      .empty .big { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        padding: 0.6rem 1rem;
        background: var(--panel-3);
        border: 1px solid var(--accent);
        border-radius: 10px;
        color: var(--accent-2);
        font-size: 0.85rem;
        transition: transform 200ms ease;
        z-index: 60;
        font-family: 'JetBrains Mono', monospace;
      }
      .toast.show { transform: translateX(-50%) translateY(0); }

      /* Keyboard hints */
      .hints {
        margin-top: 2rem;
        padding: 1rem 1.25rem;
        background: var(--panel);
        border-radius: 10px;
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.8;
      }
      .hints kbd {
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        padding: 0.1rem 0.45rem;
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--text-soft);
      }
      @media (max-width: 960px) {
        .main {
          max-height: none;
        }
        .main-inner {
          padding: 1rem 0.9rem 4rem;
        }
        .topbar {
          padding-bottom: 0.7rem;
        }
        .commit-head,
        .collection-commit,
        .turn {
          scroll-margin-top: 5rem;
        }
      }
      @media (max-width: 720px) {
        .topbar {
          gap: 0.4rem;
        }
        .spacer {
          display: none;
        }
        .icon-btn {
          padding: 0.4rem 0.65rem;
          font-size: 0.74rem;
        }
        .commit-head,
        .collection-head {
          padding: 1rem;
        }
        .collection-commit-head,
        .collection-commit-body {
          padding: 0.9rem 1rem;
        }
        .commit-context-grid {
          grid-template-columns: 1fr;
        }
        .view-tabs {
          gap: 0;
        }
        .view-tabs button {
          flex: 1;
          padding: 0.6rem 0.75rem;
          text-align: center;
        }
        .bubble {
          max-width: calc(100vw - 5rem);
        }
        .context-card {
          width: 100%;
        }
        .turn-label {
          display: none;
        }
        .turn .bubble-footer {
          margin-left: 0 !important;
        }
      }
      @media (max-width: 560px) {
        .commit-meta-row {
          gap: 0.25rem 0.6rem;
          font-size: 0.74rem;
        }
        .stats-row {
          gap: 0.35rem;
        }
        .stat {
          padding: 0.28rem 0.6rem;
          font-size: 0.7rem;
        }
        .collection-jump-list {
          flex-wrap: nowrap;
          overflow-x: auto;
          padding-bottom: 0.25rem;
          scrollbar-width: thin;
        }
        .jump-chip {
          white-space: nowrap;
        }
      }
    </style>
  </head>
  <body>
    <div class="overlay" id="overlay"></div>
    <div class="app" id="app">
      <!-- ─── Sidebar ─── -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <a href={homePath} class="logo">Agent Note</a>
          <span class="badge accent">Preview</span>
        </div>
        <div class="tab-row" id="tab-row">
          <button data-tab="prs" class="active">PRs</button>
          <button data-tab="commits">Commits</button>
        </div>
        <div class="search">
          <input id="search-box" type="search" placeholder="Search…" autocomplete="off" />
          <kbd>/</kbd>
        </div>
        <div class="sidebar-list" id="sidebar-list">
          <div class="empty"><div class="big">⏳</div>Loading…</div>
        </div>
      </aside>

      <!-- ─── Main ─── -->
      <main class="main" id="main">
        <div class="main-inner" id="main-inner">
          <div class="topbar">
            <button class="icon-btn hamburger" id="btn-menu" aria-label="Menu">☰</button>
            <button class="icon-btn" id="btn-prev" aria-label="Previous commit">← prev</button>
            <button class="icon-btn" id="btn-next" aria-label="Next commit">next →</button>
            <div class="spacer"></div>
            {repoUrl && (
              <a class="icon-btn" id="btn-github" href={repoUrl} target="_blank" rel="noopener">
                GitHub ↗
              </a>
            )}
          </div>

          <div id="root">
            <div class="empty">
              <div class="big">💬</div>
              Pick a commit from the sidebar.
            </div>
          </div>
          <div class="main-footer" id="main-footer"></div>
        </div>
      </main>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline define:vars={{ baseUrl, repoUrl, dashboardIndex }}>
      const state = {
        index: dashboardIndex,
        current: null,
        currentNote: null,
        currentGroupNotes: [],
        loading: false,
        loadToken: 0,
        noteCache: new Map(),
        tab: "chat",            // main tabs: chat | diff
        sideTab: "prs",         // sidebar tabs: prs | commits
        search: "",
        flatCommits: [],
        wide: false,
        expandedSidebarCommit: null,
        missingSelection: null,
      };

      // ─── Utilities ───
      function h(tag, attrs = {}, children = []) {
        const el = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (v == null || v === false) continue;
          if (k === "className") el.className = v;
          else if (k === "html") el.innerHTML = v;
          else if (k.startsWith("on") && typeof v === "function") el.addEventListener(k.slice(2).toLowerCase(), v);
          else if (k === "dataset") for (const [dk, dv] of Object.entries(v)) el.dataset[dk] = dv;
          else el.setAttribute(k, v);
        }
        for (const c of [].concat(children)) {
          if (c == null || c === false) continue;
          el.appendChild(typeof c === "string" ? document.createTextNode(c) : c);
        }
        return el;
      }
      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
        })[c]);
      }
      const AGENT_ICON_LABELS = {
        claude: "Claude",
        cursor: "Cursor",
        gemini: "Gemini",
        codex: "OpenAI Codex",
      };
      const AGENT_ICON_PATHS = {
        claude: `${baseUrl}/model-icons/claude.png`.replace(/\/+/g, "/"),
        cursor: `${baseUrl}/model-icons/cursor.png`.replace(/\/+/g, "/"),
        gemini: `${baseUrl}/model-icons/gemini.png`.replace(/\/+/g, "/"),
        codex: `${baseUrl}/model-icons/codex.png`.replace(/\/+/g, "/"),
      };
      function normalizeAgentKey(...parts) {
        const text = parts
          .filter(Boolean)
          .join(" ")
          .trim()
          .toLowerCase();
        if (!text) return null;
        if (text.includes("claude") || text.includes("anthropic")) return "claude";
        if (text.includes("cursor")) return "cursor";
        if (text.includes("gemini")) return "gemini";
        if (
          text.includes("codex") ||
          text.includes("openai") ||
          text.includes("chatgpt") ||
          /\bgpt\b/.test(text)
        ) return "codex";
        return null;
      }
      function renderAgentAvatar(agent, model, compact = false) {
        const key = normalizeAgentKey(agent, model);
        const label = AGENT_ICON_LABELS[key] || agent || model || "Unknown AI agent";
        const compactClass = compact ? " avatar-inline" : "";
        if (!key) return h("div", { className: "avatar ai" + compactClass, title: label, "aria-label": label }, "🤖");
        return h("div", {
          className: "avatar ai-icon" + compactClass,
          title: label,
          "aria-label": label,
        }, h("img", { src: AGENT_ICON_PATHS[key], alt: label, loading: "lazy", decoding: "async" }));
      }
      function formatDate(iso) {
        if (!iso) return "";
        try {
          return new Date(iso).toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
        } catch { return iso; }
      }
      function formatDateTime(iso) {
        if (!iso) return "";
        try { return new Date(iso).toLocaleString(); } catch { return iso; }
      }
      function setUrlParam(key, value) {
        const url = new URL(window.location.href);
        if (value == null || value === "") url.searchParams.delete(key);
        else url.searchParams.set(key, String(value));
        history.replaceState(null, "", url);
      }
      function toast(msg) {
        const el = document.getElementById("toast");
        el.textContent = msg;
        el.classList.add("show");
        clearTimeout(toast._t);
        toast._t = setTimeout(() => el.classList.remove("show"), 1800);
      }
      function copyToClipboard(text) {
        if (navigator.clipboard) navigator.clipboard.writeText(text).then(() => toast("Copied"));
      }

      // Small dependency-free Markdown renderer for prompt/response bubbles.
      // It never interprets raw HTML; text becomes text nodes, and links are
      // allowlisted before becoming anchors. This keeps the dashboard readable
      // without relying on runtime CDN imports or CSP-sensitive libraries.
      function safeMarkdownHref(rawHref) {
        const href = String(rawHref || "").trim();
        if (!href) return null;
        if (href.startsWith("#")) return href;
        try {
          const url = new URL(href, window.location.href);
          if (["http:", "https:", "mailto:"].includes(url.protocol)) return url.href;
        } catch {
          return null;
        }
        return null;
      }
      function appendTextWithBreaks(parent, text) {
        const parts = String(text || "").split("\n");
        parts.forEach((part, index) => {
          if (index > 0) parent.appendChild(h("br"));
          if (part) parent.appendChild(document.createTextNode(part));
        });
      }
      function appendInlineMarkdown(parent, text) {
        const pattern = /(`[^`]+`|\*\*[^*]+?\*\*|\*[^*\n]+?\*|\[[^\]\n]+?\]\([^) \n]+?\))/g;
        let cursor = 0;
        for (const match of String(text || "").matchAll(pattern)) {
          if (match.index > cursor) {
            appendTextWithBreaks(parent, text.slice(cursor, match.index));
          }
          const token = match[0];
          if (token.startsWith("`")) {
            parent.appendChild(h("code", {}, token.slice(1, -1)));
          } else if (token.startsWith("**")) {
            const strong = h("strong");
            appendInlineMarkdown(strong, token.slice(2, -2));
            parent.appendChild(strong);
          } else if (token.startsWith("*")) {
            const em = h("em");
            appendInlineMarkdown(em, token.slice(1, -1));
            parent.appendChild(em);
          } else {
            const linkMatch = token.match(/^\[([^\]\n]+?)\]\(([^) \n]+?)\)$/);
            const href = safeMarkdownHref(linkMatch?.[2]);
            if (linkMatch && href) {
              const a = h("a", { href, target: "_blank", rel: "noopener noreferrer" });
              appendInlineMarkdown(a, linkMatch[1]);
              parent.appendChild(a);
            } else {
              appendTextWithBreaks(parent, token);
            }
          }
          cursor = match.index + token.length;
        }
        if (cursor < String(text || "").length) {
          appendTextWithBreaks(parent, String(text || "").slice(cursor));
        }
      }
      function appendParagraph(container, lines) {
        const text = lines.join("\n").trim();
        if (!text) return;
        const p = h("p");
        appendInlineMarkdown(p, text);
        container.appendChild(p);
      }
      function appendTaskMarkerIfPresent(li, text) {
        const task = text.match(/^\[([ xX])\]\s+(.*)$/);
        if (!task) return text;
        li.appendChild(h("input", {
          type: "checkbox",
          disabled: true,
          ...(task[1].toLowerCase() === "x" ? { checked: true } : {}),
        }));
        return task[2];
      }
      function appendList(container, lines, ordered) {
        const list = h(ordered ? "ol" : "ul");
        const marker = ordered ? /^\s*\d+[.)]\s+/ : /^\s*[-*]\s+/;
        lines.forEach((line) => {
          const li = h("li");
          appendInlineMarkdown(li, appendTaskMarkerIfPresent(li, line.replace(marker, "")));
          list.appendChild(li);
        });
        container.appendChild(list);
      }
      function splitMarkdownTableRow(line) {
        return String(line || "")
          .trim()
          .replace(/^\|/, "")
          .replace(/\|$/, "")
          .split("|")
          .map((cell) => cell.trim());
      }
      function isMarkdownTableSeparator(line, expectedCells) {
        const cells = splitMarkdownTableRow(line);
        return cells.length === expectedCells && cells.length > 1 && cells.every((cell) => /^:?-{3,}:?$/.test(cell));
      }
      function appendTable(container, headerLine, bodyLines) {
        const headers = splitMarkdownTableRow(headerLine);
        const table = h("table");
        const thead = h("thead");
        const headerRow = h("tr");
        headers.forEach((header) => {
          const th = h("th");
          appendInlineMarkdown(th, header);
          headerRow.appendChild(th);
        });
        thead.appendChild(headerRow);
        table.appendChild(thead);

        const tbody = h("tbody");
        bodyLines.forEach((line) => {
          const row = h("tr");
          const cells = splitMarkdownTableRow(line);
          headers.forEach((_, cellIndex) => {
            const td = h("td");
            appendInlineMarkdown(td, cells[cellIndex] || "");
            row.appendChild(td);
          });
          tbody.appendChild(row);
        });
        table.appendChild(tbody);
        container.appendChild(table);
      }
      function renderMarkdownInto(container, text) {
        container.classList.add("md");
        container.replaceChildren();
        const source = String(text || "").replace(/\r\n/g, "\n");
        if (!source.trim()) return;

        const lines = source.split("\n");
        let paragraph = [];
        const flushParagraph = () => {
          appendParagraph(container, paragraph);
          paragraph = [];
        };

        for (let index = 0; index < lines.length; index += 1) {
          const line = lines[index];
          const trimmed = line.trim();

          if (!trimmed) {
            flushParagraph();
            continue;
          }

          const fence = trimmed.match(/^```(\S*)?/);
          if (fence) {
            flushParagraph();
            const codeLines = [];
            index += 1;
            while (index < lines.length && !lines[index].trim().startsWith("```")) {
              codeLines.push(lines[index]);
              index += 1;
            }
            const code = h("code", {}, codeLines.join("\n"));
            if (fence[1]) code.setAttribute("data-language", fence[1]);
            container.appendChild(h("pre", {}, code));
            continue;
          }

          if (/^([-*_])\s*\1\s*\1\s*$/.test(trimmed)) {
            flushParagraph();
            container.appendChild(h("hr"));
            continue;
          }

          const heading = trimmed.match(/^(#{1,4})\s+(.+)$/);
          if (heading) {
            flushParagraph();
            const level = String(heading[1]).length;
            const el = h("h" + level);
            appendInlineMarkdown(el, heading[2]);
            container.appendChild(el);
            continue;
          }

          if (/^>\s?/.test(line)) {
            flushParagraph();
            const quoteLines = [];
            while (index < lines.length && /^>\s?/.test(lines[index])) {
              quoteLines.push(lines[index].replace(/^>\s?/, ""));
              index += 1;
            }
            index -= 1;
            const blockquote = h("blockquote");
            appendParagraph(blockquote, quoteLines);
            container.appendChild(blockquote);
            continue;
          }

          const tableHeaders = line.includes("|") ? splitMarkdownTableRow(line) : [];
          if (
            tableHeaders.length > 1
            && index + 1 < lines.length
            && isMarkdownTableSeparator(lines[index + 1], tableHeaders.length)
          ) {
            flushParagraph();
            const headerLine = line;
            const bodyLines = [];
            index += 2;
            while (index < lines.length && lines[index].includes("|") && lines[index].trim()) {
              bodyLines.push(lines[index]);
              index += 1;
            }
            index -= 1;
            appendTable(container, headerLine, bodyLines);
            continue;
          }

          const unordered = /^\s*[-*]\s+/.test(line);
          const ordered = /^\s*\d+[.)]\s+/.test(line);
          if (unordered || ordered) {
            flushParagraph();
            const listLines = [];
            const marker = ordered ? /^\s*\d+[.)]\s+/ : /^\s*[-*]\s+/;
            while (index < lines.length && marker.test(lines[index])) {
              listLines.push(lines[index]);
              index += 1;
            }
            index -= 1;
            appendList(container, listLines, ordered);
            continue;
          }

          paragraph.push(line);
        }
        flushParagraph();
      }

      function compactText(text, max = 44) {
        const singleLine = String(text || "").replace(/\s+/g, " ").trim();
        if (!singleLine) return "(empty)";
        return singleLine.length > max ? singleLine.slice(0, max - 1) + "…" : singleLine;
      }
      function commitShortShaFromHash(hashValue = window.location.hash) {
        const hash = String(hashValue || "").replace(/^#/, "");
        if (!hash) return null;
        if (hash.startsWith("commit-")) return hash.slice("commit-".length) || null;
        const turnMatch = hash.match(/^([0-9a-f]{7,40})-t-\d+$/i);
        if (turnMatch) return turnMatch[1];
        return null;
      }
      function setExpandedSidebarCommit(shortSha) {
        state.expandedSidebarCommit = shortSha || null;
      }
      function resolveExpandedSidebarCommit(commits) {
        const shortShas = commits.map((commit) => commit.short_sha).filter(Boolean);
        if (shortShas.length === 0) {
          setExpandedSidebarCommit(null);
          return null;
        }

        const fromHash = commitShortShaFromHash();
        if (fromHash && shortShas.includes(fromHash)) {
          setExpandedSidebarCommit(fromHash);
          return fromHash;
        }

        if (state.expandedSidebarCommit && shortShas.includes(state.expandedSidebarCommit)) {
          return state.expandedSidebarCommit;
        }

        if (state.current?.commit && shortShas.includes(state.current.commit)) {
          setExpandedSidebarCommit(state.current.commit);
          return state.current.commit;
        }

        setExpandedSidebarCommit(shortShas[0]);
        return shortShas[0];
      }
      function jumpToAnchor(id) {
        const url = new URL(window.location.href);
        url.hash = id;
        history.replaceState(null, "", url);
        if (state.current?.mode === "pr") {
          const expandedCommit = commitShortShaFromHash("#" + id);
          if (expandedCommit) setExpandedSidebarCommit(expandedCommit);
        }
        scrollToId(id);
      }
      function tailPath(path) {
        return String(path || "").split("/").slice(-2).join("/");
      }
      function renderMetaPill(label, value, extraChildren = []) {
        if (value == null || value === "") return null;
        return h("span", { className: "meta-pill" }, [
          h("span", { className: "meta-pill-label" }, label),
          ...extraChildren,
          h("span", { className: "meta-pill-value", title: String(value) }, String(value)),
        ]);
      }
      function hasLineLevelData(lines) {
        return typeof lines?.total_added === "number" && lines.total_added > 0;
      }
      function lineAttributionLabel(note) {
        const attr = note?.attribution || {};
        const lines = attr.lines || {};
        if (hasLineLevelData(lines)) {
          return `${lines.ai_added ?? 0}/${lines.total_added} AI-added lines`;
        }
        if (attr.method === "file") return "File-level attribution";
        if (attr.method === "none") return "No AI-added lines";
        return "Line data unavailable";
      }
      function renderLineAttributionPill(note) {
        return renderMetaPill("lines", lineAttributionLabel(note));
      }
      function renderAgentPill(agent, model) {
        if (!agent && !model) return null;
        const key = normalizeAgentKey(agent, model);
        const label = AGENT_ICON_LABELS[key] || agent || model || "Unknown AI agent";
        return h("span", { className: "meta-pill agent-pill" }, [
          renderAgentAvatar(agent, model, true),
          h("span", { className: "meta-pill-value" }, label),
        ]);
      }
      function renderCommitFiles(files) {
        if (!files?.length) return h("div", { className: "commit-file-empty" }, "No files captured");
        return h("div", { className: "commit-file-list" }, files.map((file) =>
          h("div", { className: "commit-file-row" }, [
            h("span", { className: file.by_ai ? "by_ai" : "by_human" }, file.by_ai ? "🤖" : "👤"),
            h("span", { className: "commit-file-name", title: file.path }, tailPath(file.path)),
          ])
        ));
      }
      function renderTurnTree(note, anchorPrefix = "") {
        const turns = note?.interactions || [];
        if (turns.length === 0) return null;
        const activeHash = (window.location.hash || "").replace(/^#/, "");
        const parentCommit = note?.commit?.short_sha || note?.commit?.sha?.slice(0, 7) || null;
        return h("div", { className: "turn-tree" }, [
          h("div", { className: "tree-section-label" }, "Turns"),
          ...turns.map((interaction, idx) => {
            const turnId = anchorPrefix + "t-" + (idx + 1);
            return h("button", {
              className: "turn-node" + (activeHash === turnId ? " active" : ""),
              onClick: (e) => {
                e.stopPropagation();
                setExpandedSidebarCommit(parentCommit);
                jumpToAnchor(turnId);
                renderSidebar();
                closeMobileSidebar();
              },
            }, [
              h("span", { className: "turn-node-id" }, "#" + (idx + 1)),
              h("span", { className: "turn-node-text" }, compactText(interaction.prompt, 48)),
              (interaction.tools?.length || 0) > 0 && h("span", { className: "turn-node-pill" }, interaction.tools.length + "t"),
            ].filter(Boolean));
          }),
        ]);
      }
      function queryMatches(fields) {
        const q = state.search.trim().toLowerCase();
        if (!q) return true;
        const haystack = [];
        for (const field of fields) {
          if (Array.isArray(field)) haystack.push(...field);
          else haystack.push(field);
        }
        return haystack.filter(Boolean).join(" ").toLowerCase().includes(q);
      }
      function sortCommitSummaries(commits, direction = "desc") {
        return [...commits].sort((a, b) => {
          const left = a?.date || "";
          const right = b?.date || "";
          return direction === "asc" ? left.localeCompare(right) : right.localeCompare(left);
        });
      }
      function getCommitSummary(shortSha) {
        return (state.index?.commits || []).find((c) => c.short_sha === shortSha || c.sha === shortSha);
      }
      function getPRForCommit(shortSha) {
        return (state.index?.prs || []).find((pr) => pr.commits.includes(shortSha));
      }
      async function loadNoteForSummary(summary) {
        if (state.noteCache.has(summary.short_sha)) return state.noteCache.get(summary.short_sha);
        const noteUrl = typeof summary.note_url === "string" ? summary.note_url : "";
        const res = await fetch(noteUrl);
        if (!res.ok) throw new Error("Failed to load note: " + summary.short_sha);
        const note = await res.json();
        note.commit = {
          ...(note.commit || {}),
          sha: note.commit?.sha || summary.sha,
          short_sha: note.commit?.short_sha || summary.short_sha,
          message: note.commit?.message || summary.message,
          date: note.commit?.date || summary.date,
          author: note.commit?.author || summary.author,
        };
        state.noteCache.set(summary.short_sha, note);
        if (!summary.session_id && note.session_id) summary.session_id = note.session_id;
        return note;
      }
      async function loadNotesForSummaries(summaries) {
        const notes = await Promise.all(
          summaries.map(async (summary) => {
            try {
              return await loadNoteForSummary(summary);
            } catch {
              return null;
            }
          })
        );
        return notes
          .filter(Boolean)
          .sort((a, b) => (a.commit?.date || "").localeCompare(b.commit?.date || ""));
      }

      // ─── Sidebar ───
      function getFilteredCommits() {
        const commits = state.index?.commits || [];
        return commits.filter((c) =>
          queryMatches([c.message, c.short_sha, c.author, c.agent, c.model])
        );
      }
      function getFilteredPRs() {
        const prs = state.index?.prs || [];
        return prs.filter((pr) => {
          const summaries = pr.commits.map((sha) => getCommitSummary(sha)).filter(Boolean);
          return queryMatches([
            "#" + pr.number,
            pr.title,
            summaries.map((s) => [s.message, s.short_sha, s.author, s.agent]),
          ]);
        });
      }
      function commitSectionIdFromSummary(summary) {
        return "commit-" + (summary?.short_sha || (summary?.sha || "").slice(0, 7));
      }
      function renderSidebarCommitNode(summary, options = {}) {
        const mode = options.mode || "select";
        const note = options.note || null;
        const showTurns = !!options.showTurns;
        const anchorPrefix = options.anchorPrefix || "";
        const sectionId = commitSectionIdFromSummary(summary);
        const activeCommit = state.current?.mode === "commit" && state.current.commit === summary.short_sha;
        const activeHash = (window.location.hash || "").replace(/^#/, "");
        const highlighted =
          mode === "scroll" &&
          (activeHash === sectionId || activeHash.startsWith(anchorPrefix + "t-"));
        return h("div", {}, [
          h("button", {
            className:
              "tree-commit" +
              (activeCommit || highlighted ? " active" : "") +
              (mode === "scroll" ? " scroll-target" : ""),
            onClick: (e) => {
              e.stopPropagation();
              if (mode === "scroll") {
                setExpandedSidebarCommit(summary.short_sha);
                jumpToAnchor(sectionId);
                renderSidebar();
                closeMobileSidebar();
                return;
              }
              selectCommit(summary.short_sha);
            },
          }, [
            h("div", { className: "tree-commit-title" }, summary.message || "(no message)"),
            h("div", { className: "tree-commit-meta" }, [
              h("span", { className: "sha" }, summary.short_sha),
              h("span", {}, "🤖 " + (summary.ai_ratio ?? 0) + "%"),
              h("span", {}, (summary.turns ?? 0) + " turns"),
              summary.date && h("span", {}, formatDate(summary.date)),
            ].filter(Boolean)),
          ]),
          showTurns && note && renderTurnTree(note, anchorPrefix),
          !showTurns && activeCommit && state.currentNote && renderTurnTree(state.currentNote),
        ].filter(Boolean));
      }

      function renderSidebar() {
        const list = document.getElementById("sidebar-list");
        list.innerHTML = "";
        if (!state.index) return;
        const filtered = getFilteredCommits();
        const filteredCommitIds = new Set(filtered.map((commit) => commit.short_sha));

        if (state.sideTab === "prs") {
          const prs = getFilteredPRs();
          if (prs.length === 0) {
            list.appendChild(h("div", { className: "empty" }, "No PRs yet"));
            return;
          }
          list.appendChild(h("div", { className: "group-label" }, "Pull Requests"));
          for (const pr of prs) {
            const prCommits = pr.commits
              .map((sha) => state.index.commits.find((c) => c.short_sha === sha || c.sha === sha))
              .filter(Boolean);
            const prNotesByShortSha = new Map(
              (state.currentGroupNotes || []).map((note) => [note.commit?.short_sha, note])
            );
            const avgRatio = prCommits.length
              ? Math.round(prCommits.reduce((a, c) => a + (c.ai_ratio ?? 0), 0) / prCommits.length)
              : 0;
            const active = state.current?.prNumber === pr.number;
            const branch = h("div", { className: "sidebar-branch" }, []);
            const card = h("div", {
              className: "pr-card" + (active ? " active" : ""),
              onClick: () => selectPR(pr.number),
            }, [
              h("div", { className: "card-title" }, "#" + pr.number + " " + pr.title),
              h("div", { className: "card-meta" }, [
                h("span", {}, prCommits.length + " commits"),
                h("span", { className: "ratio" }, "🤖 " + avgRatio + "%"),
              ]),
              h("div", { className: "ratio-bar" }, h("span", { style: "width:" + avgRatio + "%;" })),
            ]);
            branch.appendChild(card);
            if (active) {
              const visibleCommits = prCommits.filter((commit) => !state.search || filteredCommitIds.has(commit.short_sha));
              if (visibleCommits.length > 0) {
                const expandedCommit = resolveExpandedSidebarCommit(visibleCommits);
                branch.appendChild(h(
                  "div",
                  { className: "sidebar-tree" },
                  [
                    h("div", { className: "tree-section-label" }, "Commits"),
                    ...visibleCommits.map((commit) =>
                    renderSidebarCommitNode(
                      commit,
                      {
                        mode: state.current?.mode === "pr" ? "scroll" : "select",
                        note: prNotesByShortSha.get(commit.short_sha) || null,
                        showTurns: state.current?.mode === "pr" && expandedCommit === commit.short_sha,
                        anchorPrefix: `${commit.short_sha}-`,
                      },
                    )
                  ),
                  ]
                ));
              }
            }
            list.appendChild(branch);
          }
          return;
        }

        if (state.sideTab === "commits") {
          list.appendChild(h("div", { className: "group-label" }, "Commits (newest first)"));
          const sorted = [...filtered].sort((a, b) => (b.date || "").localeCompare(a.date || ""));
          if (sorted.length === 0) {
            list.appendChild(h("div", { className: "empty" }, "No matches"));
            return;
          }
          for (const c of sorted) {
            list.appendChild(h("div", { className: "sidebar-branch" }, [
              renderSidebarCommitNode(c, { mode: "select" }),
            ]));
          }
          return;
        }
      }

      // ─── Navigation ───
      async function selectCommit(shortSha) {
        const summary = getCommitSummary(shortSha);
        if (!summary) return;
        const pr = getPRForCommit(shortSha);
        state.loading = true;
        state.missingSelection = null;
        state.current = {
          mode: "commit",
          commit: shortSha,
          prNumber: pr?.number ?? null,
        };
        setExpandedSidebarCommit(shortSha);
        state.currentNote = null;
        state.currentGroupNotes = [];
        setUrlParam("commit", shortSha);
        setUrlParam("pr", pr?.number ?? null);
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
        closeMobileSidebar();
        const token = ++state.loadToken;
        try {
          const note = await loadNoteForSummary(summary);
          if (token !== state.loadToken) return;
          state.currentNote = note;
        } catch {
          if (token !== state.loadToken) return;
          state.currentNote = null;
        }
        if (token !== state.loadToken) return;
        state.loading = false;
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
      }

      async function selectPR(num) {
        const pr = (state.index?.prs || []).find((p) => p.number === num);
        const summaries = pr?.commits?.map((sha) => getCommitSummary(sha)).filter(Boolean) || [];
        if (summaries.length === 0) return;
        const sortedSummaries = sortCommitSummaries(summaries, "asc");
        state.loading = true;
        state.missingSelection = null;
        state.current = {
          mode: "pr",
          commit: null,
          prNumber: num,
        };
        setExpandedSidebarCommit(resolveExpandedSidebarCommit(sortedSummaries));
        state.currentNote = null;
        state.currentGroupNotes = [];
        setUrlParam("commit", null);
        setUrlParam("pr", num);
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
        closeMobileSidebar();
        const token = ++state.loadToken;
        const notes = await loadNotesForSummaries(sortedSummaries);
        if (token !== state.loadToken) return;
        state.currentGroupNotes = notes;
        setExpandedSidebarCommit(resolveExpandedSidebarCommit(sortedSummaries));
        state.loading = false;
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
      }

      function neighborCommit(dir) {
        if (state.current?.mode !== "commit") return null;
        const list = state.flatCommits;
        const idx = list.findIndex((c) => c.short_sha === state.current?.commit);
        if (idx === -1) return null;
        const next = list[idx + dir];
        return next ? next.short_sha : null;
      }

      function updateNavButtons() {
        const prev = neighborCommit(-1);
        const next = neighborCommit(1);
        document.getElementById("btn-prev").toggleAttribute("disabled", !prev);
        document.getElementById("btn-next").toggleAttribute("disabled", !next);
      }

      function summarizeNotes(notes) {
        const fileCounts = new Map();
        const agents = new Set();
        const authors = new Set();
        let turns = 0;
        let aiAdded = 0;
        let totalAdded = 0;
        let deleted = 0;
        let lineDataCommits = 0;
        let fileLevelCommits = 0;
        let noneMethodCommits = 0;
        let ratioTotal = 0;
        const prNumbers = new Set();

        for (const note of notes) {
          turns += note.interactions?.length || 0;
          const lines = note.attribution?.lines || {};
          const method = note.attribution?.method;
          if (hasLineLevelData(lines)) {
            lineDataCommits += 1;
            aiAdded += lines.ai_added ?? 0;
            totalAdded += lines.total_added;
            deleted += lines.deleted ?? 0;
          }
          if (method === "file") fileLevelCommits += 1;
          if (method === "none") noneMethodCommits += 1;
          ratioTotal += note.attribution?.ai_ratio ?? 0;
          if (note.agent) agents.add(note.agent);
          if (note.commit?.author) authors.add(note.commit.author);
          const pr = getPRForCommit(note.commit?.short_sha);
          if (pr?.number != null) prNumbers.add(pr.number);
          for (const file of note.files || []) {
            const current = fileCounts.get(file.path) || { path: file.path, count: 0, aiCount: 0 };
            current.count += 1;
            if (file.by_ai) current.aiCount += 1;
            fileCounts.set(file.path, current);
          }
        }

        const sortedByDate = [...notes].sort((a, b) => (a.commit?.date || "").localeCompare(b.commit?.date || ""));
        return {
          commits: notes.length,
          turns,
          aiAdded,
          totalAdded,
          deleted,
          lineDataCommits,
          fileLevelCommits,
          noneMethodCommits,
          uniqueFiles: fileCounts.size,
          avgRatio: notes.length ? Math.round(ratioTotal / notes.length) : 0,
          firstDate: sortedByDate[0]?.commit?.date ?? null,
          lastDate: sortedByDate[sortedByDate.length - 1]?.commit?.date ?? null,
          agents: [...agents],
          authors: [...authors],
          prNumbers: [...prNumbers],
          fileCounts: [...fileCounts.values()].sort((a, b) => b.count - a.count || a.path.localeCompare(b.path)),
        };
      }
      function lineSummaryLabel(summary) {
        if (summary.totalAdded > 0) {
          const partial = summary.lineDataCommits < summary.commits ? " · partial" : "";
          return `${summary.aiAdded}/${summary.totalAdded} AI-added lines${partial}`;
        }
        if (summary.commits > 0 && summary.fileLevelCommits === summary.commits) {
          return "File-level attribution";
        }
        if (summary.commits > 0 && summary.noneMethodCommits === summary.commits) {
          return "No AI-added lines";
        }
        return "Line data unavailable";
      }
      function commitSectionId(note) {
        return commitSectionIdFromSummary(note.commit || {});
      }
      function scrollToId(id) {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
      }
      function updateGitHubLink() {
        const link = document.getElementById("btn-github");
        if (!link) return;
        let href = repoUrl;
        let label = "GitHub ↗";
        if (state.current?.mode === "commit" && state.currentNote?.commit?.sha) {
          href = `${repoUrl}/commit/${state.currentNote.commit.sha}`;
          label = `Commit ${state.currentNote.commit.short_sha || state.currentNote.commit.sha.slice(0, 7)} ↗`;
        } else if (state.current?.mode === "pr" && state.current?.prNumber != null) {
          href = `${repoUrl}/pull/${state.current.prNumber}`;
          label = `PR #${state.current.prNumber} ↗`;
        }
        link.href = href;
        link.textContent = label;
      }

      // ─── Main ───
      function renderCommitHeader(note) {
        const c = note.commit || {};
        const attr = note.attribution || {};
        const files = note.files || [];
        const ratio = attr.ai_ratio ?? 0;
        const lines = attr.lines || {};
        const sessionShort = note.session_id ? `${note.session_id.slice(0, 8)}…` : null;

        const shaSpan = h("span", {
          className: "sha",
          title: "Click to copy full SHA",
          onClick: () => {
            copyToClipboard(c.sha || c.short_sha || "");
            shaSpan.classList.add("copied");
            setTimeout(() => shaSpan.classList.remove("copied"), 1200);
          },
        }, c.short_sha || (c.sha || "").slice(0, 7));

        return h("div", { className: "commit-head" }, [
          h("h1", { className: "commit-title" }, c.message || "(no message)"),
          h("div", { className: "commit-meta-row" }, [
            shaSpan,
            c.author && h("span", {}, c.author),
            c.date && h("span", {}, formatDateTime(c.date)),
          ].filter(Boolean)),
          h("div", { className: "stats-row" }, [
            h("span", { className: "stat primary bar" }, [
              h("span", {}, "🤖 " + ratio + "%"),
              h("span", { className: "track" }, h("span", { style: "width:" + ratio + "%;" })),
            ]),
            note.interactions && h("span", { className: "stat outline" }, note.interactions.length + " turns"),
          ].filter(Boolean)),
          h("div", { className: "commit-context-grid" }, [
            h("section", { className: "commit-context-card" }, [
              h("h2", { className: "commit-context-title" }, "Meta"),
              h("div", { className: "meta-pill-row" }, [
                renderAgentPill(note.agent, note.model),
                renderMetaPill("model", note.model),
                renderMetaPill("session", sessionShort, []),
                renderMetaPill("method", attr.method),
                renderLineAttributionPill(note),
                hasLineLevelData(lines) && renderMetaPill("deleted", String(lines.deleted ?? 0)),
              ].filter(Boolean)),
            ]),
            h("section", { className: "commit-context-card" }, [
              h("h2", { className: "commit-context-title" }, "Files in Commit"),
              renderCommitFiles(files),
            ]),
          ]),
        ]);
      }

      function renderTurn(interaction, idx, total, agent, model, anchorPrefix = "") {
        const tools = interaction.tools || [];
        const files = interaction.files_touched || [];
        const turnId = anchorPrefix + "t-" + (idx + 1);
        const contextText = getInteractionContextText(interaction);
        let contextRow = null;
        if (contextText) {
          const contextBody = h("div", {});
          renderMarkdownInto(contextBody, contextText);
          contextRow = h("div", { className: "context-row" }, [
            h("div", { className: "context-card" }, [
              h("div", { className: "context-label" }, "📝 Context"),
              contextBody,
            ]),
          ]);
        }

        // User bubble — prompts are usually plain text (user input), render as markdown too for inline code support
        const userBody = h("div", {});
        renderMarkdownInto(userBody, interaction.prompt || "");
        const userRow = h("div", { className: "bubble-row from-user" }, [
          h("span", { className: "turn-label" }, "#" + (idx + 1)),
          h("div", {
            className: "bubble user",
            dataset: { turn: String(idx + 1) },
          }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy prompt",
                onClick: () => copyToClipboard(interaction.prompt || ""),
              }, "📋"),
              h("button", {
                title: "Permalink",
                onClick: () => {
                  const url = new URL(window.location.href);
                  url.hash = turnId;
                  copyToClipboard(url.toString());
                },
              }, "🔗"),
            ]),
            userBody,
          ]),
          h("div", { className: "avatar" }, "🧑"),
        ]);

        // AI bubble — markdown-rendered
        const hasResp = !!interaction.response;
        const aiBody = h("div", {});
        if (hasResp) renderMarkdownInto(aiBody, interaction.response);
        else aiBody.textContent = "(no response captured)";
        const aiRow = h("div", { className: "bubble-row from-ai" }, [
          renderAgentAvatar(agent, model),
          h("div", { className: "bubble ai" + (hasResp ? "" : " empty") }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy response",
                onClick: () => copyToClipboard(interaction.response || ""),
              }, "📋"),
            ]),
            aiBody,
          ]),
        ]);

        const footer = [];
        for (const t of tools) footer.push(h("span", { className: "chip tool" }, t));
        for (const f of files) footer.push(h("span", { className: "chip file" }, f.split("/").pop()));

        return h("div", { className: "turn", id: turnId }, [
          h("div", { className: "turn-divider" }, "turn " + (idx + 1) + " / " + total),
          contextRow,
          userRow,
          aiRow,
          footer.length > 0 && h("div", { className: "bubble-footer", style: "margin-left: 2.3rem;" }, footer),
        ].filter(Boolean));
      }

      function getInteractionContextText(interaction) {
        const contexts = [];
        const seen = new Set();
        const add = (context) => {
          const text = String(context?.text || "").trim();
          if (!text || seen.has(text)) return;
          seen.add(text);
          contexts.push({ kind: context?.kind || "reference", text });
        };

        const legacy = String(interaction?.context || "").trim();
        if (legacy) add({ kind: "reference", text: legacy });
        for (const context of interaction?.contexts || []) add(context);

        return contexts
          .sort((left, right) => contextKindOrder(left.kind) - contextKindOrder(right.kind))
          .map((context) => context.text)
          .join("\n\n")
          .trim();
      }

      function contextKindOrder(kind) {
        return kind === "reference" ? 0 : 1;
      }

      function renderChat(note, anchorPrefix = "") {
        const thread = h("div", { className: "chat-pane" });
        const interactions = mergePromptOnlyDisplayInteractions(note.interactions || []);
        interactions.forEach((i, idx) => {
          thread.appendChild(renderTurn(i, idx, interactions.length, note.agent, note.model, anchorPrefix));
        });
        return thread;
      }

      function mergePromptOnlyDisplayInteractions(interactions) {
        const result = [];
        let pendingPrompts = [];

        for (const interaction of interactions) {
          if (isPromptOnlyDisplayPrefix(interaction)) {
            pendingPrompts.push(interaction.prompt || "");
            continue;
          }

          if (pendingPrompts.length > 0) {
            result.push({
              ...interaction,
              prompt: [...pendingPrompts, interaction.prompt || ""].join("\n\n"),
            });
            pendingPrompts = [];
            continue;
          }

          result.push(interaction);
        }

        for (const prompt of pendingPrompts) {
          result.push({ prompt, response: null });
        }

        return result;
      }

      function isPromptOnlyDisplayPrefix(interaction) {
        return (
          interaction?.response === null &&
          !interaction?.context &&
          !(interaction?.contexts || []).length &&
          !(interaction?.files_touched || []).length &&
          !interaction?.selection &&
          interaction?.tools === undefined
        );
      }

      function diffStats(file) {
        let added = 0, removed = 0;
        for (const line of file.lines || []) {
          if (line.startsWith("+") && !line.startsWith("+++")) added++;
          else if (line.startsWith("-") && !line.startsWith("---")) removed++;
        }
        return { added, removed };
      }

      function renderDiff(note) {
        const wrap = h("div", { className: "diff-pane" });
        const diff = note.diff;
        if (!diff?.files?.length) {
          wrap.appendChild(h("div", { className: "empty" }, [h("div", { className: "big" }, "📄"), "No diff captured"]));
          return wrap;
        }
        for (const file of diff.files) {
          const { added, removed } = diffStats(file);
          const diffLines = file.lines || [];
          const header = h("div", {
            className: "diff-file-header",
            onClick: (e) => {
              const parent = e.currentTarget.parentElement;
              parent.classList.toggle("collapsed");
            },
          }, [
            h("span", { className: "caret" }, "▾"),
            h("span", {}, file.path),
            h("span", { className: "stats" }, [
              h("span", { className: "added" }, "+" + added),
              h("span", { className: "removed" }, "−" + removed),
            ]),
          ]);

          const body = diffLines.length > 0 ? h("div", { className: "diff-body" }) : null;
          let oldNo = 0, newNo = 0;
          for (const line of diffLines) {
            let cls = "diff-line";
            let num = "";
            if (line.startsWith("@@")) {
              cls += " hunk";
              const m = line.match(/\+(\d+)/);
              if (m) newNo = parseInt(m[1], 10) - 1;
              const m2 = line.match(/-(\d+)/);
              if (m2) oldNo = parseInt(m2[1], 10) - 1;
              num = "";
            } else if (line.startsWith("+") && !line.startsWith("+++")) {
              cls += " add"; newNo++; num = String(newNo);
            } else if (line.startsWith("-") && !line.startsWith("---")) {
              cls += " del"; oldNo++; num = String(oldNo);
            } else if (line.startsWith("diff ") || line.startsWith("index ") || line.startsWith("---") || line.startsWith("+++") || line.startsWith("new file") || line.startsWith("deleted file") || line.startsWith("rename") || line.startsWith("similarity")) {
              cls += " meta";
              num = "";
            } else {
              oldNo++; newNo++; num = String(newNo);
            }
            body.appendChild(h("div", { className: cls }, [
              h("span", { className: "lineno" }, num),
              h("span", { className: "content" }, line || " "),
            ]));
          }
          const diffNotice = file.binary
            ? "Binary diff not shown"
            : file.truncated
              ? diffLines.length > 0
                ? "Diff truncated"
                : "Diff omitted after size limit"
              : null;

          const fileEl = h("div", { className: "diff-file" }, [
            header,
            body,
            diffNotice && h("div", { className: "diff-truncated" }, diffNotice),
          ].filter(Boolean));
          wrap.appendChild(fileEl);
        }
        return wrap;
      }
      function renderCollectionHeader(notes) {
        const summary = summarizeNotes(notes);
        const pr = (state.index?.prs || []).find((item) => item.number === state.current?.prNumber);
        const title = `PR #${pr?.number ?? state.current?.prNumber} · ${pr?.title || "Merged conversation"}`;
        const subtitle = "Read the whole conversation arc across commits before drilling into a single diff.";

        return h("div", { className: "collection-head" }, [
          h("div", { className: "collection-kicker" }, "Pull Request Story"),
          h("h1", { className: "collection-title" }, title),
          h("p", { className: "collection-subtitle" }, subtitle),
          h("div", { className: "stats-row" }, [
            h("span", { className: "stat primary bar" }, [
              h("span", {}, "🤖 " + summary.avgRatio + "%"),
              h("span", { className: "track" }, h("span", { style: "width:" + summary.avgRatio + "%;" })),
            ]),
            h("span", { className: "stat outline" }, summary.commits + " commits"),
            h("span", { className: "stat outline" }, summary.turns + " turns"),
            h("span", { className: "stat outline" }, summary.uniqueFiles + " files"),
            h("span", { className: "stat warm" }, lineSummaryLabel(summary)),
          ]),
          h("div", { className: "collection-subtitle", style: "margin-top:0.85rem;" }, [
            summary.firstDate && h("span", {}, `${formatDate(summary.firstDate)} → ${formatDate(summary.lastDate)}`),
            summary.authors.length > 0 && h("span", {}, ` · ${summary.authors.join(", ")}`),
            summary.agents.length > 0 && h("span", {}, ` · ${summary.agents.join(", ")}`),
          ].filter(Boolean)),
          h("div", { className: "collection-jump-list" },
            notes.map((note) => h("button", {
              className: "jump-chip",
              onClick: () => jumpToAnchor(commitSectionId(note)),
            }, `${note.commit?.short_sha} · ${compactText(note.commit?.message, 28)}`))
          ),
        ]);
      }
      function renderCollectionCommit(note, idx, total) {
        const commit = note.commit || {};
        const ratio = note.attribution?.ai_ratio ?? 0;
        return h("section", { className: "collection-commit", id: commitSectionId(note) }, [
          h("div", { className: "collection-commit-head" }, [
            h("div", { className: "collection-commit-head-main" }, [
              h("div", { className: "collection-commit-kicker" }, `Commit ${idx + 1} of ${total}`),
              h("h2", { className: "collection-commit-title" }, commit.message || "(no message)"),
              h("div", { className: "collection-commit-meta" }, [
                h("span", { className: "sha" }, commit.short_sha || (commit.sha || "").slice(0, 7)),
                commit.author && h("span", {}, commit.author),
                commit.date && h("span", {}, formatDateTime(commit.date)),
                h("span", { className: "ratio" }, `🤖 ${ratio}%`),
                h("span", {}, `${note.interactions?.length || 0} turns`),
              ].filter(Boolean)),
            ]),
            h("div", { className: "collection-commit-actions" }, [
              h("button", {
                className: "icon-btn primary",
                onClick: () => selectCommit(commit.short_sha || (commit.sha || "").slice(0, 7)),
              }, "Open commit"),
            ]),
          ]),
          h("div", { className: "collection-commit-body" }, [
            renderChat(note, `${commit.short_sha || (commit.sha || "").slice(0, 7)}-`),
            h("details", {}, [
              h("summary", {}, `Show diff (${note.diff?.files?.length || 0} files)`),
              renderDiff(note),
            ]),
          ]),
        ]);
      }
      function renderCollection(notes) {
        return h("div", { className: "collection-pane" }, notes.map((note, idx) => renderCollectionCommit(note, idx, notes.length)));
      }

      function renderViewTabs() {
        const tabs = [
          { id: "chat", label: "💬 Chat" },
          { id: "diff", label: "📝 Diff" },
        ];
        return h("div", { className: "view-tabs" },
          tabs.map((t) => h("button", {
            className: state.tab === t.id ? "active" : "",
            onClick: () => {
              state.tab = t.id;
              setUrlParam("tab", t.id === "chat" ? null : t.id);
              renderMain();
            },
          }, t.label))
        );
      }

      function renderKeyboardHints() {
        return h("div", { className: "hints" }, [
          h("span", {}, "Tip: "),
          h("kbd", {}, "/"), " to focus search · use the sidebar tree or jump chips to move through the story.",
        ]);
      }

      function renderMain() {
        const root = document.getElementById("root");
        const footer = document.getElementById("main-footer");
        root.innerHTML = "";
        footer.innerHTML = "";
        footer.appendChild(renderKeyboardHints());
        updateGitHubLink();
        if (state.loading) {
          root.appendChild(h("div", { className: "empty" }, [
            h("div", { className: "big" }, "⏳"),
            "Loading captured notes…",
          ]));
          return;
        }
        if (!state.current) {
          if (state.missingSelection) {
            root.appendChild(h("div", { className: "empty" }, [
              h("div", { className: "big" }, "📭"),
              `No dashboard data found for ${state.missingSelection}.`,
            ]));
            return;
          }
          const hasNotes = (state.index?.commits?.length || 0) > 0;
          root.appendChild(h("div", { className: "empty" }, [
            h("div", { className: "big" }, hasNotes ? "💬" : "📭"),
            hasNotes
              ? "Pick a commit from the sidebar."
              : "No dashboard data yet. Push a branch with agent-note history to start populating this dashboard.",
          ]));
          return;
        }
        if (state.current.mode === "commit") {
          if (!state.currentNote) {
            root.appendChild(h("div", { className: "empty" }, [
              h("div", { className: "big" }, "📭"),
              "No note data found for this commit.",
            ]));
            return;
          }
          const note = state.currentNote;
          root.appendChild(renderCommitHeader(note));
          root.appendChild(renderViewTabs());
          root.appendChild(state.tab === "diff" ? renderDiff(note) : renderChat(note));
        } else {
          const notes = state.currentGroupNotes;
          if (notes.length === 0) {
            root.appendChild(h("div", { className: "empty" }, [
              h("div", { className: "big" }, "📭"),
              "No note data found for this selection.",
            ]));
            return;
          }
          root.appendChild(renderCollectionHeader(notes));
          root.appendChild(renderCollection(notes));
        }

        // Scroll to anchor if any
        if (window.location.hash) {
          const el = document.querySelector(window.location.hash);
          if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      function renderRail() {
        return;
      }

      // ─── Mobile sidebar drawer ───
      function openMobileSidebar() {
        document.getElementById("sidebar").classList.add("open");
        document.getElementById("overlay").classList.add("show");
      }
      function closeMobileSidebar() {
        document.getElementById("sidebar").classList.remove("open");
        document.getElementById("overlay").classList.remove("show");
      }

      // ─── Wide mode detect ───
      function detectLayout() {
        state.wide = false;
        document.getElementById("app").classList.remove("wide");
      }

      // ─── Init ───
      function bindTopbar() {
        document.getElementById("btn-menu").addEventListener("click", openMobileSidebar);
        document.getElementById("overlay").addEventListener("click", closeMobileSidebar);
        document.getElementById("btn-prev").addEventListener("click", () => {
          const s = neighborCommit(-1);
          if (s) selectCommit(s);
        });
        document.getElementById("btn-next").addEventListener("click", () => {
          const s = neighborCommit(1);
          if (s) selectCommit(s);
        });
      }

      function bindSidebarTabs() {
        for (const btn of document.querySelectorAll("#tab-row button")) {
          btn.addEventListener("click", () => {
            document.querySelectorAll("#tab-row button").forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            state.sideTab = btn.dataset.tab;
            renderSidebar();
          });
        }
      }

      function bindKeyboard() {
        window.addEventListener("keydown", (e) => {
          if (e.target.tagName === "INPUT") {
            if (e.key === "Escape") e.target.blur();
            return;
          }
          if (e.key === "/") {
            e.preventDefault();
            document.getElementById("search-box").focus();
          }
        });
      }

      function bindSearch() {
        const input = document.getElementById("search-box");
        input.addEventListener("input", (e) => {
          state.search = e.target.value || "";
          renderSidebar();
        });
      }

      function restoreFromUrl() {
        const p = new URLSearchParams(window.location.search);
        const tab = p.get("tab");
        if (tab === "diff") state.tab = "diff";
        const commit = p.get("commit");
        if (commit) {
          if (getCommitSummary(commit)) return selectCommit(commit);
          return showMissingSelection(`commit ${commit}`);
        }
        const pr = p.get("pr");
        if (pr) {
          const match = (state.index?.prs || []).find((x) => String(x.number) === pr);
          if (match?.commits?.length) return selectPR(match.number);
          return showMissingSelection(`PR #${pr}`);
        }
        showDashboardHome();
      }

      function showDashboardHome() {
        state.loading = false;
        state.current = null;
        state.currentNote = null;
        state.currentGroupNotes = [];
        state.missingSelection = null;
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
      }

      function showMissingSelection(label) {
        state.loading = false;
        state.current = null;
        state.currentNote = null;
        state.currentGroupNotes = [];
        state.missingSelection = label;
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
      }

      async function init() {
        detectLayout();
        window.addEventListener("resize", () => {
          detectLayout();
        });

        // Build flat-sorted commit list for keyboard/prev/next (newest first)
        state.flatCommits = [...(state.index.commits || [])].sort((a, b) => (b.date || "").localeCompare(a.date || ""));

        bindTopbar();
        bindSidebarTabs();
        bindKeyboard();
        bindSearch();
        renderSidebar();
        await restoreFromUrl();
      }

      init();
    </script>
  </body>
</html>
