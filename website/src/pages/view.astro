---
const homePath = `${import.meta.env.BASE_URL}`;
const demoDataPath = `${import.meta.env.BASE_URL}view-demo.json`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Note — Chat Viewer</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/+/g, '/')} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0f172a;
        --panel-2: #1e293b;
        --border: #334155;
        --border-soft: #1e293b;
        --text: #f8fafc;
        --muted: #94a3b8;
        --muted-2: #64748b;
        --accent: #22c55e;
        --accent-dim: rgba(34, 197, 94, 0.12);
        --user-bubble: #14532d;
        --user-bubble-text: #dcfce7;
        --ai-bubble: #1e293b;
        --chip-bg: #0f172a;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg); color: var(--text);
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN', sans-serif;
        min-height: 100vh;
      }
      code, pre {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
      }

      .layout {
        max-width: 880px;
        margin: 0 auto;
        padding: 2rem 1rem 4rem;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border-soft);
      }
      .topbar a {
        color: var(--muted);
        font-size: 0.85rem;
        text-decoration: none;
      }
      .topbar a:hover { color: var(--accent); }

      .commit-header {
        margin: 2rem 0 1.5rem;
        padding: 1.25rem 1.5rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
      }
      .commit-header h1 {
        margin: 0 0 0.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .commit-header .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        font-size: 0.8rem;
        color: var(--muted);
      }
      .commit-header .meta .sha {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent);
      }
      .commit-header .stats {
        margin-top: 0.75rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .stat {
        padding: 0.25rem 0.75rem;
        background: var(--accent-dim);
        border: 1px solid var(--accent);
        border-radius: 999px;
        font-size: 0.75rem;
        color: var(--accent);
        font-family: 'JetBrains Mono', monospace;
      }
      .stat.muted {
        background: transparent;
        border-color: var(--border);
        color: var(--muted);
      }

      /* Chat bubbles */
      .thread {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .bubble {
        max-width: min(78%, 620px);
        padding: 0.75rem 1rem;
        border-radius: 16px;
        line-height: 1.55;
        font-size: 0.95rem;
        white-space: pre-wrap;
        word-wrap: break-word;
      }
      .bubble.user {
        align-self: flex-end;
        background: var(--user-bubble);
        color: var(--user-bubble-text);
        border-bottom-right-radius: 4px;
      }
      .bubble.ai {
        align-self: flex-start;
        background: var(--ai-bubble);
        color: var(--text);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border-soft);
      }
      .bubble.ai.empty {
        color: var(--muted-2);
        font-style: italic;
      }
      .bubble-footer {
        margin-top: 0.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        font-size: 0.7rem;
      }
      .chip {
        padding: 0.15rem 0.55rem;
        background: var(--chip-bg);
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
      }
      .chip.tool { color: var(--accent); border-color: var(--accent); }
      .chip.file { color: var(--muted); }

      /* Avatars + side labels */
      .side {
        font-size: 0.7rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        padding: 0 0.25rem;
      }
      .turn.from-user .side { text-align: right; }
      .turn.from-ai .side { text-align: left; }

      .divider {
        margin: 1.5rem 0 0.5rem;
        font-size: 0.7rem;
        color: var(--muted-2);
        text-align: center;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      code.inline {
        background: var(--chip-bg);
        padding: 0.1em 0.3em;
        border-radius: 4px;
        font-size: 0.85em;
        color: var(--accent);
      }

      .note {
        margin-top: 2.5rem;
        padding: 1rem 1.25rem;
        background: var(--panel);
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        font-size: 0.85rem;
        color: var(--muted);
        line-height: 1.6;
      }
      .note strong { color: var(--text); }

      @media (max-width: 600px) {
        .bubble { max-width: 88%; font-size: 0.9rem; }
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <div class="topbar">
        <a href={homePath}>← Agent Note</a>
        <span class="side">Prototype — Chat Viewer</span>
      </div>

      <div id="root">
        <p class="note">Loading note from <code class="inline">{demoDataPath}</code>…</p>
      </div>
    </div>

    <script is:inline define:vars={{ demoDataPath }}>
      function h(tag, attrs = {}, children = []) {
        const el = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (k === 'className') el.className = v;
          else if (k === 'html') el.innerHTML = v;
          else el.setAttribute(k, v);
        }
        for (const child of [].concat(children)) {
          if (child == null) continue;
          if (typeof child === 'string') el.appendChild(document.createTextNode(child));
          else el.appendChild(child);
        }
        return el;
      }

      function renderChip(text, variant) {
        return h('span', { className: 'chip ' + (variant || '') }, text);
      }

      function renderHeader(note) {
        const c = note.commit || {};
        const attr = note.attribution || {};
        const files = note.files || [];
        const aiFiles = files.filter(f => f.by_ai).length;

        const meta = h('div', { className: 'meta' }, [
          c.sha && h('span', { className: 'sha' }, c.sha.slice(0, 7)),
          note.agent && h('span', {}, 'agent: ' + note.agent),
          note.model && h('span', {}, 'model: ' + note.model),
          c.date && h('span', {}, new Date(c.date).toLocaleString()),
        ].filter(Boolean));

        const stats = h('div', { className: 'stats' }, [
          typeof attr.ai_ratio === 'number' && h('span', { className: 'stat' }, '🤖 ' + attr.ai_ratio + '% AI'),
          attr.lines && h('span', { className: 'stat' }, attr.lines.ai_added + '/' + attr.lines.total_added + ' lines'),
          files.length > 0 && h('span', { className: 'stat muted' }, aiFiles + '/' + files.length + ' files AI'),
          note.interactions && h('span', { className: 'stat muted' }, note.interactions.length + ' turns'),
        ].filter(Boolean));

        return h('div', { className: 'commit-header' }, [
          c.message && h('h1', {}, c.message),
          meta,
          stats,
        ]);
      }

      function renderTurn(interaction, turnNumber) {
        const tools = interaction.tools || [];
        const files = interaction.files_touched || [];

        const userFooter = [];
        userFooter.push(h('span', { className: 'chip' }, 'turn ' + turnNumber));

        const aiFooter = [];
        for (const t of tools) aiFooter.push(renderChip(t, 'tool'));
        for (const f of files) aiFooter.push(renderChip(f.split('/').pop(), 'file'));

        const userBubble = h('div', { className: 'bubble user' }, interaction.prompt || '');
        const responseText = interaction.response || '(no response captured)';
        const aiBubble = h('div', { className: 'bubble ai' + (interaction.response ? '' : ' empty') }, responseText);

        return h('div', { className: 'turn' }, [
          h('div', { className: 'side from-user' }, '🧑 user'),
          userBubble,
          userFooter.length > 0 && h('div', { className: 'bubble-footer', style: 'align-self: flex-end;' }, userFooter),
          h('div', { className: 'side from-ai', style: 'margin-top: 0.5rem;' }, '🤖 ' + (interaction.response ? 'assistant' : 'assistant (no text response)')),
          aiBubble,
          aiFooter.length > 0 && h('div', { className: 'bubble-footer' }, aiFooter),
        ].filter(Boolean));
      }

      function render(note) {
        const root = document.getElementById('root');
        root.innerHTML = '';
        root.appendChild(renderHeader(note));

        const thread = h('div', { className: 'thread' });
        (note.interactions || []).forEach((i, idx) => {
          thread.appendChild(renderTurn(i, idx + 1));
        });
        root.appendChild(thread);

        root.appendChild(h('div', { className: 'note' }, [
          h('strong', {}, 'Prototype.'),
          ' ',
          'Reads a note JSON from the same origin. Later revisions can accept ',
          h('code', { className: 'inline' }, '?note=<url>'),
          ' to load any public note, or snapshot notes during the CI run so sharing a link just works.',
        ]));
      }

      async function load() {
        const params = new URLSearchParams(window.location.search);
        const override = params.get('note');
        const url = override || demoDataPath;
        try {
          const res = await fetch(url);
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const note = await res.json();
          render(note);
        } catch (err) {
          document.getElementById('root').innerHTML =
            '<p class="note"><strong>Failed to load note:</strong> ' + String(err) + '</p>';
        }
      }

      load();
    </script>
  </body>
</html>
