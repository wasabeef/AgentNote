---
const baseUrl = import.meta.env.BASE_URL;
const homePath = `${baseUrl}`;
const indexPath = `${baseUrl}/view-demo/index.json`.replace(/\/+/g, "/");
const repoUrl = "https://github.com/wasabeef/AgentNote";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Note — Chat Viewer</title>
    <link rel="icon" href={`${baseUrl}/favicon.svg`.replace(/\/+/g, "/")} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0b1220;
        --panel-2: #111c2e;
        --panel-3: #18253b;
        --border: #1e2a44;
        --border-strong: #334155;
        --text: #f1f5f9;
        --text-soft: #cbd5e1;
        --muted: #94a3b8;
        --muted-2: #64748b;
        --accent: #22c55e;
        --accent-2: #86efac;
        --accent-dim: rgba(34, 197, 94, 0.14);
        --user-bubble: linear-gradient(180deg, #166534, #14532d);
        --user-bubble-text: #ecfccb;
        --ai-bubble: #111c2e;
        --code-bg: #030712;
        --code-border: #1e293b;
        --chip-bg: #0f172a;
        --diff-add: rgba(34, 197, 94, 0.13);
        --diff-add-text: #86efac;
        --diff-del: rgba(239, 68, 68, 0.13);
        --diff-del-text: #fca5a5;
        --diff-hunk: rgba(59, 130, 246, 0.1);
        --diff-hunk-text: #93c5fd;
        --shadow: 0 6px 24px rgba(2, 6, 23, 0.6);
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          'IBM Plex Sans', -apple-system, BlinkMacSystemFont,
          'Hiragino Kaku Gothic ProN', 'Yu Gothic', sans-serif;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }
      code, pre, kbd {
        font-family: 'JetBrains Mono', ui-monospace, Menlo, Consolas, monospace;
      }
      button {
        font-family: inherit;
      }

      /* ─── App skeleton ─── */
      .app {
        display: grid;
        grid-template-columns: 320px 1fr;
        min-height: 100vh;
      }
      .app.wide {
        grid-template-columns: 300px 1fr 1fr;
      }
      @media (max-width: 960px) {
        .app, .app.wide { grid-template-columns: 1fr; }
        .sidebar {
          position: fixed; inset: 0; z-index: 40;
          transform: translateX(-100%);
          transition: transform 200ms ease;
        }
        .sidebar.open { transform: translateX(0); box-shadow: 4px 0 40px rgba(0,0,0,0.5); }
        .overlay {
          position: fixed; inset: 0; z-index: 35;
          background: rgba(0,0,0,0.5);
          display: none;
        }
        .overlay.show { display: block; }
      }

      /* ─── Sidebar ─── */
      .sidebar {
        background: var(--panel);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        max-height: 100vh;
        position: sticky;
        top: 0;
      }
      .sidebar-header {
        padding: 0.9rem 1rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .sidebar-header .logo {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text);
        text-decoration: none;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: -0.01em;
      }
      .sidebar-header .logo::before {
        content: "";
        width: 22px; height: 22px;
        background: var(--accent);
        mask-image: radial-gradient(circle, black 25%, transparent 26%);
        border-radius: 6px;
      }
      .badge {
        padding: 0.15rem 0.55rem;
        font-size: 0.62rem;
        border-radius: 999px;
        font-family: 'JetBrains Mono', monospace;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }
      .badge.accent { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }

      .tab-row {
        display: flex;
        padding: 0.4rem 0.6rem;
        border-bottom: 1px solid var(--border);
        gap: 0.25rem;
        background: var(--panel);
      }
      .tab-row button {
        flex: 1;
        padding: 0.45rem;
        background: transparent;
        border: 1px solid transparent;
        color: var(--muted);
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.78rem;
      }
      .tab-row button:hover { color: var(--text-soft); background: var(--panel-2); }
      .tab-row button.active { color: var(--accent); background: var(--accent-dim); border-color: var(--accent); }

      .search {
        padding: 0.55rem 0.8rem 0.8rem;
        position: relative;
      }
      .search input {
        width: 100%;
        padding: 0.55rem 0.8rem 0.55rem 2rem;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        border-radius: 8px;
        color: var(--text);
        font-family: inherit;
        font-size: 0.85rem;
        outline: none;
      }
      .search input:focus { border-color: var(--accent); }
      .search::before {
        content: "🔍";
        position: absolute;
        left: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        opacity: 0.5;
      }
      .search kbd {
        position: absolute;
        right: 1.1rem;
        top: 50%;
        transform: translateY(-50%);
        padding: 0.1rem 0.4rem;
        font-size: 0.65rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        border-radius: 4px;
        color: var(--muted);
      }

      .sidebar-list {
        overflow-y: auto;
        flex: 1;
        padding: 0.25rem 0 2rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border-strong) transparent;
      }
      .sidebar-list::-webkit-scrollbar { width: 6px; }
      .sidebar-list::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

      .group-label {
        padding: 0.75rem 1rem 0.3rem;
        font-size: 0.6rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }

      .pr-card, .commit-card, .session-card {
        margin: 0.15rem 0.55rem;
        padding: 0.65rem 0.85rem;
        border-radius: 10px;
        cursor: pointer;
        transition: background 120ms, border-color 120ms;
        border: 1px solid transparent;
      }
      .pr-card:hover, .commit-card:hover, .session-card:hover {
        background: var(--panel-2);
      }
      .pr-card.active, .commit-card.active, .session-card.active {
        background: var(--accent-dim);
        border-color: var(--accent);
      }
      .card-title {
        font-size: 0.83rem;
        color: var(--text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .card-meta {
        margin-top: 0.3rem;
        font-size: 0.68rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .card-meta .sha { color: var(--accent); }
      .card-meta .ratio { color: var(--accent-2); }
      .ratio-bar {
        margin-top: 0.4rem;
        height: 3px;
        background: var(--border);
        border-radius: 2px;
        overflow: hidden;
      }
      .ratio-bar span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .pr-card .pr-commits {
        margin-top: 0.4rem;
        font-size: 0.68rem;
        color: var(--muted);
        display: flex;
        gap: 0.4rem;
        font-family: 'JetBrains Mono', monospace;
      }

      /* ─── Main area ─── */
      .main {
        overflow-y: auto;
        max-height: 100vh;
      }
      .main-inner {
        max-width: 820px;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 6rem;
      }
      .app.wide .main-inner { max-width: 680px; }

      .topbar {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }
      .icon-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.45rem 0.75rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--muted);
        cursor: pointer;
        font-size: 0.78rem;
        transition: color 120ms, border-color 120ms, background 120ms;
      }
      .icon-btn:hover {
        color: var(--text);
        border-color: var(--border-strong);
        background: var(--panel-2);
      }
      .icon-btn.primary {
        background: var(--accent-dim);
        border-color: var(--accent);
        color: var(--accent);
      }
      .hamburger { display: none; }
      @media (max-width: 960px) { .hamburger { display: inline-flex; } }
      .spacer { flex: 1; }

      .commit-head {
        padding: 1.25rem 1.5rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        margin-bottom: 1.25rem;
      }
      .commit-title {
        margin: 0 0 0.5rem;
        font-size: 1.15rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.35;
      }
      .commit-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem 0.9rem;
        font-size: 0.78rem;
        color: var(--muted);
      }
      .commit-meta-row .sha {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent);
        cursor: pointer;
        position: relative;
      }
      .commit-meta-row .sha:hover { color: var(--accent-2); }
      .commit-meta-row .sha.copied::after {
        content: "copied!";
        position: absolute;
        left: 100%;
        margin-left: 0.5rem;
        font-size: 0.7rem;
        color: var(--accent-2);
        font-family: inherit;
      }
      .stats-row {
        margin-top: 0.9rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .stat {
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-family: 'JetBrains Mono', monospace;
      }
      .stat.primary { background: var(--accent-dim); border: 1px solid var(--accent); color: var(--accent); }
      .stat.outline { background: transparent; border: 1px solid var(--border-strong); color: var(--muted); }
      .stat.bar {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .stat.bar .track {
        width: 60px;
        height: 5px;
        background: var(--border);
        border-radius: 3px;
        overflow: hidden;
      }
      .stat.bar .track span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      /* ─── Tabs / split ─── */
      .view-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid var(--border);
        margin-bottom: 1rem;
      }
      .view-tabs button {
        padding: 0.6rem 1.1rem;
        background: transparent;
        color: var(--muted);
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        font-size: 0.85rem;
        transition: color 120ms;
      }
      .view-tabs button:hover { color: var(--text); }
      .view-tabs button.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }
      .app.wide .view-tabs { display: none; }

      /* Chat */
      .chat-pane {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
      }
      .turn {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }
      .turn-divider {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.65rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        margin: 0.5rem 0;
      }
      .turn-divider::before, .turn-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .bubble-row {
        display: flex;
        gap: 0.6rem;
      }
      .bubble-row.from-user {
        justify-content: flex-end;
      }
      .bubble-row.from-ai {
        justify-content: flex-start;
      }
      .avatar {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
        background: var(--panel-2);
        border: 1px solid var(--border);
      }
      .avatar.ai {
        background: linear-gradient(135deg, #14532d 0%, #166534 100%);
        border-color: var(--accent);
        color: var(--accent-2);
      }
      .bubble {
        max-width: min(82%, 540px);
        padding: 0.75rem 1rem;
        border-radius: 14px;
        line-height: 1.6;
        font-size: 0.92rem;
        word-wrap: break-word;
        position: relative;
      }
      .bubble .md { white-space: normal; }
      .bubble.user {
        background: var(--user-bubble);
        color: var(--user-bubble-text);
        border-bottom-right-radius: 4px;
      }
      .bubble.ai {
        background: var(--ai-bubble);
        color: var(--text-soft);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border);
      }
      .bubble.ai.empty { color: var(--muted-2); font-style: italic; }
      /* ─── Markdown content inside bubbles ─── */
      .md {
        white-space: normal;
      }
      .md > *:first-child { margin-top: 0; }
      .md > *:last-child { margin-bottom: 0; }
      .md p { margin: 0.5rem 0; line-height: 1.65; }
      .md h1, .md h2, .md h3, .md h4 {
        margin: 1rem 0 0.45rem;
        line-height: 1.3;
        font-weight: 600;
        color: var(--text);
      }
      .md h1 { font-size: 1.15rem; }
      .md h2 { font-size: 1.05rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      .md h3 { font-size: 0.95rem; }
      .md h4 { font-size: 0.88rem; color: var(--text-soft); }
      .md ul, .md ol { margin: 0.5rem 0; padding-left: 1.4rem; }
      .md li { margin: 0.15rem 0; }
      .md li > p { margin: 0.2rem 0; }
      .md blockquote {
        margin: 0.6rem 0;
        padding: 0.25rem 0.8rem;
        border-left: 3px solid var(--accent);
        background: rgba(34, 197, 94, 0.05);
        color: var(--muted);
      }
      .md a {
        color: var(--accent);
        text-decoration: none;
        border-bottom: 1px dashed var(--accent);
      }
      .md a:hover { color: var(--accent-2); border-bottom-style: solid; }
      .md strong { color: var(--text); font-weight: 600; }
      .md em { font-style: italic; color: var(--text-soft); }
      .md hr { border: 0; border-top: 1px solid var(--border); margin: 1rem 0; }
      .md table {
        border-collapse: collapse;
        margin: 0.75rem 0;
        font-size: 0.85rem;
        width: 100%;
      }
      .md th, .md td {
        border: 1px solid var(--border);
        padding: 0.35rem 0.7rem;
        text-align: left;
      }
      .md th {
        background: var(--panel-2);
        color: var(--text);
        font-weight: 600;
        font-size: 0.8rem;
      }
      .md pre {
        margin: 0.65rem 0;
        padding: 0.75rem 1rem;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 8px;
        font-size: 0.82rem;
        line-height: 1.55;
        overflow-x: auto;
        white-space: pre;
      }
      .md pre code {
        color: var(--text-soft);
        background: transparent;
        padding: 0;
        font-size: inherit;
      }
      .md code:not(pre code) {
        padding: 0.1em 0.35em;
        background: var(--code-bg);
        border: 1px solid var(--code-border);
        border-radius: 4px;
        font-size: 0.86em;
        color: var(--accent-2);
      }
      .md img {
        max-width: 100%;
        border-radius: 8px;
        margin: 0.5rem 0;
      }
      .md input[type="checkbox"] { margin-right: 0.4rem; }

      .bubble-footer {
        margin-top: 0.45rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.55rem;
        background: var(--chip-bg);
        border: 1px solid var(--border);
        border-radius: 999px;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .chip.tool { color: var(--accent); border-color: var(--accent); background: var(--accent-dim); }
      .chip.file::before {
        content: "📄";
        font-size: 0.7rem;
        opacity: 0.6;
      }
      .turn-label {
        color: var(--muted-2);
        font-size: 0.65rem;
        font-family: 'JetBrains Mono', monospace;
        margin: 0 0.5rem;
        align-self: flex-end;
      }

      .bubble-actions {
        position: absolute;
        top: -0.5rem;
        right: 0.5rem;
        display: none;
        gap: 0.2rem;
      }
      .bubble:hover .bubble-actions { display: flex; }
      .bubble-actions button {
        padding: 0.15rem 0.45rem;
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        color: var(--muted);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.65rem;
      }
      .bubble-actions button:hover { color: var(--text); border-color: var(--accent); }

      .collapsed-hint {
        color: var(--muted-2);
        font-size: 0.75rem;
        cursor: pointer;
        margin-top: 0.3rem;
        font-style: italic;
      }
      .collapsed-hint:hover { color: var(--accent); }

      /* Diff */
      .diff-pane {
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
      }
      .diff-file {
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        background: var(--panel);
      }
      .diff-file-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1rem;
        background: var(--panel-2);
        border-bottom: 1px solid var(--border);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        color: var(--text);
        cursor: pointer;
      }
      .diff-file-header:hover { background: var(--panel-3); }
      .diff-file-header .caret {
        color: var(--muted);
        transition: transform 150ms;
        display: inline-block;
      }
      .diff-file.collapsed .caret { transform: rotate(-90deg); }
      .diff-file.collapsed .diff-body, .diff-file.collapsed .diff-truncated { display: none; }
      .diff-file-header .stats {
        margin-left: auto;
        font-size: 0.7rem;
        color: var(--muted);
        display: flex;
        gap: 0.5rem;
      }
      .diff-file-header .stats .added { color: var(--diff-add-text); }
      .diff-file-header .stats .removed { color: var(--diff-del-text); }
      .diff-body {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.76rem;
        line-height: 1.55;
        overflow-x: auto;
      }
      .diff-line {
        display: grid;
        grid-template-columns: 48px 1fr;
        white-space: pre;
      }
      .diff-line .lineno {
        background: var(--panel);
        color: var(--muted-2);
        padding: 0 0.5rem;
        text-align: right;
        font-size: 0.7rem;
        border-right: 1px solid var(--border);
        user-select: none;
      }
      .diff-line .content { padding: 0 1rem; }
      .diff-line.add .content { background: var(--diff-add); color: var(--diff-add-text); }
      .diff-line.del .content { background: var(--diff-del); color: var(--diff-del-text); }
      .diff-line.hunk .content { background: var(--diff-hunk); color: var(--diff-hunk-text); font-weight: 600; }
      .diff-line.meta { display: none; } /* suppress diff/index/+++/--- headers for cleanliness */
      .diff-truncated {
        padding: 0.5rem 1rem;
        color: var(--muted);
        font-style: italic;
        background: var(--panel-2);
        border-top: 1px solid var(--border);
        font-size: 0.74rem;
      }

      /* ─── Split layout (wide) ─── */
      .split {
        display: none;
      }
      .app.wide .split {
        display: grid;
        grid-template-rows: 1fr;
        max-height: calc(100vh - 230px);
      }
      .app.wide .main-inner {
        display: flex;
        flex-direction: column;
        height: 100vh;
      }
      .split-pane {
        overflow-y: auto;
        padding-right: 0.5rem;
        scrollbar-width: thin;
        scrollbar-color: var(--border-strong) transparent;
      }
      .split-pane::-webkit-scrollbar { width: 6px; }
      .split-pane::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }

      .right-rail {
        padding: 1.5rem 1.25rem;
        background: var(--panel);
        border-left: 1px solid var(--border);
        overflow-y: auto;
        max-height: 100vh;
      }
      @media (max-width: 1280px) {
        .app.wide { grid-template-columns: 300px 1fr; }
        .app.wide .right-rail { display: none; }
      }
      .right-rail h3 {
        margin: 0 0 0.5rem;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .right-rail .section { margin-bottom: 1.5rem; }
      .right-rail .file-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 0.78rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        cursor: default;
      }
      .right-rail .file-row:hover { background: var(--panel-2); color: var(--text); }
      .right-rail .file-row .by_ai { color: var(--accent); }
      .right-rail .file-row .by_human { color: var(--muted-2); }
      .right-rail .kv {
        font-size: 0.78rem;
        color: var(--muted);
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 0.3rem 0.8rem;
      }
      .right-rail .kv dt { color: var(--muted-2); font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; }
      .right-rail .kv dd { margin: 0; color: var(--text-soft); font-family: 'JetBrains Mono', monospace; font-size: 0.76rem; }

      /* Empty state */
      .empty {
        padding: 4rem 1rem;
        text-align: center;
        color: var(--muted);
      }
      .empty .big { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.4; }

      /* Toast */
      .toast {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        padding: 0.6rem 1rem;
        background: var(--panel-3);
        border: 1px solid var(--accent);
        border-radius: 10px;
        color: var(--accent-2);
        font-size: 0.85rem;
        transition: transform 200ms ease;
        z-index: 60;
        font-family: 'JetBrains Mono', monospace;
      }
      .toast.show { transform: translateX(-50%) translateY(0); }

      /* Keyboard hints */
      .hints {
        margin-top: 2rem;
        padding: 1rem 1.25rem;
        background: var(--panel);
        border-radius: 10px;
        font-size: 0.78rem;
        color: var(--muted);
        line-height: 1.8;
      }
      .hints kbd {
        background: var(--panel-3);
        border: 1px solid var(--border-strong);
        padding: 0.1rem 0.45rem;
        border-radius: 4px;
        font-size: 0.75rem;
        color: var(--text-soft);
      }
    </style>
  </head>
  <body>
    <div class="overlay" id="overlay"></div>
    <div class="app" id="app">
      <!-- ─── Sidebar ─── -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <a href={homePath} class="logo">Agent Note</a>
          <span class="badge accent">Preview</span>
        </div>
        <div class="tab-row" id="tab-row">
          <button data-tab="prs" class="active">PRs</button>
          <button data-tab="commits">Commits</button>
          <button data-tab="sessions">Sessions</button>
        </div>
        <div class="search">
          <input id="search-box" type="search" placeholder="Search…" autocomplete="off" />
          <kbd>/</kbd>
        </div>
        <div class="sidebar-list" id="sidebar-list">
          <div class="empty"><div class="big">⏳</div>Loading…</div>
        </div>
      </aside>

      <!-- ─── Main ─── -->
      <main class="main" id="main">
        <div class="main-inner" id="main-inner">
          <div class="topbar">
            <button class="icon-btn hamburger" id="btn-menu" aria-label="Menu">☰</button>
            <button class="icon-btn" id="btn-prev" aria-label="Previous commit">← prev</button>
            <button class="icon-btn" id="btn-next" aria-label="Next commit">next →</button>
            <div class="spacer"></div>
            <button class="icon-btn" id="btn-share" aria-label="Share">🔗 Share</button>
            <a class="icon-btn" id="btn-github" href={repoUrl} target="_blank" rel="noopener">GitHub ↗</a>
          </div>

          <div id="root">
            <div class="empty">
              <div class="big">💬</div>
              Pick a commit from the sidebar.
            </div>
          </div>
        </div>
      </main>

      <!-- ─── Right rail (shown only in wide mode) -->
      <aside class="right-rail" id="rail" hidden>
        <div class="section">
          <h3>Meta</h3>
          <dl class="kv" id="rail-kv"></dl>
        </div>
        <div class="section">
          <h3>Files in Commit</h3>
          <div id="rail-files"></div>
        </div>
      </aside>
    </div>

    <div class="toast" id="toast"></div>

    <script is:inline define:vars={{ indexPath, baseUrl, repoUrl }}>
      const state = {
        index: null,
        current: null,
        currentNote: null,
        tab: "chat",            // main tabs: chat | diff
        sideTab: "prs",         // sidebar tabs: prs | commits | sessions
        search: "",
        flatCommits: [],
        wide: false,
      };

      // ─── Utilities ───
      function h(tag, attrs = {}, children = []) {
        const el = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (v == null || v === false) continue;
          if (k === "className") el.className = v;
          else if (k === "html") el.innerHTML = v;
          else if (k.startsWith("on") && typeof v === "function") el.addEventListener(k.slice(2).toLowerCase(), v);
          else if (k === "dataset") for (const [dk, dv] of Object.entries(v)) el.dataset[dk] = dv;
          else el.setAttribute(k, v);
        }
        for (const c of [].concat(children)) {
          if (c == null || c === false) continue;
          el.appendChild(typeof c === "string" ? document.createTextNode(c) : c);
        }
        return el;
      }
      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) => ({
          "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;",
        })[c]);
      }
      function formatDate(iso) {
        if (!iso) return "";
        try {
          return new Date(iso).toLocaleDateString(undefined, { year: "numeric", month: "short", day: "numeric" });
        } catch { return iso; }
      }
      function formatDateTime(iso) {
        if (!iso) return "";
        try { return new Date(iso).toLocaleString(); } catch { return iso; }
      }
      function setUrlParam(key, value) {
        const url = new URL(window.location.href);
        if (value == null || value === "") url.searchParams.delete(key);
        else url.searchParams.set(key, String(value));
        history.replaceState(null, "", url);
      }
      function toast(msg) {
        const el = document.getElementById("toast");
        el.textContent = msg;
        el.classList.add("show");
        clearTimeout(toast._t);
        toast._t = setTimeout(() => el.classList.remove("show"), 1800);
      }
      function copyToClipboard(text) {
        if (navigator.clipboard) navigator.clipboard.writeText(text).then(() => toast("Copied"));
      }

      // Markdown renderer (lazy-loaded from CDN + sanitized).
      let _markdownPromise = null;
      function loadMarkdown() {
        if (!_markdownPromise) {
          _markdownPromise = Promise.all([
            import("https://esm.sh/marked@12"),
            import("https://esm.sh/dompurify@3"),
          ]).then(([markedMod, dompurifyMod]) => {
            const marked = markedMod.marked ?? markedMod.default;
            const DOMPurify = dompurifyMod.default ?? dompurifyMod;
            marked.setOptions({
              breaks: true,
              gfm: true,
            });
            return { marked, DOMPurify };
          });
        }
        return _markdownPromise;
      }
      function renderMarkdownInto(container, text) {
        container.classList.add("md");
        // Render sync with fallback (plain text) so UI shows something immediately;
        // upgrade to rendered markdown once the library lands.
        container.textContent = text || "";
        loadMarkdown().then(({ marked, DOMPurify }) => {
          try {
            const html = marked.parse(text || "");
            const safe = DOMPurify.sanitize(html, {
              ALLOWED_ATTR: ["href", "title", "target", "rel", "class", "type", "checked", "disabled"],
            });
            container.innerHTML = safe;
            // Open links in new tab
            container.querySelectorAll("a").forEach((a) => {
              a.setAttribute("target", "_blank");
              a.setAttribute("rel", "noopener noreferrer");
            });
          } catch (err) {
            // keep the plain text fallback
          }
        }).catch(() => { /* keep fallback */ });
      }

      // ─── Sidebar ───
      function getFilteredCommits() {
        const q = state.search.trim().toLowerCase();
        const commits = state.index?.commits || [];
        if (!q) return commits;
        return commits.filter((c) => {
          const hay = [c.message, c.short_sha, c.author, c.agent].filter(Boolean).join(" ").toLowerCase();
          return hay.includes(q);
        });
      }

      function renderSidebar() {
        const list = document.getElementById("sidebar-list");
        list.innerHTML = "";
        if (!state.index) return;
        const filtered = getFilteredCommits();

        if (state.sideTab === "prs") {
          const prs = state.index.prs || [];
          if (prs.length === 0) {
            list.appendChild(h("div", { className: "empty" }, "No PRs yet"));
            return;
          }
          list.appendChild(h("div", { className: "group-label" }, "Pull Requests"));
          for (const pr of prs) {
            const prCommits = pr.commits
              .map((sha) => state.index.commits.find((c) => c.short_sha === sha || c.sha === sha))
              .filter(Boolean);
            const avgRatio = prCommits.length
              ? Math.round(prCommits.reduce((a, c) => a + (c.ai_ratio ?? 0), 0) / prCommits.length)
              : 0;
            const active = state.current?.prNumber === pr.number;
            const card = h("div", {
              className: "pr-card" + (active ? " active" : ""),
              onClick: () => selectPR(pr.number),
            }, [
              h("div", { className: "card-title" }, "#" + pr.number + " " + pr.title),
              h("div", { className: "card-meta" }, [
                h("span", {}, prCommits.length + " commits"),
                h("span", { className: "ratio" }, "🤖 " + avgRatio + "%"),
              ]),
              h("div", { className: "ratio-bar" }, h("span", { style: "width:" + avgRatio + "%;" })),
            ]);
            list.appendChild(card);
          }
          return;
        }

        if (state.sideTab === "commits") {
          list.appendChild(h("div", { className: "group-label" }, "Commits (newest first)"));
          const sorted = [...filtered].sort((a, b) => (b.date || "").localeCompare(a.date || ""));
          if (sorted.length === 0) {
            list.appendChild(h("div", { className: "empty" }, "No matches"));
            return;
          }
          for (const c of sorted) {
            const active = state.current?.commit === c.short_sha;
            const item = h("div", {
              className: "commit-card" + (active ? " active" : ""),
              onClick: () => selectCommit(c.short_sha),
            }, [
              h("div", { className: "card-title" }, c.message || "(no message)"),
              h("div", { className: "card-meta" }, [
                h("span", { className: "sha" }, c.short_sha),
                h("span", { className: "ratio" }, "🤖 " + (c.ai_ratio ?? 0) + "%"),
                h("span", {}, c.turns + "p"),
                c.date && h("span", {}, formatDate(c.date)),
              ].filter(Boolean)),
            ]);
            list.appendChild(item);
          }
          return;
        }

        if (state.sideTab === "sessions") {
          list.appendChild(h("div", { className: "group-label" }, "Sessions"));
          // group commits by session_id
          const sessions = new Map();
          for (const c of filtered) {
            const sid = c.session_id || "(unknown)";
            if (!sessions.has(sid)) sessions.set(sid, []);
            sessions.get(sid).push(c);
          }
          if (sessions.size === 0) {
            list.appendChild(h("div", { className: "empty" }, "No sessions"));
            return;
          }
          for (const [sid, commits] of sessions) {
            const short = sid.slice(0, 8);
            const active = state.current?.session === sid;
            const avgRatio = Math.round(commits.reduce((a, c) => a + (c.ai_ratio ?? 0), 0) / commits.length);
            const card = h("div", {
              className: "session-card" + (active ? " active" : ""),
              onClick: () => commits[0] && selectCommit(commits[0].short_sha),
            }, [
              h("div", { className: "card-title" }, "Session " + short),
              h("div", { className: "card-meta" }, [
                h("span", {}, commits.length + " commits"),
                h("span", { className: "ratio" }, "🤖 " + avgRatio + "%"),
              ]),
            ]);
            list.appendChild(card);
          }
        }
      }

      // ─── Navigation ───
      async function selectCommit(shortSha) {
        const summary = (state.index?.commits || []).find((c) => c.short_sha === shortSha);
        if (!summary) return;
        // Find which PR contains this commit
        const pr = (state.index.prs || []).find((p) => p.commits.includes(shortSha));
        state.current = {
          commit: shortSha,
          prNumber: pr?.number ?? null,
          session: summary.session_id ?? null,
        };
        setUrlParam("commit", shortSha);
        setUrlParam("pr", pr?.number ?? null);
        try {
          const baseAbs = new URL(indexPath, window.location.origin).toString();
          const noteUrl = new URL(summary.note_url, baseAbs).toString();
          const res = await fetch(noteUrl);
          state.currentNote = await res.json();
        } catch (err) {
          state.currentNote = null;
        }
        renderSidebar();
        renderMain();
        renderRail();
        updateNavButtons();
        closeMobileSidebar();
      }

      function selectPR(num) {
        const pr = (state.index?.prs || []).find((p) => p.number === num);
        if (!pr?.commits?.length) return;
        // open first commit in PR
        selectCommit(pr.commits[0]);
      }

      function neighborCommit(dir) {
        const list = state.flatCommits;
        const idx = list.findIndex((c) => c.short_sha === state.current?.commit);
        if (idx === -1) return null;
        const next = list[idx + dir];
        return next ? next.short_sha : null;
      }

      function updateNavButtons() {
        const prev = neighborCommit(-1);
        const next = neighborCommit(1);
        document.getElementById("btn-prev").toggleAttribute("disabled", !prev);
        document.getElementById("btn-next").toggleAttribute("disabled", !next);
      }

      // ─── Main ───
      function renderCommitHeader(note) {
        const c = note.commit || {};
        const attr = note.attribution || {};
        const files = note.files || [];
        const aiFiles = files.filter((f) => f.by_ai).length;
        const ratio = attr.ai_ratio ?? 0;

        const shaSpan = h("span", {
          className: "sha",
          title: "Click to copy full SHA",
          onClick: () => {
            copyToClipboard(c.sha || c.short_sha || "");
            shaSpan.classList.add("copied");
            setTimeout(() => shaSpan.classList.remove("copied"), 1200);
          },
        }, c.short_sha || (c.sha || "").slice(0, 7));

        return h("div", { className: "commit-head" }, [
          h("h1", { className: "commit-title" }, c.message || "(no message)"),
          h("div", { className: "commit-meta-row" }, [
            shaSpan,
            note.agent && h("span", {}, note.agent),
            note.model && h("span", {}, note.model),
            c.author && h("span", {}, c.author),
            c.date && h("span", {}, formatDateTime(c.date)),
          ].filter(Boolean)),
          h("div", { className: "stats-row" }, [
            h("span", { className: "stat primary bar" }, [
              h("span", {}, "🤖 " + ratio + "%"),
              h("span", { className: "track" }, h("span", { style: "width:" + ratio + "%;" })),
            ]),
            attr.lines && h("span", { className: "stat outline" }, attr.lines.ai_added + "/" + attr.lines.total_added + " lines"),
            files.length > 0 && h("span", { className: "stat outline" }, aiFiles + "/" + files.length + " files"),
            note.interactions && h("span", { className: "stat outline" }, note.interactions.length + " turns"),
          ].filter(Boolean)),
        ]);
      }

      function renderTurn(interaction, idx, total) {
        const tools = interaction.tools || [];
        const files = interaction.files_touched || [];

        // User bubble — prompts are usually plain text (user input), render as markdown too for inline code support
        const userBody = h("div", {});
        renderMarkdownInto(userBody, interaction.prompt || "");
        const userRow = h("div", { className: "bubble-row from-user" }, [
          h("span", { className: "turn-label" }, "#" + (idx + 1)),
          h("div", {
            className: "bubble user",
            dataset: { turn: String(idx + 1) },
          }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy prompt",
                onClick: () => copyToClipboard(interaction.prompt || ""),
              }, "📋"),
              h("button", {
                title: "Permalink",
                onClick: () => {
                  const url = new URL(window.location.href);
                  url.hash = "t-" + (idx + 1);
                  copyToClipboard(url.toString());
                },
              }, "🔗"),
            ]),
            userBody,
          ]),
          h("div", { className: "avatar" }, "🧑"),
        ]);

        // AI bubble — markdown-rendered
        const hasResp = !!interaction.response;
        const aiBody = h("div", {});
        if (hasResp) renderMarkdownInto(aiBody, interaction.response);
        else aiBody.textContent = "(no response captured)";
        const aiRow = h("div", { className: "bubble-row from-ai" }, [
          h("div", { className: "avatar ai" }, "🤖"),
          h("div", { className: "bubble ai" + (hasResp ? "" : " empty") }, [
            h("div", { className: "bubble-actions" }, [
              h("button", {
                title: "Copy response",
                onClick: () => copyToClipboard(interaction.response || ""),
              }, "📋"),
            ]),
            aiBody,
          ]),
        ]);

        const footer = [];
        for (const t of tools) footer.push(h("span", { className: "chip tool" }, t));
        for (const f of files) footer.push(h("span", { className: "chip file" }, f.split("/").pop()));

        return h("div", { className: "turn", id: "t-" + (idx + 1) }, [
          h("div", { className: "turn-divider" }, "turn " + (idx + 1) + " / " + total),
          userRow,
          aiRow,
          footer.length > 0 && h("div", { className: "bubble-footer", style: "margin-left: 2.3rem;" }, footer),
        ].filter(Boolean));
      }

      function renderChat(note) {
        const thread = h("div", { className: "chat-pane" });
        const interactions = note.interactions || [];
        interactions.forEach((i, idx) => thread.appendChild(renderTurn(i, idx, interactions.length)));
        return thread;
      }

      function diffStats(file) {
        let added = 0, removed = 0;
        for (const line of file.lines || []) {
          if (line.startsWith("+") && !line.startsWith("+++")) added++;
          else if (line.startsWith("-") && !line.startsWith("---")) removed++;
        }
        return { added, removed };
      }

      function renderDiff(note) {
        const wrap = h("div", { className: "diff-pane" });
        const diff = note.diff;
        if (!diff?.files?.length) {
          wrap.appendChild(h("div", { className: "empty" }, [h("div", { className: "big" }, "📄"), "No diff captured"]));
          return wrap;
        }
        for (const file of diff.files) {
          const { added, removed } = diffStats(file);
          const header = h("div", {
            className: "diff-file-header",
            onClick: (e) => {
              const parent = e.currentTarget.parentElement;
              parent.classList.toggle("collapsed");
            },
          }, [
            h("span", { className: "caret" }, "▾"),
            h("span", {}, file.path),
            h("span", { className: "stats" }, [
              h("span", { className: "added" }, "+" + added),
              h("span", { className: "removed" }, "−" + removed),
            ]),
          ]);

          const body = h("div", { className: "diff-body" });
          let oldNo = 0, newNo = 0;
          for (const line of file.lines || []) {
            let cls = "diff-line";
            let num = "";
            if (line.startsWith("@@")) {
              cls += " hunk";
              const m = line.match(/\+(\d+)/);
              if (m) newNo = parseInt(m[1], 10) - 1;
              const m2 = line.match(/-(\d+)/);
              if (m2) oldNo = parseInt(m2[1], 10) - 1;
              num = "";
            } else if (line.startsWith("+") && !line.startsWith("+++")) {
              cls += " add"; newNo++; num = String(newNo);
            } else if (line.startsWith("-") && !line.startsWith("---")) {
              cls += " del"; oldNo++; num = String(oldNo);
            } else if (line.startsWith("diff ") || line.startsWith("index ") || line.startsWith("---") || line.startsWith("+++") || line.startsWith("new file") || line.startsWith("deleted file") || line.startsWith("rename") || line.startsWith("similarity")) {
              cls += " meta";
              num = "";
            } else {
              oldNo++; newNo++; num = String(newNo);
            }
            body.appendChild(h("div", { className: cls }, [
              h("span", { className: "lineno" }, num),
              h("span", { className: "content" }, line || " "),
            ]));
          }

          const fileEl = h("div", { className: "diff-file" }, [
            header,
            body,
            file.truncated && h("div", { className: "diff-truncated" }, "(diff truncated at 400 lines)"),
          ].filter(Boolean));
          wrap.appendChild(fileEl);
        }
        return wrap;
      }

      function renderViewTabs() {
        const tabs = [
          { id: "chat", label: "💬 Chat" },
          { id: "diff", label: "📝 Diff" },
        ];
        return h("div", { className: "view-tabs" },
          tabs.map((t) => h("button", {
            className: state.tab === t.id ? "active" : "",
            onClick: () => {
              state.tab = t.id;
              setUrlParam("tab", t.id === "chat" ? null : t.id);
              renderMain();
            },
          }, t.label))
        );
      }

      function renderKeyboardHints() {
        return h("div", { className: "hints" }, [
          h("span", {}, "Tip: "),
          h("kbd", {}, "/"), " to focus search · hover a bubble for copy / permalink.",
        ]);
      }

      function renderMain() {
        const root = document.getElementById("root");
        root.innerHTML = "";
        if (!state.currentNote) {
          root.appendChild(h("div", { className: "empty" }, [
            h("div", { className: "big" }, "💬"),
            "Pick a commit from the sidebar.",
          ]));
          return;
        }
        const note = state.currentNote;
        root.appendChild(renderCommitHeader(note));

        if (state.wide) {
          const splitChat = h("div", { className: "split-pane" }, renderChat(note));
          const splitDiff = h("div", { className: "split-pane" }, renderDiff(note));
          root.appendChild(h("div", { className: "split" }, [splitChat, splitDiff]));
        } else {
          root.appendChild(renderViewTabs());
          root.appendChild(state.tab === "diff" ? renderDiff(note) : renderChat(note));
        }
        root.appendChild(renderKeyboardHints());

        // Scroll to anchor if any
        if (window.location.hash) {
          const el = document.querySelector(window.location.hash);
          if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      function renderRail() {
        const rail = document.getElementById("rail");
        if (!state.wide || !state.currentNote) { rail.hidden = true; return; }
        rail.hidden = false;
        const note = state.currentNote;
        const kv = document.getElementById("rail-kv");
        kv.innerHTML = "";
        const rows = [
          ["agent", note.agent],
          ["model", note.model],
          ["session", (note.session_id || "").slice(0, 8) + "…"],
          ["method", note.attribution?.method],
          ["added", (note.attribution?.lines?.ai_added ?? 0) + " / " + (note.attribution?.lines?.total_added ?? 0)],
          ["deleted", String(note.attribution?.lines?.deleted ?? 0)],
        ];
        for (const [k, v] of rows) {
          if (v == null) continue;
          kv.appendChild(h("dt", {}, k));
          kv.appendChild(h("dd", {}, String(v)));
        }

        const files = document.getElementById("rail-files");
        files.innerHTML = "";
        for (const f of note.files || []) {
          files.appendChild(h("div", { className: "file-row" }, [
            h("span", { className: f.by_ai ? "by_ai" : "by_human" }, f.by_ai ? "🤖" : "👤"),
            h("span", { title: f.path }, f.path.split("/").slice(-2).join("/")),
          ]));
        }
      }

      // ─── Mobile sidebar drawer ───
      function openMobileSidebar() {
        document.getElementById("sidebar").classList.add("open");
        document.getElementById("overlay").classList.add("show");
      }
      function closeMobileSidebar() {
        document.getElementById("sidebar").classList.remove("open");
        document.getElementById("overlay").classList.remove("show");
      }

      // ─── Wide mode detect ───
      function detectWide() {
        state.wide = window.innerWidth >= 1280;
        document.getElementById("app").classList.toggle("wide", state.wide);
      }

      // ─── Init ───
      function bindTopbar() {
        document.getElementById("btn-menu").addEventListener("click", openMobileSidebar);
        document.getElementById("overlay").addEventListener("click", closeMobileSidebar);
        document.getElementById("btn-prev").addEventListener("click", () => {
          const s = neighborCommit(-1);
          if (s) selectCommit(s);
        });
        document.getElementById("btn-next").addEventListener("click", () => {
          const s = neighborCommit(1);
          if (s) selectCommit(s);
        });
        document.getElementById("btn-share").addEventListener("click", () => {
          copyToClipboard(window.location.href);
        });
      }

      function bindSidebarTabs() {
        for (const btn of document.querySelectorAll("#tab-row button")) {
          btn.addEventListener("click", () => {
            document.querySelectorAll("#tab-row button").forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");
            state.sideTab = btn.dataset.tab;
            renderSidebar();
          });
        }
      }

      function bindKeyboard() {
        window.addEventListener("keydown", (e) => {
          if (e.target.tagName === "INPUT") {
            if (e.key === "Escape") e.target.blur();
            return;
          }
          if (e.key === "/") {
            e.preventDefault();
            document.getElementById("search-box").focus();
          }
        });
      }

      function bindSearch() {
        const input = document.getElementById("search-box");
        input.addEventListener("input", (e) => {
          state.search = e.target.value || "";
          renderSidebar();
        });
      }

      function restoreFromUrl() {
        const p = new URLSearchParams(window.location.search);
        const tab = p.get("tab");
        if (tab === "diff") state.tab = "diff";
        const commit = p.get("commit");
        if (commit) return selectCommit(commit);
        const pr = p.get("pr");
        if (pr && state.index?.prs) {
          const match = state.index.prs.find((x) => String(x.number) === pr);
          if (match?.commits?.length) return selectCommit(match.commits[0]);
        }
        if (state.index?.commits?.length) return selectCommit(state.index.commits[0].short_sha);
      }

      async function init() {
        detectWide();
        window.addEventListener("resize", () => {
          const old = state.wide;
          detectWide();
          if (old !== state.wide) {
            renderMain();
            renderRail();
          }
        });

        try {
          const res = await fetch(indexPath);
          state.index = await res.json();
        } catch (err) {
          document.getElementById("sidebar-list").innerHTML =
            '<div class="empty">Failed to load index: ' + String(err) + "</div>";
          return;
        }

        // Build flat-sorted commit list for keyboard/prev/next (newest first)
        state.flatCommits = [...(state.index.commits || [])].sort((a, b) => (b.date || "").localeCompare(a.date || ""));

        // For each commit, try to grab session_id from fetched note (lazy) or default to null
        bindTopbar();
        bindSidebarTabs();
        bindKeyboard();
        bindSearch();
        renderSidebar();
        await restoreFromUrl();
      }

      init();
    </script>
  </body>
</html>
