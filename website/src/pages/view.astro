---
const homePath = `${import.meta.env.BASE_URL}`;
const baseUrl = import.meta.env.BASE_URL;
const indexPath = `${baseUrl}/view-demo/index.json`.replace(/\/+/g, "/");
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Agent Note — Chat Viewer</title>
    <link rel="icon" href={`${baseUrl}/favicon.svg`.replace(/\/+/g, "/")} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0f172a;
        --panel-2: #1e293b;
        --border: #334155;
        --border-soft: #1e293b;
        --text: #f8fafc;
        --muted: #94a3b8;
        --muted-2: #64748b;
        --accent: #22c55e;
        --accent-dim: rgba(34, 197, 94, 0.12);
        --user-bubble: #14532d;
        --user-bubble-text: #dcfce7;
        --ai-bubble: #1e293b;
        --chip-bg: #0f172a;
        --diff-add: rgba(34, 197, 94, 0.14);
        --diff-add-text: #86efac;
        --diff-del: rgba(239, 68, 68, 0.14);
        --diff-del-text: #fca5a5;
        --diff-hunk: rgba(59, 130, 246, 0.1);
        --diff-hunk-text: #93c5fd;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        background: var(--bg); color: var(--text);
        font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, 'Hiragino Kaku Gothic ProN', sans-serif;
        min-height: 100vh;
      }
      code, pre { font-family: 'JetBrains Mono', ui-monospace, monospace; }

      .app {
        display: grid;
        grid-template-columns: 320px 1fr;
        min-height: 100vh;
      }
      @media (max-width: 820px) {
        .app { grid-template-columns: 1fr; }
        .sidebar { display: none; }
        .sidebar.open { display: block; position: fixed; inset: 0; z-index: 50; }
      }

      /* Sidebar */
      .sidebar {
        border-right: 1px solid var(--border-soft);
        background: var(--panel);
        display: flex;
        flex-direction: column;
        max-height: 100vh;
        overflow: hidden;
      }
      .sidebar-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border-soft);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .sidebar-header a {
        color: var(--text);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .sidebar-header .badge {
        padding: 0.15rem 0.55rem;
        font-size: 0.65rem;
        background: var(--accent-dim);
        border: 1px solid var(--accent);
        color: var(--accent);
        border-radius: 999px;
        font-family: 'JetBrains Mono', monospace;
      }
      .search {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--border-soft);
      }
      .search input {
        width: 100%;
        padding: 0.55rem 0.75rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text);
        font-family: inherit;
        font-size: 0.85rem;
      }
      .search input:focus {
        outline: none;
        border-color: var(--accent);
      }
      .sidebar-list {
        overflow-y: auto;
        flex: 1;
        padding-bottom: 2rem;
      }
      .section-label {
        padding: 0.75rem 1.25rem 0.25rem;
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .pr-item, .commit-item {
        padding: 0.65rem 1.25rem;
        border-bottom: 1px solid var(--border-soft);
        cursor: pointer;
        transition: background 120ms ease;
      }
      .pr-item:hover, .commit-item:hover {
        background: var(--panel-2);
      }
      .pr-item.active, .commit-item.active {
        background: var(--accent-dim);
        border-left: 3px solid var(--accent);
        padding-left: calc(1.25rem - 3px);
      }
      .pr-item .pr-title, .commit-item .commit-msg {
        font-size: 0.85rem;
        color: var(--text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      .pr-item .pr-meta, .commit-item .commit-meta {
        margin-top: 0.3rem;
        font-size: 0.7rem;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }
      .commit-item .commit-sha { color: var(--accent); }

      /* Main panel */
      .main {
        padding: 2rem 1.5rem 4rem;
        max-width: 900px;
        margin: 0 auto;
        width: 100%;
      }
      .empty {
        color: var(--muted);
        font-size: 0.9rem;
        padding: 4rem 1rem;
        text-align: center;
      }
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-bottom: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .topbar .right {
        font-size: 0.75rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
      }
      .commit-header {
        margin: 1rem 0 1.5rem;
        padding: 1.25rem 1.5rem;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
      }
      .commit-header h1 {
        margin: 0 0 0.5rem;
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .commit-header .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        font-size: 0.8rem;
        color: var(--muted);
      }
      .commit-header .meta .sha {
        font-family: 'JetBrains Mono', monospace;
        color: var(--accent);
      }
      .commit-header .stats {
        margin-top: 0.75rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }
      .stat {
        padding: 0.25rem 0.75rem;
        background: var(--accent-dim);
        border: 1px solid var(--accent);
        border-radius: 999px;
        font-size: 0.75rem;
        color: var(--accent);
        font-family: 'JetBrains Mono', monospace;
      }
      .stat.muted {
        background: transparent;
        border-color: var(--border);
        color: var(--muted);
      }

      /* Tabs */
      .tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 1px solid var(--border-soft);
        margin-bottom: 1rem;
      }
      .tab {
        padding: 0.5rem 1rem;
        background: transparent;
        color: var(--muted);
        border: none;
        border-bottom: 2px solid transparent;
        cursor: pointer;
        font-size: 0.85rem;
        font-family: inherit;
        transition: color 120ms;
      }
      .tab:hover { color: var(--text); }
      .tab.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
      }

      /* Chat */
      .thread { display: flex; flex-direction: column; gap: 1rem; }
      .turn { display: flex; flex-direction: column; gap: 0.5rem; }
      .bubble {
        max-width: min(78%, 620px);
        padding: 0.75rem 1rem;
        border-radius: 16px;
        line-height: 1.55;
        font-size: 0.9rem;
        white-space: pre-wrap;
        word-wrap: break-word;
      }
      .bubble.user {
        align-self: flex-end;
        background: var(--user-bubble);
        color: var(--user-bubble-text);
        border-bottom-right-radius: 4px;
      }
      .bubble.ai {
        align-self: flex-start;
        background: var(--ai-bubble);
        color: var(--text);
        border-bottom-left-radius: 4px;
        border: 1px solid var(--border-soft);
      }
      .bubble.ai.empty { color: var(--muted-2); font-style: italic; }
      .bubble-footer {
        margin-top: 0.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
      }
      .chip {
        padding: 0.15rem 0.55rem;
        background: var(--chip-bg);
        border: 1px solid var(--border-soft);
        border-radius: 999px;
        color: var(--muted);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.68rem;
      }
      .chip.tool { color: var(--accent); border-color: var(--accent); }
      .side {
        font-size: 0.7rem;
        color: var(--muted-2);
        font-family: 'JetBrains Mono', monospace;
        padding: 0 0.25rem;
      }
      .turn .side.right { align-self: flex-end; }
      .turn .side.left { align-self: flex-start; }

      /* Diff */
      .diff-file {
        margin-bottom: 1rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
      }
      .diff-file-header {
        padding: 0.65rem 1rem;
        background: var(--panel);
        color: var(--text);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        border-bottom: 1px solid var(--border-soft);
      }
      .diff-body {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.78rem;
        line-height: 1.55;
        overflow-x: auto;
      }
      .diff-body .diff-line {
        display: block;
        padding: 0 1rem;
        white-space: pre;
      }
      .diff-line.add { background: var(--diff-add); color: var(--diff-add-text); }
      .diff-line.del { background: var(--diff-del); color: var(--diff-del-text); }
      .diff-line.hunk { background: var(--diff-hunk); color: var(--diff-hunk-text); font-weight: 600; }
      .diff-line.meta { color: var(--muted-2); }
      .diff-truncated {
        padding: 0.5rem 1rem;
        color: var(--muted);
        font-style: italic;
        background: var(--panel);
        border-top: 1px solid var(--border-soft);
        font-size: 0.75rem;
      }

      .hint {
        padding: 1rem 1.25rem;
        margin-top: 2rem;
        background: var(--panel);
        border-left: 3px solid var(--accent);
        border-radius: 6px;
        font-size: 0.8rem;
        color: var(--muted);
        line-height: 1.6;
      }
      .hint code { color: var(--accent); background: var(--chip-bg); padding: 0.1em 0.3em; border-radius: 3px; font-size: 0.85em; }

      @media (max-width: 820px) {
        .bubble { max-width: 90%; }
        .main { padding: 1rem; }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <aside class="sidebar">
        <div class="sidebar-header">
          <a href={homePath}>← Agent Note</a>
          <span class="badge">PROTOTYPE</span>
        </div>
        <div class="search">
          <input id="search-box" type="search" placeholder="Search commits / prompts…" />
        </div>
        <div class="sidebar-list" id="sidebar-list">
          <div class="empty" style="padding: 1.5rem 1rem;">Loading…</div>
        </div>
      </aside>
      <main class="main">
        <div id="root">
          <div class="empty">Pick a commit from the left to start.</div>
        </div>
      </main>
    </div>

    <script is:inline define:vars={{ indexPath, baseUrl }}>
      const state = {
        index: null,
        currentCommit: null,
        currentNote: null,
        tab: "chat",
        search: "",
      };

      function h(tag, attrs = {}, children = []) {
        const el = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (v == null || v === false) continue;
          if (k === "className") el.className = v;
          else if (k === "html") el.innerHTML = v;
          else if (k.startsWith("on") && typeof v === "function") el.addEventListener(k.slice(2).toLowerCase(), v);
          else if (k === "dataset") for (const [dk, dv] of Object.entries(v)) el.dataset[dk] = dv;
          else el.setAttribute(k, v);
        }
        for (const c of [].concat(children)) {
          if (c == null || c === false) continue;
          el.appendChild(typeof c === "string" ? document.createTextNode(c) : c);
        }
        return el;
      }

      function formatDate(s) {
        if (!s) return "";
        try { return new Date(s).toLocaleString(); } catch { return s; }
      }

      function setUrlParam(key, value) {
        const url = new URL(window.location.href);
        if (value == null || value === "") url.searchParams.delete(key);
        else url.searchParams.set(key, value);
        history.replaceState(null, "", url);
      }

      // ─── Sidebar ───
      function renderSidebar() {
        const list = document.getElementById("sidebar-list");
        list.innerHTML = "";
        if (!state.index) return;

        const q = state.search.trim().toLowerCase();
        const matches = (commit) => {
          if (!q) return true;
          const hay = [
            commit.message,
            commit.short_sha,
            commit.author,
            commit.agent,
          ].filter(Boolean).join(" ").toLowerCase();
          return hay.includes(q);
        };

        // PRs section
        if (state.index.prs?.length) {
          list.appendChild(h("div", { className: "section-label" }, "Pull Requests"));
          for (const pr of state.index.prs) {
            const item = h("div", {
              className: "pr-item",
              onClick: () => { window.location.search = `?pr=${pr.number}`; },
            }, [
              h("div", { className: "pr-title" }, "#" + pr.number + " " + pr.title),
              h("div", { className: "pr-meta" }, [
                h("span", {}, pr.commits.length + " commits"),
              ]),
            ]);
            list.appendChild(item);
          }
        }

        list.appendChild(h("div", { className: "section-label" }, "Commits"));
        const commits = (state.index.commits || []).filter(matches);
        if (commits.length === 0) {
          list.appendChild(h("div", { className: "empty", style: "padding: 1rem;" }, "No matches"));
          return;
        }
        for (const c of commits) {
          const active = state.currentCommit === c.short_sha;
          const item = h("div", {
            className: "commit-item" + (active ? " active" : ""),
            onClick: () => selectCommit(c.short_sha),
          }, [
            h("div", { className: "commit-msg" }, c.message),
            h("div", { className: "commit-meta" }, [
              h("span", { className: "commit-sha" }, c.short_sha),
              h("span", {}, "🤖 " + (c.ai_ratio ?? 0) + "%"),
              h("span", {}, c.turns + "p"),
            ]),
          ]);
          list.appendChild(item);
        }
      }

      // ─── Main view ───
      function renderHeader(note) {
        const c = note.commit || {};
        const attr = note.attribution || {};
        const files = note.files || [];
        const aiFiles = files.filter((f) => f.by_ai).length;

        return h("div", { className: "commit-header" }, [
          c.message && h("h1", {}, c.message),
          h("div", { className: "meta" }, [
            c.short_sha && h("span", { className: "sha" }, c.short_sha),
            note.agent && h("span", {}, "agent: " + note.agent),
            note.model && h("span", {}, "model: " + note.model),
            c.date && h("span", {}, formatDate(c.date)),
            c.author && h("span", {}, c.author),
          ].filter(Boolean)),
          h("div", { className: "stats" }, [
            typeof attr.ai_ratio === "number" && h("span", { className: "stat" }, "🤖 " + attr.ai_ratio + "% AI"),
            attr.lines && h("span", { className: "stat" }, attr.lines.ai_added + "/" + attr.lines.total_added + " lines"),
            files.length > 0 && h("span", { className: "stat muted" }, aiFiles + "/" + files.length + " files AI"),
            note.interactions && h("span", { className: "stat muted" }, note.interactions.length + " turns"),
          ].filter(Boolean)),
        ].filter(Boolean));
      }

      function renderTabs() {
        const tabs = [
          { id: "chat", label: "💬 Chat" },
          { id: "diff", label: "📝 Diff" },
        ];
        return h("div", { className: "tabs" },
          tabs.map((t) => h("button", {
            className: "tab" + (state.tab === t.id ? " active" : ""),
            onClick: () => { state.tab = t.id; setUrlParam("tab", t.id === "chat" ? null : t.id); renderMain(); },
          }, t.label))
        );
      }

      function renderTurn(interaction, idx) {
        const tools = interaction.tools || [];
        const files = interaction.files_touched || [];
        const aiChips = [];
        for (const t of tools) aiChips.push(h("span", { className: "chip tool" }, t));
        for (const f of files) aiChips.push(h("span", { className: "chip" }, f.split("/").pop()));

        return h("div", { className: "turn" }, [
          h("div", { className: "side right" }, "🧑 user"),
          h("div", { className: "bubble user" }, interaction.prompt || ""),
          h("div", { className: "bubble-footer", style: "align-self: flex-end;" },
            [h("span", { className: "chip" }, "turn " + (idx + 1))]),
          h("div", { className: "side left", style: "margin-top: 0.5rem;" }, "🤖 " + (note_modelLabel() || "assistant")),
          h("div", {
            className: "bubble ai" + (interaction.response ? "" : " empty"),
          }, interaction.response || "(no response captured)"),
          aiChips.length > 0 && h("div", { className: "bubble-footer" }, aiChips),
        ].filter(Boolean));
      }

      function note_modelLabel() {
        return state.currentNote?.model || "assistant";
      }

      function renderChat(note) {
        const thread = h("div", { className: "thread" });
        (note.interactions || []).forEach((i, idx) => thread.appendChild(renderTurn(i, idx)));
        return thread;
      }

      function renderDiff(note) {
        const wrap = h("div", { className: "diff" });
        const diff = note.diff;
        if (!diff?.files?.length) {
          wrap.appendChild(h("div", { className: "empty", style: "padding: 2rem 0;" }, "No diff captured for this commit."));
          return wrap;
        }
        for (const file of diff.files) {
          const body = h("pre", { className: "diff-body" });
          for (const line of file.lines || []) {
            let cls = "diff-line";
            if (line.startsWith("+") && !line.startsWith("+++")) cls += " add";
            else if (line.startsWith("-") && !line.startsWith("---")) cls += " del";
            else if (line.startsWith("@@")) cls += " hunk";
            else if (line.startsWith("diff ") || line.startsWith("index ") || line.startsWith("---") || line.startsWith("+++") || line.startsWith("new file") || line.startsWith("deleted file") || line.startsWith("rename") || line.startsWith("similarity")) cls += " meta";
            body.appendChild(h("span", { className: cls }, line || " "));
          }
          wrap.appendChild(h("div", { className: "diff-file" }, [
            h("div", { className: "diff-file-header" }, file.path),
            body,
            file.truncated && h("div", { className: "diff-truncated" }, "(diff truncated at 400 lines)"),
          ].filter(Boolean)));
        }
        return wrap;
      }

      function renderMain() {
        const root = document.getElementById("root");
        root.innerHTML = "";

        if (!state.currentNote) {
          root.appendChild(h("div", { className: "empty" }, "Pick a commit from the left to start."));
          return;
        }

        const note = state.currentNote;
        root.appendChild(renderHeader(note));
        root.appendChild(renderTabs());
        if (state.tab === "chat") root.appendChild(renderChat(note));
        else if (state.tab === "diff") root.appendChild(renderDiff(note));

        root.appendChild(h("div", { className: "hint" }, [
          h("strong", {}, "Prototype."),
          " URL: ",
          h("code", {}, "?commit=" + state.currentCommit),
          " or ",
          h("code", {}, "?pr=<number>"),
          ". Demo data is bundled under ",
          h("code", {}, "/view-demo/"),
          "; a future CI step snapshots real notes.",
        ]));
      }

      // ─── Navigation ───
      async function selectCommit(shortSha) {
        state.currentCommit = shortSha;
        setUrlParam("commit", shortSha);
        const summary = (state.index?.commits || []).find((c) => c.short_sha === shortSha);
        if (!summary) return;
        const baseAbs = new URL(indexPath, window.location.origin).toString();
        const noteUrl = new URL(summary.note_url, baseAbs).toString();
        try {
          const res = await fetch(noteUrl);
          state.currentNote = await res.json();
        } catch (err) {
          state.currentNote = null;
        }
        renderSidebar();
        renderMain();
      }

      function restoreFromUrl() {
        const p = new URLSearchParams(window.location.search);
        const tab = p.get("tab");
        if (tab === "diff") state.tab = "diff";
        const commit = p.get("commit");
        if (commit) return selectCommit(commit);
        const pr = p.get("pr");
        if (pr && state.index?.prs) {
          const match = state.index.prs.find((x) => String(x.number) === pr);
          if (match?.commits?.length) return selectCommit(match.commits[0]);
        }
        // Default: load latest commit
        if (state.index?.commits?.length) return selectCommit(state.index.commits[0].short_sha);
      }

      async function init() {
        try {
          const res = await fetch(indexPath);
          state.index = await res.json();
        } catch (err) {
          document.getElementById("sidebar-list").innerHTML =
            '<div class="empty" style="padding: 1rem;">Failed to load index: ' + String(err) + "</div>";
          return;
        }

        const input = document.getElementById("search-box");
        input.addEventListener("input", (e) => {
          state.search = e.target.value || "";
          renderSidebar();
        });

        renderSidebar();
        await restoreFromUrl();
      }

      init();
    </script>
  </body>
</html>
