---
const homePath = `${import.meta.env.BASE_URL}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Agent Note</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #020617;
        --panel: #0f172a;
        --border: #334155;
        --text: #f8fafc;
        --muted: #94a3b8;
        --accent: #22c55e;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          radial-gradient(circle at top, rgba(34, 197, 94, 0.12), transparent 45%),
          var(--bg);
        color: var(--text);
        font-family: "IBM Plex Sans", system-ui, sans-serif;
      }

      main {
        max-width: 640px;
        width: 100%;
        padding: 32px;
        border: 1px solid var(--border);
        border-radius: 20px;
        background: rgba(15, 23, 42, 0.92);
        box-shadow: 0 24px 80px rgba(2, 6, 23, 0.35);
      }

      h1 {
        margin: 0 0 12px;
        font-size: clamp(2rem, 6vw, 3rem);
      }

      p {
        margin: 0 0 16px;
        line-height: 1.7;
        color: var(--muted);
      }

      a {
        display: inline-block;
        margin-top: 8px;
        padding: 12px 18px;
        border-radius: 10px;
        background: var(--accent);
        color: white;
        font-weight: 600;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Page Not Found</h1>
      <p>The page you requested does not exist, or the URL has changed.</p>
      <p>Try the docs home page and continue from the sidebar.</p>
      <a href={homePath}>Go to Agent Note Docs</a>
    </main>
  </body>
</html>
